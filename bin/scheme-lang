#!/usr/bin/env node
// bin/scheme-lang — the neutral launcher.
//
// Discovers installed Scheme dialects on this machine and either:
//   • 0 dialects       → prints a helpful "install Sakura" hint
//   • 1 dialect        → drops straight into its REPL (with its banner)
//   • N dialects       → clean menu picker (arrow keys, Enter)
//   • name specified   → skips menu, launches that dialect
//
// Doesn't ship an engine of its own. Every dialect binary — including the
// bundled `sakura-scheme` — is a separate wrapper that owns its own eval
// path. That's why swapping the Sakura dialect for a fork is a matter of
// dropping in a new `dialect.json` — no launcher code changes required.
//
// Alfred, 2026-07-12: "The user-facing command is `scheme-lang`, not
// `sakura-scheme` — because dialects may rename." So this binary picks
// (or is told), and delegates.

import { spawnSync } from 'node:child_process'
import { fileURLToPath } from 'node:url'
import { dirname, resolve } from 'node:path'
import { discoverDialects } from '../src/launcher/discover.js'
import { pickDialect } from '../src/launcher/menu.js'
import { role, PALETTE, fg } from '../src/repl/palette.js'

const LAUNCHER = fileURLToPath(import.meta.url)
const LAUNCHER_DIR = dirname(LAUNCHER)

function printHelp() {
  process.stdout.write(`scheme-lang — a launcher for Scheme dialects

Usage:
  scheme-lang                   discover installed dialects; menu if >1
  scheme-lang <name>            skip menu, launch <name> (e.g. 'sakura')
  scheme-lang <name> <cmd>...   forward remaining args to the dialect
  scheme-lang --list            list every dialect + source
  scheme-lang --help            this help
  scheme-lang --version         launcher version

Examples:
  scheme-lang                   → menu or direct launch
  scheme-lang sakura            → launch Sakura REPL
  scheme-lang sakura eval "(+ 1 2)"
  scheme-lang --list

Dialects are discovered at:
  ./dialect.json
  ./scheme-lang/dialect.json
  $XDG_DATA_HOME/scheme-lang/dialects/*/dialect.json
  ~/.scheme-lang/dialects/*/dialect.json
  /usr/local/share/scheme-lang/dialects/*/dialect.json

To install a dialect, drop its folder (with dialect.json) at any of
the above paths. See README.md for the dialect manifest format.
`)
}

function printList(dialects) {
  if (dialects.length === 0) {
    process.stdout.write(role.dim('  (no dialects installed)\n'))
    return
  }
  for (const d of dialects) {
    process.stdout.write(
      '  ' + role.strong(d.name.padEnd(16)) +
      role.dim('v' + (d.version || '0').padEnd(8)) +
      '  ' + role.text(d.entrypoint) + '\n'
    )
    if (d.tagline) process.stdout.write('    ' + role.dim(d.tagline) + '\n')
  }
}

function launchDialect(dialect, args) {
  // Delegate to the dialect's entrypoint.
  const r = spawnSync(dialect.entrypoint, args, { stdio: 'inherit' })
  process.exit(r.status || 0)
}

async function main() {
  const argv = process.argv.slice(2)

  // Launcher-only flags — must be the FIRST arg. Otherwise they get
  // forwarded to the dialect (so `scheme-lang sakura --version` shows
  // sakura's version, not the launcher's).
  if (argv[0] === '--help' || argv[0] === '-h') return printHelp()
  if (argv[0] === '--version' || argv[0] === '-v') {
    process.stdout.write('scheme-lang 1.0.0\n'); return
  }

  const dialects = discoverDialects({ launcherPath: LAUNCHER })

  if (argv[0] === '--list' || argv[0] === 'list') return printList(dialects)

  // Zero dialects → helpful message.
  if (dialects.length === 0) {
    process.stderr.write(`scheme-lang: no dialects found.

Install the Sakura core dialect:

  git clone https://github.com/lacuna-labs/sakura-scheme ~/.scheme-lang/dialects/sakura

or drop a directory with a dialect.json at one of the search paths
(run \`scheme-lang --help\` to see the list).

`)
    process.exit(1)
  }

  // Explicit dialect name given.
  if (argv.length > 0 && !argv[0].startsWith('-')) {
    const name = argv[0]
    const found = dialects.find(d => d.name === name)
    if (!found) {
      process.stderr.write(`scheme-lang: no dialect named '${name}'\n`)
      process.stderr.write('  installed dialects: ' + dialects.map(d => d.name).join(', ') + '\n')
      process.exit(2)
    }
    return launchDialect(found, argv.slice(1))
  }

  // 1 dialect → straight in.
  if (dialects.length === 1) return launchDialect(dialects[0], [])

  // N dialects → menu.
  const pick = await pickDialect(dialects)
  if (!pick) process.exit(0)
  return launchDialect(pick, [])
}

main().catch(e => {
  process.stderr.write('scheme-lang: ' + (e && e.message ? e.message : String(e)) + '\n')
  process.exit(1)
})
