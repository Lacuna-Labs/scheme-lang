    (:tier "master" :code "(define (summarize-folder folder)\n  (let ((msgs (read-gmail-folder folder)))\n    (list folder (if (list? msgs) (length msgs) 'unknown))))\n(summarize-folder \"inbox\")" :note "Summary with defensive guard against descriptor.")
