    (:tier "apprentice" :code "(set-inventory 'sku-1 0)" :note "Out of stock.")
    (:tier "intermediate" :code "(map (lambda (pair) (set-inventory (car pair) (cadr pair))) '((a 10) (b 5)))" :note "Batch update.")
    (:tier "expert" :code "(define (restock-all skus n) (map (lambda (s) (set-inventory s n)) skus)) (restock-all '(a b c) 20)" :note "Restock all.")
    (:tier "master" :code "(define (zip a b)\n  (if (or (null? a) (null? b)) '()\n      (cons (list (car a) (car b)) (zip (cdr a) (cdr b)))))\n(define (adjust-inventory skus deltas)\n  (map (lambda (pair) (set-inventory (car pair) (cadr pair)))\n       (zip skus deltas)))\n(adjust-inventory '(a b) '(5 10))" :note "Adjust from a delta list, zipping SKUs and deltas.")
  )
