(verb
  :name "radio-current-station-country"
  :library "-"
  :kind "read"
  :signature "(radio-current-station-country) -> descriptor | string"
  :summary "Return the country code or name of the currently playing radio station."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor in standalone REPL — no radio state bound. Live audio host returns the actual country."
  :examples (
    (:tier "novice" :code "(radio-current-station-country)" :note "Descriptor in standalone.")
    (:tier "apprentice" :code "(equal? (radio-current-station-country) '(\"radio-current-station-country\"))" :note "Check for the descriptor shape.")
    (:tier "intermediate" :code "(define (log-country)\n  (list 'country (radio-current-station-country)))\n(log-country)" :note "Tagged lookup.")
    (:tier "expert" :code "(define (radio-status)\n  (list 'name (radio-current-station-name)\n        'country (radio-current-station-country)))\n(radio-status)" :note "Combine radio queries.")
    (:tier "master" :code "(define (radio-status-string)\n  (let ((n (radio-current-station-name))\n        (c (radio-current-station-country)))\n    (if (and (string? n) (string? c))\n        (string-append n \" (\" c \")\")\n        'no-station)))\n(radio-status-string)" :note "Format a status string, guarding for the descriptor case.")
  )
  :caveats ("Standalone descriptor only." "Live hosts may return ISO code or full country name — check host docs.")
  :drawbacks ("No structured record — just a string.")
  :usecases ("Radio HUD" "Station info" "Playback logging")
  :related ("radio-current-station-name")
  :learn (:concept "Metadata about the current playback — one string at a time." :prerequisites () :progression "Query → tagged → composed → formatted.")
  +cs (:complexity "O(1)" :effects (io) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "read" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("string-append" "list") :consumes-from () :cardinality "one" :deterministic #f :cacheable #f :common-mistakes "Assuming string in standalone — it's a descriptor." :when-not-to-use "For programmatic routing — use a station-id verb.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "radio-current-station-name"
  :library "-"
  :kind "read"
  :signature "(radio-current-station-name) -> descriptor | string"
  :summary "Returns the name of the currently playing radio station, or empty string if none."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor in standalone REPL. Live audio host returns the actual station name or empty string."
