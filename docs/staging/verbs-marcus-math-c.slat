(verb
  :name "set-dot-alpha"
  :library "-"
  :kind "descriptor"
  :signature "(set-dot-alpha surface layer index alpha) -> descriptor"
  :summary "Set the opacity (alpha channel) of a single dot in a surface layer."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Standalone REPL returns unchanged."
  :examples (
    (:tier "novice" :code "(set-dot-alpha 'main 0 0 0.5)" :note "Half-alpha at dot index 0.")
    (:tier "apprentice" :code "(set-dot-alpha 'main 0 5 1)" :note "Fully opaque.")
    (:tier "intermediate" :code "(list (set-dot-alpha 'main 0 0 0) (set-dot-alpha 'main 0 1 1))" :note "One transparent, one opaque.")
    (:tier "expert" :code "(define (fade-dot surface layer index target)\n  (set-dot-alpha surface layer index target))\n(fade-dot 'main 0 5 0.3)" :note "Wrap in a named helper.")
    (:tier "master" :code "(define (fade-row surface layer alphas)\n  (map (lambda (pair) (set-dot-alpha surface layer (car pair) (cadr pair)))\n       (let loop ((xs alphas) (i 0) (acc '())) (if (null? xs) (reverse acc) (loop (cdr xs) (+ i 1) (cons (list i (car xs)) acc))))))\n(fade-row 'main 0 '(0 0.25 0.5 0.75 1))" :note "Gradient across dots: sweep alphas.")
  )
  :caveats ("Standalone descriptor only." "Index is 0-based within the layer.")
  :drawbacks ("One dot per call — batch by wrapping in map.")
  :usecases ("Fade in/out" "Highlight active dots" "Ghost effects")
  :related ("set-dot-color" "set-dot-radius" "surface-paint-dots")
  :learn (:concept "Every dot has alpha. Change it, and the whole picture changes." :prerequisites () :progression "Single → paired → helper → gradient.")
