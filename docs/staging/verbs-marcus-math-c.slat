(verb
  :name "sub-position-per-beat"
  :library "-"
  :kind "descriptor"
  :signature "(sub-position-per-beat entity subdivisions) -> descriptor"
  :summary "Place an entity at a rhythmic sub-position within a beat formation."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('sub-position-per-beat entity n). Consumed by the beat / choreography host. Standalone REPL returns the descriptor."
  :examples (
    (:tier "novice" :code "(sub-position-per-beat 'dancer 4)" :note "Dancer subdivides beats by 4.")
    (:tier "apprentice" :code "(sub-position-per-beat 'lead 2)" :note "Half-beat subdivisions.")
    (:tier "intermediate" :code "(list (sub-position-per-beat 'a 2) (sub-position-per-beat 'b 4))" :note "Two dancers, different subdivisions — one syncopates against the other.")
    (:tier "expert" :code "(define (poly-rhythm pairs)\n  ;; pairs: ((entity subdivs) ...)\n  (map (lambda (p) (sub-position-per-beat (car p) (cadr p))) pairs))\n(poly-rhythm '((a 2) (b 3) (c 5)))" :note "Polyrhythmic assignment: three dancers with 2, 3, 5 subdivisions each.")
    (:tier "master" :code "(define (rhythmic-canon dancers max-sub)\n  (let loop ((ds dancers) (n 1) (acc '()))\n    (if (null? ds) (reverse acc)\n        (loop (cdr ds) (min max-sub (+ n 1))\n              (cons (sub-position-per-beat (car ds) n) acc)))))\n(rhythmic-canon '(a b c d e) 8)" :note "Canonical increment: each dancer subdivides one more finely than the last.")
  )
  :caveats ("Standalone descriptor only." "Subdivisions are positive integers — 1 is 'on the beat', higher is finer.")
  :drawbacks ("No offset within the subdivision — the base signature is position only.")
  :usecases ("Rhythmic choreography" "Polyrhythms" "Beat-quantized entity placement")
  :related ("tempo" "with-spacing")
  :learn (:concept "Rhythm is division of time. Sub-position places an entity at a specific division." :prerequisites () :progression "Single → paired polyrhythm → canon.")
  +cs (:complexity "O(1)" :effects (state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "state-change" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "map") :consumes-from ("symbol") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Passing 0 subdivisions — off the beat entirely." :when-not-to-use "For melodic timing — this is choreographic, not musical.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "register-tick"
  :library "-"
  :kind "descriptor"
  :signature "(register-tick name fn) -> descriptor"
  :summary "Install a named, recurring function to run on every frame tick."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('register-tick name fn). Consumed by the game / animation loop host. Standalone REPL returns the descriptor."
  :examples (
    (:tier "novice" :code "(register-tick 'main (lambda () 'tick))" :note "A named tick callback.")
    (:tier "apprentice" :code "(register-tick 'log (lambda () (list 'ticked)))" :note "Log-style callback.")
    (:tier "intermediate" :code "(define counter 0)\n(register-tick 'count (lambda () (set! counter (+ counter 1)) counter))" :note "Counter that increments per tick. In a real host, ticks fire; in REPL the register just returns a descriptor.")
    (:tier "expert" :code "(define (make-oscillator freq)\n  (register-tick 'osc (lambda () (sin (* freq (random))))))\n(make-oscillator 2)" :note "Wrap a computed tick in a named registration.")
    (:tier "master" :code "(define (register-many callbacks)\n  (map (lambda (pair) (register-tick (car pair) (cadr pair)))\n       callbacks))\n(register-many (list (list 'a (lambda () 1))\n                     (list 'b (lambda () 2))))" :note "Batch-register a table of named callbacks.")
  )
  :caveats ("Standalone descriptor only — no ticks fire in REPL." "Named — a duplicate name replaces the earlier registration in a live host.")
  :drawbacks ("No priority / order guarantee in the base signature.")
  :usecases ("Game loop callbacks" "Animation drivers" "Periodic housekeeping")
  :related ("tick/*" "wait")
  :learn (:concept "A tick is a recurring event; registering names it and hands it to the loop." :prerequisites ("lambda") :progression "Simple → stateful → wrapped → batched.")
  +cs (:complexity "O(1)" :effects (state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "state-change" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("map" "list") :consumes-from ("lambda") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Registering unnamed ticks and having them collide." :when-not-to-use "For one-shot callbacks — use after or setTimeout equivalents.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

