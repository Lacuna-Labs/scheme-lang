(verb
  :name "rotate-card"
  :library "-"
  :kind "descriptor"
  :signature "(rotate-card kind-or-id [deg]) -> descriptor"
  :summary "Rotate a card by the given angle, or by the snap increment if no angle is supplied."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('rotate-card id [deg]). Consumed by the card / desktop host. Standalone REPL returns the descriptor."
  :examples (
    (:tier "novice" :code "(rotate-card 'card-1 45)" :note "45 degrees clockwise.")
    (:tier "apprentice" :code "(rotate-card 'card-1)" :note "No angle: rotate by the default snap (typically 90 degrees).")
    (:tier "intermediate" :code "(list (rotate-card 'a 15) (rotate-card 'b -15))" :note "Two cards, opposite rotations.")
    (:tier "expert" :code "(define (fan-rotate ids delta)\n  (let loop ((xs ids) (angle 0) (acc '()))\n    (if (null? xs) (reverse acc)\n        (loop (cdr xs) (+ angle delta) (cons (rotate-card (car xs) angle) acc)))))\n(fan-rotate '(a b c d) 15)" :note "Fan of cards, each 15° more than the last.")
    (:tier "master" :code "(define (reset-orientation ids)\n  (map (lambda (id) (rotate-card id 0)) ids))\n(reset-orientation '(a b c))" :note "Snap a group of cards back to zero rotation.")
  )
  :caveats ("Standalone descriptor only." "Angle is degrees, not radians.")
  :drawbacks ("Absolute rotation; no delta or additive form in the base signature.")
  :usecases ("Card orientation" "Fan / spread layouts" "Snap-to-grid resets")
  :related ("scale-card" "orient-card")
  :learn (:concept "Cards live in a plane; rotation is an orientation change." :prerequisites () :progression "Single → paired → fanned → reset.")
