(verb
  :name "const/sqrt2"
  :library "const"
  :kind "constant"
  :signature "const/sqrt2 -> 1.41421..."
  :summary "The square root of 2; the ratio of a square's diagonal to its side."
  :impl-status "wired"
  :impl-file "src/wired-verbs-marcus-math-c.js"
  :impl-notes "Bound as bare Math.SQRT2. Previously wired as a thunk. Marcus's lane fixed."
  :examples (
    (:tier "novice" :code "const/sqrt2" :note "The value 1.41421…")
    (:tier "apprentice" :code "(* const/sqrt2 const/sqrt2)" :note "√2 · √2 = 2. Definition, up to floating-point rounding.")
    (:tier "intermediate" :code "(define (unit-square-diagonal)\n  const/sqrt2)\n(unit-square-diagonal)" :note "A square of side 1 has diagonal √2. Pythagoras: 1² + 1² = 2.")
    (:tier "expert" :code "(define (a4-paper-height width)\n  (* width const/sqrt2))\n(a4-paper-height 210)" :note "A-series paper: height/width = √2. A4 (210 mm wide) is ≈ 297 mm tall.")
    (:tier "master" :code "(define (rms-of-sinusoid amplitude)\n  (/ amplitude const/sqrt2))\n(rms-of-sinusoid 170)" :note "US household outlet: 170 V peak → 120 V RMS. Divide by √2.")
  )
  :caveats ("Floating-point — √2 is irrational so it's approximated." "Bare symbol.")
  :drawbacks ("Repeated multiplication drifts from exact 2.")
  :usecases ("Diagonal of a square" "A-series paper" "Sinusoid RMS values" "Isosceles right triangles" "Numerical analysis test cases")
  :related ("const/sqrt3" "geom/pythagoras-hypotenuse")
  :learn (:concept "√2 is the first irrational number the Greeks discovered — it upset them." :prerequisites ("sqrt" "Pythagoras") :progression "Right triangles → 45° geometry → RMS in electrical.")
  +math (:algebra "irrational, algebraic (root of x²-2)" :total #t :domain "-" :codomain "R" :proofs "Hippasus's proof: √2 is irrational.")
  +cs (:complexity "O(1)" :effects (none) :pure #t)
  +eng (:impl-file "src/wired-verbs-marcus-math-c.js" :impl-notes "Math.SQRT2 constant." :permission "read" :latency-class "sync-fast" :since "0.1.0")
  +hacker (:primitive #t :kin ("JS: Math.SQRT2; Python: math.sqrt(2)") :history "Known since antiquity; irrationality proved by the Pythagoreans." :hackable #f)
  +ai (:raises () :pipes-into ("*" "/") :consumes-from () :cardinality "one" :deterministic #t :cacheable #t :common-mistakes "Believing (* const/sqrt2 const/sqrt2) is exactly 2 — it's 2.0000000000000004." :when-not-to-use "When exact arithmetic matters.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

