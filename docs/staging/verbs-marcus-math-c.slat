    (:tier "novice" :code "(radio-current-station-name)" :note "Descriptor in standalone.")
    (:tier "apprentice" :code "(list 'name (radio-current-station-name))" :note "Tagged.")
    (:tier "intermediate" :code "(define (station)\n  (radio-current-station-name))\n(station)" :note "Named lookup.")
    (:tier "expert" :code "(define (playing?)\n  (let ((n (radio-current-station-name)))\n    (and (string? n) (not (string=? n \"\")))))\n(playing?)" :note "Predicate for 'is anything playing'.")
    (:tier "master" :code "(define (radio-summary)\n  (let ((name (radio-current-station-name))\n        (country (radio-current-station-country)))\n    (list 'name name 'country country)))\n(radio-summary)" :note "Composed summary of what's on.")
  )
