  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "scale-card"
  :library "-"
  :kind "descriptor"
  :signature "(scale-card id width height) -> descriptor"
  :summary "Resize a card to the given pixel dimensions (width and height)."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('scale-card id w h). Consumed by the card / desktop host. Standalone REPL returns the descriptor."
  :examples (
    (:tier "novice" :code "(scale-card 'card-1 100 100)" :note "Square 100x100.")
    (:tier "apprentice" :code "(scale-card 'photo 200 150)" :note "Landscape photo.")
    (:tier "intermediate" :code "(list (scale-card 'a 100 100) (scale-card 'b 200 200))" :note "Two cards, two sizes.")
    (:tier "expert" :code "(define (resize-all ids w h)\n  (map (lambda (id) (scale-card id w h)) ids))\n(resize-all '(a b c) 150 100)" :note "Batch resize.")
    (:tier "master" :code "(define (uniform-thumbnails ids)\n  (map (lambda (id) (scale-card id 120 90)) ids))\n(uniform-thumbnails '(t1 t2 t3 t4))" :note "Standardize thumbnails to a common aspect.")
  )
  :caveats ("Standalone descriptor only." "Dimensions are pixel counts, not cells.")
  :drawbacks ("Uniform scaling only — no separate x/y scale factors in the base signature.")
  :usecases ("Thumbnail sizing" "Card layout" "Responsive rescale")
  :related ("rotate-card" "measure-content")
  :learn (:concept "Size is data. Scaling changes the container without changing content." :prerequisites () :progression "One → batch → standardized.")
  +cs (:complexity "O(1)" :effects (state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "state-change" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "map") :consumes-from ("symbol") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Passing floats — dimensions round to integers." :when-not-to-use "For content-driven size — use auto-layout instead.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "viewport"
  :library "-"
  :kind "meta"
  :signature "(viewport) -> descriptor"
  :summary "Query the current viewport bounding box (camera frame on the card surface)."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('viewport). In standalone REPL, returns the descriptor unchanged (no camera). Live hosts return a real {x, y, w, h} record."
  :examples (
    (:tier "novice" :code "(viewport)" :note "Ask for the viewport.")
    (:tier "apprentice" :code "(list 'current (viewport))" :note "Wrap the descriptor with a tag.")
    (:tier "intermediate" :code "(define (viewport-tag)\n  (cons 'vp (viewport)))\n(viewport-tag)" :note "Named viewport lookup.")
    (:tier "expert" :code "(define (log-viewports)\n  (list (viewport) (viewport)))\n(log-viewports)" :note "Two viewport snapshots. In a live host, ordering matters (may differ).")
    (:tier "master" :code "(define (view-plan)\n  (list 'view (viewport) 'width (viewport-width)))\n(view-plan)" :note "Compose viewport + width into a plan structure.")
  )
  :caveats ("Standalone REPL: descriptor only, no real coordinates." "Live host returns a record with x, y, w, h fields.")
  :drawbacks ("No zoom / rotation queried by this verb alone — pair with zoom-legible? or camera verbs.")
  :usecases ("Camera-aware layout" "Culling" "Debug HUDs")
  :related ("viewport-width" "rows" "cols" "zoom-legible?")
  :learn (:concept "The viewport is what the camera sees. Everything drawn outside it is invisible." :prerequisites () :progression "Query → tag → plan.")
  +cs (:complexity "O(1)" :effects (io) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "read" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "cons") :consumes-from () :cardinality "one" :deterministic #f :cacheable #f :common-mistakes "Assuming the return is a hash — live hosts may return a list or a record." :when-not-to-use "For static layout — use surface dimensions instead.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "viewport-width"
  :library "-"
  :kind "meta"
  :signature "(viewport-width) -> descriptor | number"
  :summary "Query the current viewport width in world coordinates."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('viewport-width) in standalone REPL; live hosts return a number."
  :examples (
    (:tier "novice" :code "(viewport-width)" :note "Ask the current viewport width.")
    (:tier "apprentice" :code "(list 'w (viewport-width))" :note "Tagged width.")
    (:tier "intermediate" :code "(define (log-width)\n  (viewport-width))\n(log-width)" :note "Named lookup.")
    (:tier "expert" :code "(define (both-dims)\n  (list (viewport-width) (rows)))\n(both-dims)" :note "Width from camera, height from surface — the two rulers.")
    (:tier "master" :code "(define (visible-bounds)\n  (let ((w (viewport-width)))\n    (list 'left 0 'right w)))\n(visible-bounds)" :note "Compute simple left/right bounds using width.")
  )
  :caveats ("Standalone REPL: descriptor only." "World coordinates depend on camera; a wide zoom-out gives larger width.")
  :drawbacks ("No height counterpart in this verb alone — see viewport or rows.")
  :usecases ("Layout width computations" "Culling range" "Debug logging")
  :related ("viewport" "rows")
  :learn (:concept "Width is one number. viewport-width is that number, camera-aware." :prerequisites () :progression "Query → tagged → composed.")
  +cs (:complexity "O(1)" :effects (io) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "read" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list") :consumes-from () :cardinality "one" :deterministic #f :cacheable #f :common-mistakes "Assuming pixel count — it's world coordinates." :when-not-to-use "For pixel-accurate work — use pixels-wide.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "svg-set"
  :library "-"
  :kind "descriptor"
  :signature "(svg-set surface selector attr value) -> descriptor"
  :summary "Set a single SVG DOM attribute on an element matched by CSS selector within a surface."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('svg-set surface selector attr value). Consumed by the SVG-backed surface host. Standalone REPL returns the descriptor. NO CHECK on selector validity here."
  :examples (
    (:tier "novice" :code "(svg-set 'surface \"#circle-1\" \"fill\" \"red\")" :note "Fill a specific circle red.")
    (:tier "apprentice" :code "(svg-set 'main \".highlight\" \"stroke\" \"blue\")" :note "Set stroke on any element with class highlight.")
    (:tier "intermediate" :code "(list (svg-set 'main \"#a\" \"fill\" \"red\") (svg-set 'main \"#b\" \"fill\" \"blue\"))" :note "Two updates in a batch.")
    (:tier "expert" :code "(define (color-all surface selector color)\n  (svg-set surface selector \"fill\" color))\n(color-all 'main \".card\" \"#ffcc00\")" :note "Wrap in a domain-specific helper.")
    (:tier "master" :code "(define (theme-swap surface theme)\n  (map (lambda (pair) (svg-set surface (car pair) \"fill\" (cadr pair)))\n       theme))\n(theme-swap 'main '((\".bg\" \"#111\") (\".fg\" \"#eee\") (\".accent\" \"#f0c\")))" :note "Batch-apply a theme table of selector-to-color pairs.")
  )
  :caveats ("Standalone descriptor only." "Selector is a CSS selector, not an XPath — must match the host's DOM.")
  :drawbacks ("One attribute per call — for many attrs use multiple calls or a batch verb.")
  :usecases ("Theme switching" "Dynamic styling" "Debug highlighting")
  :related ("surface-paint-dots" "surface-paint-text")
  :learn (:concept "Direct DOM manipulation — a shortcut when structured painting is overkill." :prerequisites ("CSS selectors") :progression "Single attr → batch → themed.")
  +cs (:complexity "O(1) per attr" :effects (state io) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "state-change" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "map") :consumes-from ("string") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Passing a selector that matches multiple elements when you meant one — updates all matches." :when-not-to-use "For creating new elements — svg-set only mutates existing ones.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

;; ═══════════════════════════════════════════════════════════════════════
;; Surface / paint verbs (descriptor-shaped, host binds real semantics)
;; ═══════════════════════════════════════════════════════════════════════

(verb
  :name "surface-curtain"
  :library "-"
  :kind "descriptor"
  :signature "(surface-curtain alpha [duration-ms]) -> descriptor"
  :summary "Fade the entire canvas in or out globally (legacy alias of surface/curtain)."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Consumed by the framebuffer host. Standalone REPL returns the descriptor unchanged."
  :examples (
    (:tier "novice" :code "(surface-curtain 0.5)" :note "Half-fade.")
    (:tier "apprentice" :code "(surface-curtain 0 1000)" :note "Full fade in over 1 second.")
    (:tier "intermediate" :code "(list (surface-curtain 1) (surface-curtain 0 500))" :note "Curtain up then fade over half a second.")
    (:tier "expert" :code "(define (dramatic-reveal)\n  (list (surface-curtain 1) (wait 1) (surface-curtain 0 2000)))\n(dramatic-reveal)" :note "Curtain up, hold a second, fade in over 2 seconds.")
    (:tier "master" :code "(define (chapter-transition duration)\n  (list (surface-curtain 1 (/ duration 2))\n        (wait (/ duration 1000))\n        (surface-curtain 0 (/ duration 2))))\n(chapter-transition 2000)" :note "Full transition: half fade out, hold, half fade in.")
  )
  :caveats ("Standalone descriptor only." "Alpha 0..1; 0 is fully visible, 1 is fully opaque black.")
  :drawbacks ("No color parameter — always black. Use surface-paper for colored backgrounds.")
  :usecases ("Scene transitions" "Chapter breaks" "Dramatic reveals")
  :related ("surface-dim" "surface-dusk" "surface-paper")
  :learn (:concept "A curtain hides everything. Handy for cuts and reveals." :prerequisites () :progression "Instant → timed → composed transition.")
  +cs (:complexity "O(1)" :effects (io state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "paint" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "wait") :consumes-from () :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Alpha > 1 or < 0 — clamped by hosts, but be explicit." :when-not-to-use "For partial-scene fades — use per-entity alpha instead.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "surface-dim"
  :library "-"
  :kind "descriptor"
  :signature "(surface-dim alpha) -> descriptor"
  :summary "Set the global canvas dim level (overlay darkness)."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Standalone REPL returns unchanged."
  :examples (
    (:tier "novice" :code "(surface-dim 0.3)" :note "30% dim.")
    (:tier "apprentice" :code "(surface-dim 0)" :note "Full brightness.")
    (:tier "intermediate" :code "(list (surface-dim 0.5) (surface-dim 0))" :note "Dim then restore.")
    (:tier "expert" :code "(define (spotlight-mode)\n  (list (surface-dim 0.7) (surface-spotlight 100 100 60)))\n(spotlight-mode)" :note "Dim the surface then punch a spotlight for focus.")
    (:tier "master" :code "(define (dim-ladder steps hold-ms)\n  (map (lambda (i) (surface-dim (/ i steps)))\n       (let loop ((k 0)) (if (>= k steps) '() (cons k (loop (+ k 1)))))))\n(dim-ladder 5 200)" :note "Gradual dim in five steps.")
  )
  :caveats ("Standalone descriptor only." "Alpha 0..1.")
  :drawbacks ("Global; per-region dim needs a mask.")
  :usecases ("Focus" "Nighttime rendering" "Depth cueing")
  :related ("surface-curtain" "surface-dusk" "surface-spotlight")
  :learn (:concept "Dim is a global alpha overlay. Cheap and effective." :prerequisites () :progression "Single → paired → laddered.")
  +cs (:complexity "O(1)" :effects (io state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "paint" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "map") :consumes-from () :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Confusing dim with curtain — dim is partial, curtain is full black." :when-not-to-use "For flash effects — a full curtain-up/down is faster to write.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "surface-dusk"
  :library "-"
  :kind "descriptor"
  :signature "(surface-dusk level [opts]) -> descriptor"
  :summary "Raise or lower ambient dusk (twilight/dim) with optional parameters."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Standalone REPL returns unchanged. Live hosts may color-shift toward purple as level rises."
  :examples (
    (:tier "novice" :code "(surface-dusk 0.5)" :note "Half dusk.")
    (:tier "apprentice" :code "(surface-dusk 1)" :note "Full dusk.")
    (:tier "intermediate" :code "(list (surface-dusk 0.2) (surface-dusk 0.6))" :note "Two dusk levels queued.")
    (:tier "expert" :code "(define (day-to-night steps)\n  (map (lambda (i) (surface-dusk (/ i steps)))\n       (let loop ((k 0)) (if (>= k steps) '() (cons k (loop (+ k 1)))))))\n(day-to-night 5)" :note "Simulate a day-to-night transition in five discrete steps.")
    (:tier "master" :code "(define (scene-atmosphere kind)\n  (case kind\n    ((noon) (surface-dusk 0))\n    ((sunset) (surface-dusk 0.5))\n    ((night) (surface-dusk 1))\n    (else (surface-dusk 0.3))))\n(scene-atmosphere 'sunset)" :note "Map named times of day to dusk levels.")
  )
  :caveats ("Standalone descriptor only." "Level 0..1.")
  :drawbacks ("Different from surface-dim: dusk implies color shift, dim is pure darkness.")
  :usecases ("Time-of-day rendering" "Mood settings" "Atmospheric scenes")
  :related ("surface-dim" "surface-curtain")
  :learn (:concept "Dusk is dim WITH a hue shift. Kids feel the difference between night and just dim." :prerequisites () :progression "Single → paired → laddered → named.")
  +cs (:complexity "O(1)" :effects (io state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "paint" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "case") :consumes-from () :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Confusing with surface-dim." :when-not-to-use "For pure alpha darkening — use surface-dim.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "surface-exists?"
  :library "-"
  :kind "predicate"
  :signature "(surface-exists? surface-name) -> boolean"
  :summary "Check whether a named surface is registered and available."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Predicate. Standalone REPL: always returns #f (no surfaces registered). Live hosts consult the surface registry."
  :examples (
    (:tier "novice" :code "(surface-exists? 'main)" :note "#f in standalone. #t in a live host that registered 'main.")
    (:tier "apprentice" :code "(if (surface-exists? 'ui) 'yes 'no)" :note "Guard a paint operation on surface existence.")
    (:tier "intermediate" :code "(map surface-exists? '(main ui debug))" :note "Check several at once — all #f in standalone.")
    (:tier "expert" :code "(define (ensure-surfaces names)\n  (map (lambda (n) (list n (surface-exists? n))) names))\n(ensure-surfaces '(main ui debug))" :note "Report which surfaces the host has.")
    (:tier "master" :code "(define (paint-if-exists surface dots)\n  (if (surface-exists? surface)\n      'painted\n      'skipped))\n(paint-if-exists 'main '())" :note "Idiomatic guarded paint — skips silently if the target isn't there.")
  )
  :caveats ("Standalone: always #f." "Predicate — returns boolean.")
  :drawbacks ("No introspection of surface properties beyond existence.")
  :usecases ("Guarded paints" "Debugging missing surfaces" "Optional overlays")
  :related ("surface-paint-dots" "surface-paint-text")
  :learn (:concept "Ask before you paint — check existence to avoid errors on missing hosts." :prerequisites () :progression "Guard → batch check → guarded paint.")
  +cs (:complexity "O(1)" :effects (none) :pure #t :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Returns #f in standalone." :permission "read" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("if" "cond") :consumes-from ("symbol") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Trusting the return in standalone as authoritative — it says #f for everything." :when-not-to-use "In standalone code paths that need surface access — verify host bindings first.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "surface-paint-dots"
  :library "-"
  :kind "descriptor"
  :signature "(surface-paint-dots surface layer dots [colour] [radius] [alpha] [paletteName]) -> descriptor"
  :summary "Paint a set of dots (points with alpha) onto a named surface layer."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Standalone REPL returns unchanged."
  :examples (
    (:tier "novice" :code "(surface-paint-dots 'main 'top '())" :note "Empty dot list — no-op.")
    (:tier "apprentice" :code "(surface-paint-dots 'main 'top '((1 2) (3 4)))" :note "Two dots on the top layer.")
    (:tier "intermediate" :code "(surface-paint-dots 'main 'top (rasterize-text \"HI\"))" :note "Paint the rasterized text.")
    (:tier "expert" :code "(define (paint-word surface word x y)\n  (surface-paint-dots surface 'text (rasterize-text word x y)))\n(paint-word 'main \"OK\" 10 10)" :note "Rasterize + paint helper.")
    (:tier "master" :code "(define (paint-lines surface lines)\n  (map (lambda (i)\n         (let ((y (* i 10)))\n           (surface-paint-dots surface 'text (rasterize-text (list-ref lines i) 0 y))))\n       (let loop ((k 0)) (if (>= k (length lines)) '() (cons k (loop (+ k 1)))))))\n(paint-lines 'main '(\"HELLO\" \"WORLD\"))" :note "Paint each line at its own y offset.")
  )
  :caveats ("Standalone descriptor only — no actual painting happens." "dots is a list of dot records or (x y) pairs.")
  :drawbacks ("No z-order / depth in the base signature — layer name conveys it.")
  :usecases ("Text rendering" "Custom shapes" "Pixel art")
  :related ("rasterize-text" "surface-paint-text" "clear-surface-layer")
  :learn (:concept "Painting is a data flow: dots go to a layer. Kids see cause and effect." :prerequisites ("rasterize-text") :progression "Empty → literal dots → rasterized → helper → multi-line.")
  +cs (:complexity "O(n) where n = dot count" :effects (io state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "paint" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("map") :consumes-from ("rasterize-text") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Passing dots without an alpha channel — hosts may treat missing alpha as 1.0." :when-not-to-use "For large images — use a bitmap paint verb.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "surface-paint-text"
  :library "-"
  :kind "descriptor"
  :signature "(surface-paint-text surface text [x] [y] [font] [size] [colour] [grid] [supersample] [minAlpha]) -> descriptor"
  :summary "Rasterize and paint text directly onto a surface at a given position."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Composes rasterize-text + surface-paint-dots — in a live host, one call. Standalone REPL returns the descriptor unchanged."
  :examples (
    (:tier "novice" :code "(surface-paint-text 'main \"HI\")" :note "Default position, default font.")
    (:tier "apprentice" :code "(surface-paint-text 'main \"HELLO\" 10 20)" :note "Positioned text.")
    (:tier "intermediate" :code "(list (surface-paint-text 'main \"LINE 1\") (surface-paint-text 'main \"LINE 2\" 0 10))" :note "Two lines, second offset down.")
    (:tier "expert" :code "(define (label surface text pos)\n  (surface-paint-text surface text (car pos) (cadr pos)))\n(label 'main \"OK\" '(10 10))" :note "Small labeled paint helper.")
    (:tier "master" :code "(define (paint-lines surface lines)\n  (let loop ((xs lines) (y 0))\n    (if (null? xs) 'done\n        (begin (surface-paint-text surface (car xs) 0 y)\n               (loop (cdr xs) (+ y 10))))))\n(paint-lines 'main '(\"HELLO\" \"WORLD\"))" :note "Multiline text via sequential paints.")
  )
  :caveats ("Standalone descriptor only." "Default font is the standalone 5x7 raster.")
  :drawbacks ("No text-wrapping or measurement — pair with measure-content in a live host.")
  :usecases ("Labels" "Debug HUDs" "Kid-friendly hello-world")
  :related ("rasterize-text" "surface-paint-dots")
  :learn (:concept "Text on the canvas is text + position. Everything else is convenience." :prerequisites () :progression "Default → positioned → multiline → labeled.")
  +cs (:complexity "O(text length × pixels-per-glyph)" :effects (io state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "paint" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "map") :consumes-from ("string") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Assuming line wrapping — there is none by default." :when-not-to-use "For long paragraphs — measure and split first.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "surface-paper"
  :library "-"
  :kind "descriptor"
  :signature "(surface-paper kind) -> descriptor"
  :summary "Set the background paper texture or style of the rendering surface."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Standalone REPL returns unchanged."
  :examples (
    (:tier "novice" :code "(surface-paper 'linen)" :note "Linen paper.")
    (:tier "apprentice" :code "(surface-paper 'grid)" :note "Grid paper.")
    (:tier "intermediate" :code "(list (surface-paper 'linen) (surface-paper 'grid))" :note "Two paper styles queued.")
    (:tier "expert" :code "(define (theme-paper theme)\n  (case theme ((sakura) (surface-paper 'linen))\n              ((cyber) (surface-paper 'grid))\n              (else (surface-paper 'plain))))\n(theme-paper 'sakura)" :note "Theme-driven paper selection.")
    (:tier "master" :code "(define (paper-schedule kinds)\n  (map surface-paper kinds))\n(paper-schedule '(linen grid dot plain))" :note "Cycle through paper styles.")
  )
  :caveats ("Standalone descriptor only." "kind is host-defined — 'linen, 'grid, 'plain, etc.")
  :drawbacks ("No custom papers via URL — hosts define their own registry.")
  :usecases ("Theming" "Scene atmosphere" "Kid-friendly canvas variety")
  :related ("surface-curtain" "surface-dim")
