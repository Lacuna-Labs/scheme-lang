(verb
  :name "transfer"
  :library "-"
  :kind "descriptor"
  :signature "(transfer source-card-id destination-card-id item-ids) -> descriptor"
  :summary "Move a list of items from one card to another, gated by operator gesture confirmation."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('transfer src dst items). Consumed by the shop / inventory host which enforces confirmation. Standalone REPL returns the descriptor."
  :examples (
    (:tier "novice" :code "(transfer 'shop-a 'shop-b '(item-1))" :note "Move one item between shops.")
    (:tier "apprentice" :code "(transfer 'cart-1 'saved '(sku-a sku-b))" :note "Two items to a saved-for-later cart.")
    (:tier "intermediate" :code "(define (move-all items src dst)\n  (transfer src dst items))\n(move-all '(a b c) 'inbox 'archive)" :note "Wrap in a named helper.")
    (:tier "expert" :code "(define (move-if pred items src dst)\n  (let ((yes (filter pred items)))\n    (if (null? yes) 'nothing-moved (transfer src dst yes))))\n(move-if (lambda (i) #t) '(a b) 'src 'dst)" :note "Filtered move — nothing moves if no items match.")
    (:tier "master" :code "(define (batched-transfer src dst all-items batch-size)\n  (let loop ((remaining all-items) (acc '()))\n    (if (null? remaining) (reverse acc)\n        (let ((batch (if (< (length remaining) batch-size) remaining (take-n remaining batch-size))))\n          (loop (drop-n remaining batch-size) (cons (transfer src dst batch) acc))))))\n(define (take-n lst n) (if (or (null? lst) (<= n 0)) '() (cons (car lst) (take-n (cdr lst) (- n 1)))))\n(define (drop-n lst n) (if (or (null? lst) (<= n 0)) lst (drop-n (cdr lst) (- n 1))))\n(batched-transfer 'a 'b '(1 2 3 4 5 6 7) 3)" :note "Chunked transfer: many small transfers instead of one huge one. Real inventory systems batch to avoid API limits.")
  )
  :caveats ("Standalone descriptor only." "Host may require a follow-up confirmation gesture before executing.")
  :drawbacks ("No rollback in the base signature; the host owns transaction semantics.")
  :usecases ("Shop-to-shop moves" "Inventory reshuffles" "Cart to save-for-later")
  :related ("receive-listing" "release-listing" "set-inventory")
  :learn (:concept "Transfer is a request with three parts: source, destination, items. All present tense." :prerequisites () :progression "Single → filtered → batched.")
  +cs (:complexity "O(n) where n = item-ids length" :effects (state io) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "state-change" :latency-class "async-quick" :since "0.1.0")
  +ai (:raises () :pipes-into () :consumes-from ("list") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Passing a single item as bare instead of a list — always wrap." :when-not-to-use "For single item and no shop context — a direct move verb may be lighter.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "sway!"
  :library "-"
  :kind "descriptor"
  :signature "(sway! entity-id period amplitude) -> descriptor"
  :summary "Apply a periodic sine-wave rotation (sway) to a single entity."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor ('sway! id period amplitude). Consumed by the animation host, which drives the entity's rotation as amplitude * sin(2π t / period). Standalone REPL returns the descriptor."
  :examples (
    (:tier "novice" :code "(sway! 'card-1 2 0.1)" :note "Small sway, 2-second period.")
    (:tier "apprentice" :code "(sway! 'lantern 4 0.05)" :note "Slow gentle sway — lantern in a breeze.")
    (:tier "intermediate" :code "(map (lambda (id) (sway! id 2 0.1)) '(a b c))" :note "Sway a group of entities with matching parameters.")
    (:tier "expert" :code "(define (breeze-sway ids)\n  (map (lambda (id) (sway! id (+ 1.5 (random)) 0.05))\n       ids))\n(breeze-sway '(leaf-1 leaf-2 leaf-3))" :note "Randomize period per entity for a natural feel.")
    (:tier "master" :code "(define (choir-sway ids base-period)\n  (map (lambda (id) (sway! id base-period 0.03)) ids))\n(choir-sway '(v1 v2 v3 v4) 3)" :note "Coordinated sway — all entities same period, so they move in unison like a choir.")
  )
  :caveats ("Standalone descriptor only — no real animation in REPL." "Amplitude is in radians; small values (< 0.2) look natural.")
  :drawbacks ("Only sine — no square or triangle waves in the base signature.")
  :usecases ("Leaves in wind" "Lanterns" "Character idle animations" "Ambient life in a scene")
  :related ("walk-cycle" "touch")
  :learn (:concept "Ambient motion makes a scene feel alive. Sway is the simplest ambient." :prerequisites () :progression "One entity → group → randomized → coordinated.")
  +cs (:complexity "O(1)" :effects (state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "state-change" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("map" "list") :consumes-from ("symbol") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Passing amplitude in degrees. It's radians — 0.1 rad ≈ 5.7 degrees." :when-not-to-use "When you need one-shot rotation — use rotate-card.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

