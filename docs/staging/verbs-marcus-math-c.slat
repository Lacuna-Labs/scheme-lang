  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "set-dot-color"
  :library "-"
  :kind "descriptor"
  :signature "(set-dot-color surface layer index colour) -> descriptor"
  :summary "Set the fill color of a single dot in a surface layer."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Standalone REPL returns unchanged."
  :examples (
    (:tier "novice" :code "(set-dot-color 'main 0 0 'red)" :note "Red dot.")
    (:tier "apprentice" :code "(set-dot-color 'main 0 1 \"#f0c\")" :note "Hex color.")
    (:tier "intermediate" :code "(list (set-dot-color 'main 0 0 'red) (set-dot-color 'main 0 1 'blue))" :note "Two dots, two colors.")
    (:tier "expert" :code "(define (zip a b)\n  (if (or (null? a) (null? b)) '()\n      (cons (list (car a) (car b)) (zip (cdr a) (cdr b)))))\n(define (rainbow surface layer indices colors)\n  (map (lambda (pair) (set-dot-color surface layer (car pair) (cadr pair)))\n       (zip indices colors)))\n(rainbow 'main 0 '(0 1 2 3 4 5 6) '(red orange yellow green blue indigo violet))" :note "A rainbow across seven dots. Uses a local zip since Sakura's map is single-list.")
    (:tier "master" :code "(define (color-by-index surface layer count color-fn)\n  (let loop ((i 0) (acc '()))\n    (if (>= i count) (reverse acc)\n        (loop (+ i 1) (cons (set-dot-color surface layer i (color-fn i)) acc)))))\n(color-by-index 'main 0 5 (lambda (i) (list-ref '(red green blue yellow purple) i)))" :note "Programmatic coloring by index — palette lookup.")
  )
  :caveats ("Standalone descriptor only." "colour can be symbol, string (hex), or list — hosts parse.")
  :drawbacks ("One dot per call.")
  :usecases ("Highlighting" "Rainbow effects" "Programmatic palettes")
  :related ("set-dot-alpha" "set-dot-radius")
  :learn (:concept "Color is a per-dot property. Change it, watch the picture change." :prerequisites () :progression "Single → rainbow → programmatic.")
  +cs (:complexity "O(1) per dot" :effects (io state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "paint" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "map") :consumes-from ("symbol" "string") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Passing color as RGB list without a tag — hosts vary." :when-not-to-use "For layer-wide theme changes — use surface-paper or a batch verb.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

(verb
  :name "set-dot-radius"
  :library "-"
  :kind "descriptor"
  :signature "(set-dot-radius surface layer index radius) -> descriptor"
  :summary "Set the radius (size) of a single dot in a surface layer."
  :impl-status "wired"
  :impl-file "src/wired-verbs.js"
  :impl-notes "Descriptor. Standalone REPL returns unchanged."
  :examples (
    (:tier "novice" :code "(set-dot-radius 'main 0 0 3)" :note "Radius 3.")
    (:tier "apprentice" :code "(set-dot-radius 'main 0 5 1)" :note "Small dot.")
    (:tier "intermediate" :code "(list (set-dot-radius 'main 0 0 1) (set-dot-radius 'main 0 1 5))" :note "Small and big.")
    (:tier "expert" :code "(define (breathe surface layer index min max phase)\n  (set-dot-radius surface layer index (+ min (* (- max min) (sin phase)))))\n(breathe 'main 0 5 1 5 0.5)" :note "Compute a breathing radius.")
    (:tier "master" :code "(define (size-ladder surface layer count)\n  (let loop ((i 0) (acc '()))\n    (if (>= i count) (reverse acc)\n        (loop (+ i 1) (cons (set-dot-radius surface layer i (+ 1 (* i 0.5))) acc)))))\n(size-ladder 'main 0 5)" :note "Increasing radii: 1, 1.5, 2, 2.5, 3.")
  )
  :caveats ("Standalone descriptor only." "Radius in pixels or cells depending on host.")
  :drawbacks ("One dot per call.")
  :usecases ("Emphasis" "Breathing effects" "Size gradients")
  :related ("set-dot-color" "set-dot-alpha")
  :learn (:concept "Radius is another per-dot knob." :prerequisites () :progression "Fixed → paired → animated → laddered.")
  +cs (:complexity "O(1) per dot" :effects (io state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "paint" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("list" "map") :consumes-from () :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Passing zero or negative radius — the dot disappears." :when-not-to-use "For dense point clouds — use a shader or bitmap.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

;; ═══════════════════════════════════════════════════════════════════════
;; Sprite verbs (real impls in game.js but presented as bare name)
;; ═══════════════════════════════════════════════════════════════════════

(verb
  :name "sprite"
  :library "-"
  :kind "state-change"
  :signature "(sprite name x y [color]) -> undefined"
  :summary "Push a sprite record onto the game.sprites accumulator with the given position and color."
  :impl-status "wired"
  :impl-file "src/game.js"
  :impl-notes "Reference signature in the SLAT lists optional forms (turn, size, tint …) which the current impl does not accept — this entry documents the ACTUAL signature (name x y [color]) and flags the mismatch. entry-provenance: spec-ambiguous until Alfred picks."
  :examples (
    (:tier "novice" :code "(sprite 'ball 40 40)" :note "Push a ball sprite at (40,40).")
    (:tier "apprentice" :code "(sprite 'star 100 100 'gold)" :note "With color.")
    (:tier "intermediate" :code "(sprite 'ball 40 40) (sprites)" :note "After a sprite call, sprites lists it.")
    (:tier "expert" :code "(define (spawn-row y n)\n  (let loop ((i 0))\n    (if (>= i n) 'done\n        (begin (sprite 'dot (* i 20) y)\n               (loop (+ i 1))))))\n(spawn-row 50 5)" :note "Push five dots along a row.")
    (:tier "master" :code "(define (place-many spec)\n  (for-each (lambda (s) (sprite (list-ref s 0) (list-ref s 1) (list-ref s 2)))\n            spec))\n(place-many '((a 10 10) (b 20 20) (c 30 30)))" :note "Batch-place from a spec list.")
  )
  :caveats ("Signature mismatch: reference says (sprite name [form ...]); impl is (sprite name x y [color]). Prefer the impl signature; reference will be updated." "Returns undefined; use (sprites) to inspect.")
  :drawbacks ("No returned handle — must use sprites to enumerate.")
  :usecases ("Rendering game objects" "Debug markers" "Batch placement")
  :related ("sprites" "sprites/clear")
  :learn (:concept "Sprites are data pushed to an accumulator; the renderer draws the accumulator." :prerequisites () :progression "One → row → batch.")
  +cs (:complexity "O(1) per call" :effects (state) :pure #f :special-form #f)
  +eng (:impl-file "src/game.js" :impl-notes "Pushes to game.sprites array." :permission "paint" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("sprites") :consumes-from ("symbol") :cardinality "void" :deterministic #t :cacheable #f :common-mistakes "Expecting a sprite object back — you get undefined." :when-not-to-use "When you need a handle — see game.js's entity/make.")
  :meta (:entry-provenance "spec-ambiguous" :required-fields-present #t
         :spec-note "Reference optional-forms (turn/size/tint) not implemented; impl accepts (name x y [color]) only."))

(verb
  :name "sprites"
  :library "-"
  :kind "read"
  :signature "(sprites) -> list"
  :summary "Return the current sprite accumulator as a list of sprite records."
  :impl-status "wired"
  :impl-file "src/game.js"
  :impl-notes "Returns a slice of game.sprites. Reference lists an alternative form (sprites sprite-list form) which the current impl does not accept — flagged spec-ambiguous."
  :examples (
    (:tier "novice" :code "(sprites)" :note "Empty list when nothing has been pushed.")
    (:tier "apprentice" :code "(sprite 'a 1 1) (sprites)" :note "One sprite after a push.")
    (:tier "intermediate" :code "(length (sprites))" :note "Count of active sprites.")
    (:tier "expert" :code "(define (sprite-count)\n  (length (sprites)))\n(sprite-count)" :note "Named counter.")
    (:tier "master" :code "(define (any p xs)\n  (cond ((null? xs) #f)\n        ((p (car xs)) #t)\n        (else (any p (cdr xs)))))\n(define (has-sprite? name)\n  (any (lambda (s) (equal? (obj-get s 'name) (symbol->string name)))\n       (sprites)))\n(sprite 'ball 40 40)\n(has-sprite? 'ball)" :note "Query for a specific sprite by name. Sprite records are objects — use obj-get 'name to compare.")
  )
  :caveats ("Signature mismatch: reference has a two-arg form; impl is zero-arg." "Returns a slice, not the live array — modifications don't persist.")
  :drawbacks ("No filtering in the base signature — iterate manually.")
  :usecases ("Debug inspection" "Test assertions" "Rendering post-processing")
  :related ("sprite" "sprites/clear")
  :learn (:concept "The accumulator is a value; reading it is a snapshot." :prerequisites () :progression "Read → count → named → query.")
  +cs (:complexity "O(n)" :effects (none) :pure #t :special-form #f)
  +eng (:impl-file "src/game.js" :impl-notes "Slice of game.sprites." :permission "read" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("length" "map" "filter") :consumes-from () :cardinality "many" :deterministic #f :cacheable #f :common-mistakes "Expecting mutations to the return to affect the game state." :when-not-to-use "For hot loops — cache the length or filter once.")
  :meta (:entry-provenance "spec-ambiguous" :required-fields-present #t
         :spec-note "Reference (sprites sprite-list form) not implemented; impl is zero-arg."))

