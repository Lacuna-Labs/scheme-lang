  :related ("radio-current-station-country")
  :learn (:concept "The name is the human-facing metadata." :prerequisites () :progression "Query → tagged → predicate → summary.")
  +cs (:complexity "O(1)" :effects (io) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "read" :latency-class "sync-fast" :since "0.1.0")
  +ai (:raises () :pipes-into ("string-append" "list" "string=?") :consumes-from () :cardinality "one" :deterministic #f :cacheable #f :common-mistakes "Not guarding for empty string." :when-not-to-use "For station switching — use radio-tune-station.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

