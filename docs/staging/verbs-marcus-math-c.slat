    (:tier "intermediate" :code "(define (unpublish-all ids) (map unpublish-listing ids)) (unpublish-all '(a b c))" :note "Batch.")
    (:tier "expert" :code "(define (unpublish-if pred ids) (map unpublish-listing (filter pred ids))) (unpublish-if (lambda (i) #t) '(a))" :note "Filtered.")
    (:tier "master" :code "(define (queue-removal ids reason)\n  (list 'reason reason 'queued (map unpublish-listing ids)))\n(queue-removal '(a b) 'discontinued)" :note "Audited batch.")
  )
  :caveats ("Standalone descriptor only." "Removal is queued, not immediate, in some hosts.")
  :drawbacks ("No 'restore from unpublished' primitive in the base signature.")
  :usecases ("Discontinuing items" "Seasonal removal" "Errata cleanup")
  :related ("store-listing-republish" "release-listing")
  :learn (:concept "Unpublishing hides. Different from release (which changes owner)." :prerequisites () :progression "Single → batch → filtered → audited.")
  +cs (:complexity "O(1) per call" :effects (io state) :pure #f :special-form #f)
  +eng (:impl-file "src/wired-verbs.js" :impl-notes "Descriptor return." :permission "network" :latency-class "async-quick" :since "0.1.0")
  +ai (:raises () :pipes-into ("map" "list") :consumes-from ("symbol") :cardinality "one" :deterministic #t :cacheable #f :common-mistakes "Confusing with delete — unpublish hides; delete removes." :when-not-to-use "For permanent removal — use delete-listing.")
  :meta (:entry-provenance "authored" :required-fields-present #t))

