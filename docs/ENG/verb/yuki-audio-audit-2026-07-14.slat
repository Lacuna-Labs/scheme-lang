;; ═══════════════════════════════════════════════════════════════
;; Yuki — Lacuna Eng Lead, audio wiring lane
;; Audit report — Phase A
;; Date: 2026-07-14
;; Branch: verbs/wire-596-2026-07-14
;;
;; Scope: radio/* + synth/* + note/* + audio/*.
;; Alfred: "We can't lie to people. They trust us."
;; ═══════════════════════════════════════════════════════════════

(lane
  :name "yuki-audio"
  :lead "Yuki"
  :scope "radio/* + synth/* + note/* + audio/*  (music-and-sound namespaces)"
  :phase "A — audit"
  :verb-count-in-scope 39
  :verb-count-in-brief 28
  :verb-count-note "Brief said ~28; the reference actually holds 39 records across these four libraries. All 39 are covered by this lane — full push."
  :reference-file "docs/SAKURA-SCHEME-REFERENCE.slat"
  :schema-file    "docs/SAKURA-SCHEME-REFERENCE-SCHEMA.slat"
  :impl-files     ("src/media.js" "src/sound.js" "src/wired-verbs.js" "src/reference-impls.js")
  :notes "Audio is low-latency by definition. Every verb here declares :latency-class. Descriptor-return verbs are honestly labeled as :impl-status \"wired-descriptor\" — the verb is callable, returns a stable shape a consumer can inspect, and does not lie about producing sound in a headless REPL.")

;; ── the FOUR namespaces ──────────────────────────────────────────
;;
;; radio/*  — 14 verbs.  A live radio-host surface. In standalone
;;            REPL every verb returns a descriptor list. In the
;;            hosted (browser) context the descriptors are consumed
;;            by the radio surface layer to actually play audio.
;;            Currently all 14 are dispatched as descriptors from
;;            src/wired-verbs.js:984-991. None lie: (radio/play 'x)
;;            returns ("radio/play" x) — a shape the caller can read.
;;
;; synth/*  — 9 verbs.  Musical synthesizers (808, chord, kit,
;;            orch, orchestra, play, sp1200, load-score, onset-tap).
;;            All 9 return [status info-dict] pairs — a mix of
;;            'ok, 'pending-audio, 'pending-fetch, 'pending-sample-bank
;;            depending on what live resource the verb would need.
;;            src/wired-verbs.js:183-200.
;;
;; note/*   — 3 verbs.  note/strike (sound a pitch), note/release
;;            (cut sustain), note/place-at (visual glyph on staff).
;;            All 3 return descriptors from wired-verbs.js:173-176.
;;            Semantics are well-shaped; consumer surfaces can turn
;;            the descriptor into a real audio+visual event.
;;
;; audio/*  — 13 verbs.  The read-side of the audio subsystem —
;;            listen, spectrum, tempo, key, lufs, onset?,
;;            onset-strength, playing?, halt, play, master-volume,
;;            bar-clock, transcribe-with-cloud-help. The
;;            'audio/master-volume' verb is one of the few that has
;;            a small side effect today: it stores intent in cortex
;;            via wired-verbs.js:398-403.
;;
;; ── evidence, recorded 2026-07-14 via ./bin/sakura-scheme eval ─────
;;   (radio/eq 'warm)                     → ("radio/eq" warm)
;;   (radio/play 'lofi)                   → ("radio/play" lofi)
;;   (note/strike 'C4 0.5)                → ("note/strike" "C4" 0.5)
;;   (synth/808 'kick)                    → (pending-audio #<object>)
;;   (audio/master-volume 0.5)            → (ok #<object>)
;;   (synth/orchestra 'main)              → (ok #<object>)
;;   (synth/play 'score 120)              → (pending-audio #<object>)
;;   (audio/transcribe-with-cloud-help x) → (pending-audio #<object>)
;;
;; No lies. Every call is callable and returns a shape.

;; ── audit entries — 39 verbs ─────────────────────────────────────
;;
;; Every audit entry uses the same three fields:
;;   :status  — one of:
;;     "wired-descriptor"  = returns a stable descriptor list.
;;     "wired-partial"     = does a small side effect (e.g. remembering
;;                           intent) plus returns an [ok info] tuple.
;;     "wired-pending"     = returns [pending-audio|pending-fetch info]
;;                           because a live subsystem is absent in REPL.
;;   :ref-shortfall — what's missing in the reference record vs the
;;     locked schema. Every entry today is short: 3 example tiers
;;     instead of 5, and the schema-added fields
;;     (:impl-status, :impl-file, :impl-notes, :permission,
;;      :latency-class, :cost, :raises, :deterministic, :cacheable,
;;      :entry-provenance) are absent.

