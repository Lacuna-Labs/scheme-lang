;; ── PHASE B PLAN ─────────────────────────────────────────────────

(plan
  :phase "B"
  :order
    (;; note/* first — smallest namespace, teaches the pattern
     "note/strike"
     "note/release"
     "note/place-at"
     ;; audio/* — read-side, mostly descriptor returns
     "audio/listen"
     "audio/playing?"
     "audio/halt"
     "audio/play"
     "audio/master-volume"
     "audio/spectrum"
     "audio/tempo"
     "audio/key"
     "audio/lufs"
     "audio/onset?"
     "audio/onset-strength"
     "audio/bar-clock"
     "audio/transcribe-with-cloud-help"
     ;; synth/* — richer schema fields, ok/pending pairs
     "synth/808"
     "synth/kit"
     "synth/chord"
     "synth/orch"
     "synth/orchestra"
     "synth/play"
     "synth/load-score"
     "synth/onset-tap"
     "synth/sp1200"
     ;; radio/* — 14 host-surface verbs
     "radio/stations"
     "radio/now-playing"
     "radio/play"
     "radio/pause"
     "radio/toggle"
     "radio/next"
     "radio/prev"
     "radio/mute"
     "radio/unmute"
     "radio/volume"
     "radio/mesh"
     "radio/visualize"
     "radio/sync-to-beat"
     "radio/eq")
  :fallback-shape
    "Every verb whose live subsystem is absent in the standalone REPL
     returns a shaped tuple:
       [pending-audio     info-dict]  — needs audio hardware / gesture
       [pending-fetch     info-dict]  — needs network
       [pending-sample-bank info-dict] — needs sample assets
       [ok                info-dict]  — pure metadata / state change
     Consumers running under a host surface pass their own installer
     that overrides these descriptors with real impls. That is the
     documented contract. Zero lies."
  :verification "each of 5 example tiers via ./bin/sakura-scheme eval; the verifier accepts any non-Error stderr as OK per architect-watch.mjs"
  :staging-file "docs/staging/verbs-yuki-audio.slat"
  :commit-shape "yuki-audio: wire <name>"
  :push "per-verb, no force, no --no-verify"
  :author-blocked-verbs "none — all 39 are describable within the current runtime")

;; End of audit. Waiting on schema lock, then Phase B begins.
