(verb
  :name "alg/interval-vector"
  :library "alg"
  :kind "pure"
  :signature "(alg/interval-vector pcs) -> list"
  :summary "Return the interval vector of a pitch-class set (music theory)."
  :impl-status "wired"
  :explanation "The interval vector of a pitch-class set counts, for each interval class (1 through 6, modulo octave), how many pairs of pitch classes span that interval. Result is a list of 6 integers. Interval vectors are invariant under transposition and inversion, so they classify pcsets up to the T/I-equivalence."
  :examples (
    (:tier "novice" :code "(alg/interval-vector '(0 4 7))" :note "C major triad — interval vector (0 0 1 1 1 0).")
    (:tier "apprentice" :code "(alg/interval-vector '(0 3 7))" :note "C minor triad — same interval vector as major (up to inversion).")
    (:tier "intermediate" :code "(alg/interval-vector '(0 1 2))" :note "Chromatic cluster: (2 1 0 0 0 0).")
    (:tier "expert" :code "(alg/interval-vector '())" :note "Empty pcset: (0 0 0 0 0 0).")
    (:tier "master" :code "(equal? (alg/interval-vector '(0 4 7)) (alg/interval-vector '(3 7 10)))" :note "Interval vector invariant under transposition: #t.")
  )
  :caveats ("Six integers, one per interval class 1..6." "Invariant under T_n and I.")
  :drawbacks ("Doesn't distinguish Z-related pcsets (rare pairs with same vector but different set-class).")
  :usecases ("Classify pcsets up to T/I equivalence." "Analyze harmonic content.")
  :related ("alg/pcset" "alg/prime-form")
  :learn (:concept "Interval vector as pcset invariant." :prerequisites ("alg/pcset") :progression "interval-vector -> prime-form -> Forte set-class catalogue.")
  :+eng (:impl-file "src/reference-impls.js" :impl-notes "Pairwise interval counting mod 12." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t)
  :+cs (:complexity "time O(n^2), space O(1)" :effects "none" :pure #t)
  :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/perm-cycles"
  :library "alg"
  :kind "pure"
  :signature "(alg/perm-cycles p) -> list-of-cycles"
  :summary "Alias for alg/perm->cycles: decompose a permutation into cycles."
  :impl-status "wired"
  :explanation "Same as alg/perm->cycles. This spelling matches older textbooks that use 'perm-cycles' rather than the arrow syntax. All three (perm-cycles, perm->cycles, permutation-cycles) are the same operation."
  :examples (
    (:tier "novice" :code "(alg/perm-cycles '(1 0 3 2))" :note "((0 1) (2 3)).")
    (:tier "apprentice" :code "(equal? (alg/perm-cycles '(1 2 0)) (alg/perm->cycles '(1 2 0)))" :note "#t.")
    (:tier "intermediate" :code "(alg/perm-cycles (alg/identity 4))" :note "().")
    (:tier "expert" :code "(map length (alg/perm-cycles '(1 2 0 4 3)))" :note "(3 2).")
    (:tier "master" :code "(equal? (alg/perm-cycles '(2 0 1)) (alg/permutation-cycles '(2 0 1)))" :note "Three spellings, one operation.")
  )
  :caveats ("Alias.") :drawbacks ("Redundant naming.")
  :usecases ("Match legacy code conventions.")
  :related ("alg/perm->cycles" "alg/permutation-cycles" "alg/perm-order")
  :learn (:concept "Cycle decomposition." :prerequisites ("alg/perm-apply") :progression "perm-cycles -> perm-order.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Delegates to permCycles helper." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(n), space O(n)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/permutation-cycles"
  :library "alg"
  :kind "pure"
  :signature "(alg/permutation-cycles p) -> list-of-cycles"
  :summary "Alias for alg/perm->cycles: decompose a permutation into cycles."
  :impl-status "wired"
  :explanation "Same as alg/perm->cycles. Longer spelling; some references prefer 'permutation-*' over 'perm-*'. All three names produce the same result."
  :examples (
    (:tier "novice" :code "(alg/permutation-cycles '(1 0 3 2))" :note "((0 1) (2 3)).")
    (:tier "apprentice" :code "(alg/permutation-cycles '(2 0 1))" :note "((0 2 1)).")
    (:tier "intermediate" :code "(equal? (alg/permutation-cycles '(1 2 0)) (alg/perm->cycles '(1 2 0)))" :note "#t.")
    (:tier "expert" :code "(alg/permutation-cycles (alg/identity 4))" :note "().")
    (:tier "master" :code "(map length (alg/permutation-cycles '(3 2 1 0)))" :note "(2 2) — two disjoint transpositions.")
  )
  :caveats ("Alias.") :drawbacks ("Redundant naming.")
  :usecases ("Match older conventions.")
  :related ("alg/perm->cycles" "alg/perm-cycles")
  :learn (:concept "Cycle decomposition (alt spelling)." :prerequisites ("alg/perm-apply") :progression "permutation-cycles -> perm-order.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Delegates to permCycles." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(n), space O(n)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/perm-order"
  :library "alg"
  :kind "pure"
  :signature "(alg/perm-order p) -> integer"
  :summary "Alias for alg/element-order: return the order of a permutation."
  :impl-status "wired"
  :explanation "Same as alg/element-order applied to a permutation: LCM of cycle lengths, including implicit 1-cycles. The identity has order 1."
  :examples (
    (:tier "novice" :code "(alg/perm-order '(1 2 0))" :note "3.")
    (:tier "apprentice" :code "(alg/perm-order (alg/identity 5))" :note "1.")
    (:tier "intermediate" :code "(alg/perm-order '(1 0 3 2))" :note "2 = LCM(2,2).")
    (:tier "expert" :code "(alg/perm-order '(1 2 0 4 3))" :note "6 = LCM(3,2).")
    (:tier "master" :code "(map alg/perm-order (alg/symmetric 3))" :note "(1 2 3 2 3 2) — orders of S_3 elements.")
  )
  :caveats ("Alias.") :drawbacks ("Redundant.")
  :usecases ("Match textbook conventions.")
  :related ("alg/element-order" "alg/perm->cycles")
  :learn (:concept "Order of a permutation." :prerequisites ("alg/perm->cycles") :progression "perm-order -> alg/exponent.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Delegates to permCycles + LCM." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(n), space O(n)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/perm-parity"
  :library "alg"
  :kind "pure"
  :signature "(alg/perm-parity p) -> integer"
  :summary "Alias for alg/perm-sign: return +1 for even, -1 for odd."
  :impl-status "wired"
  :explanation "Parity of a permutation: same as sign. +1 if the permutation is a product of an even number of transpositions, -1 otherwise. Homomorphism from S_n to {+1, -1}."
  :examples (
    (:tier "novice" :code "(alg/perm-parity '(1 0 2))" :note "-1 (odd).")
    (:tier "apprentice" :code "(alg/perm-parity (alg/identity 5))" :note "1.")
    (:tier "intermediate" :code "(alg/perm-parity '(1 2 0))" :note "1 (3-cycle is even).")
    (:tier "expert" :code "(equal? (alg/perm-parity '(2 1 0)) (alg/perm-sign '(2 1 0)))" :note "Alias check.")
    (:tier "master" :code "(map alg/perm-parity (alg/alternating 4))" :note "All +1.")
  )
  :caveats ("Alias.") :drawbacks ("Redundant.")
  :usecases ("Match sign-based textbook notation.")
  :related ("alg/perm-sign" "alg/alternating")
  :learn (:concept "Parity as sign." :prerequisites ("alg/perm-sign") :progression "perm-parity -> alternating.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Delegates to permSign." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(n), space O(n)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/permutation-compose"
  :library "alg"
  :kind "pure"
  :signature "(alg/permutation-compose p q) -> perm"
  :summary "Alias for alg/perm-compose: compose two permutations."
  :impl-status "wired"
  :explanation "Same as alg/perm-compose. Longer spelling; textbooks vary. All refer to (p ∘ q)(i) = p(q(i))."
  :examples (
    (:tier "novice" :code "(alg/permutation-compose '(1 0 2) '(2 1 0))" :note "Compose two permutations.")
    (:tier "apprentice" :code "(equal? (alg/permutation-compose '(1 2 0) '(2 0 1)) (alg/perm-compose '(1 2 0) '(2 0 1)))" :note "Alias check.")
    (:tier "intermediate" :code "(alg/permutation-compose (alg/identity 3) '(2 0 1))" :note "(2 0 1).")
    (:tier "expert" :code "(alg/permutation-compose '(1 2 0) (alg/perm-inverse '(1 2 0)))" :note "Identity.")
    (:tier "master" :code "(equal? (alg/permutation-compose '(1 0) '(1 0)) (alg/perm-identity 2))" :note "Self-inverse.")
  )
  :caveats ("Alias.") :drawbacks ("Redundant.")
  :usecases ("Match textbook conventions.")
  :related ("alg/perm-compose")
  :learn (:concept "Function composition." :prerequisites ("alg/perm-compose") :progression "same.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Delegates to permCompose." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:algebra "associative" :total #t) :+cs (:complexity "time O(n), space O(n)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/generate"
  :library "alg"
  :kind "pure"
  :signature "(alg/generate G generators) -> subgroup"
  :summary "Alias for alg/subgroup-gen: generate a subgroup from a set of elements."
  :impl-status "wired"
  :explanation "Same as alg/subgroup-gen. Compute the closure of the given generators under the group operation, yielding the smallest subgroup containing them."
  :examples (
    (:tier "novice" :code "(alg/generate (alg/cyclic 6) (list 2))" :note "(0 2 4).")
    (:tier "apprentice" :code "(equal? (alg/generate (alg/cyclic 6) (list 3)) (alg/subgroup-gen (alg/cyclic 6) (list 3)))" :note "Alias check.")
    (:tier "intermediate" :code "(alg/generate (alg/cyclic 6) (list 1))" :note "(0 1 2 3 4 5) — 1 is a generator.")
    (:tier "expert" :code "(length (alg/generate (alg/cyclic 12) (list 4 6)))" :note "gcd(4, 6, 12) = 2 -> generates (0 2 4 6 8 10).")
    (:tier "master" :code "(equal? (alg/generate (alg/cyclic 6) (list 2 3)) (alg/subgroup-gen (alg/cyclic 6) (list 2 3)))" :note "Same as subgroup-gen.")
  )
  :caveats ("Alias.") :drawbacks ("Redundant naming.")
  :usecases ("Match older library conventions.")
  :related ("alg/subgroup-gen" "alg/subgroup")
  :learn (:concept "Subgroup generation (alias)." :prerequisites ("alg/subgroup-gen") :progression "same.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Delegates to subgroup-gen." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(k * n^2), space O(n)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/subgroup"
  :library "alg"
  :kind "pure"
  :signature "(alg/subgroup G generators) -> subgroup"
  :summary "Alias for alg/subgroup-gen: build the subgroup generated by the given elements."
  :impl-status "wired"
  :explanation "Same as alg/subgroup-gen and alg/generate. Compute the closure under the group operation."
  :examples (
    (:tier "novice" :code "(alg/subgroup (alg/cyclic 6) (list 2))" :note "(0 2 4).")
    (:tier "apprentice" :code "(alg/subgroup (alg/cyclic 12) (list 3))" :note "(0 3 6 9).")
    (:tier "intermediate" :code "(alg/subgroup (alg/cyclic 8) (list 4))" :note "(0 4).")
    (:tier "expert" :code "(length (alg/subgroup (alg/cyclic 5) (list 1)))" :note "5.")
    (:tier "master" :code "(equal? (alg/subgroup (alg/cyclic 6) (list 3)) (alg/generate (alg/cyclic 6) (list 3)))" :note "Alias.")
  )
  :caveats ("Alias.") :drawbacks ("Redundant.")
  :usecases ("Match textbook conventions.")
  :related ("alg/subgroup-gen" "alg/generate")
  :learn (:concept "Subgroup generation." :prerequisites ("alg/subgroup-gen") :progression "same.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Delegates to subgroup-gen." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(k * n^2), space O(n)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/subgroups"
  :library "alg"
  :kind "pure"
  :signature "(alg/subgroups G) -> list-of-subgroups"
  :summary "Enumerate all subgroups of G."
  :impl-status "wired"
  :explanation "Return every subgroup of G. Uses bitmask enumeration of subsets, filtered by closure + inverse + identity. Capped at |G| <= 8 for tractability; larger groups return 'use-backend. Every finite group has at least 2 subgroups: {e} and G itself."
  :examples (
    (:tier "novice" :code "(length (alg/subgroups (alg/cyclic 4)))" :note "Z_4 has 3 subgroups: {0}, {0,2}, {0,1,2,3}.")
    (:tier "apprentice" :code "(length (alg/subgroups (alg/cyclic 6)))" :note "Z_6 has 4 subgroups.")
    (:tier "intermediate" :code "(alg/subgroups (alg/cyclic 3))" :note "Two subgroups: identity and Z_3 itself.")
    (:tier "expert" :code "(alg/subgroups (alg/cyclic 9))" :note "|G| = 9 > 8: returns 'use-backend.")
    (:tier "master" :code "(map length (alg/subgroups (alg/cyclic 6)))" :note "Subgroup sizes divide |G|: divisors of 6 are (1 2 3 6).")
  )
  :caveats ("Capped at |G| <= 8; larger returns 'use-backend." "2^|G| enumeration.")
  :drawbacks ("Exponential in |G| — infeasible for large groups.")
  :usecases ("Enumerate subgroup lattice for small groups." "Test structural theorems.")
  :related ("alg/subgroup" "alg/subgroup-gen" "alg/is-normal?")
  :learn (:concept "Subgroup lattice." :prerequisites ("alg/subgroup?") :progression "subgroups -> normal subgroups -> composition series.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Bitmask + closure + inverse check." :permission "read" :latency-class "sync-slow" :since "1.0")
  :+math (:total #f) :+cs (:complexity "time O(2^|G| * |G|^2), space O(|G|)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t :raises ("(quote use-backend) for |G| > 8")))


(verb
  :name "alg/is-cyclic?"
  :library "alg"
  :kind "pure"
  :signature "(alg/is-cyclic? G) -> boolean"
  :summary "Return #t if G is cyclic (generated by a single element)."
  :impl-status "wired"
  :explanation "G is cyclic if there exists an element g in G whose powers exhaust G — i.e., g has order |G|. This verb searches for such an element by computing each element's order and checking equality with |G|. Every cyclic group is abelian, but not every abelian group is cyclic (e.g., Klein 4-group)."
  :examples (
    (:tier "novice" :code "(alg/is-cyclic? (alg/cyclic 5))" :note "#t — trivially.")
    (:tier "apprentice" :code "(alg/is-cyclic? (alg/cyclic 6))" :note "#t.")
    (:tier "intermediate" :code "(alg/is-cyclic? (alg/dihedral 4))" :note "#f — D_4 is not cyclic.")
    (:tier "expert" :code "(alg/is-cyclic? (alg/cyclic 12))" :note "#t.")
    (:tier "master" :code "(filter alg/is-cyclic? (list (alg/cyclic 5) (alg/dihedral 3) (alg/cyclic 8) (alg/dihedral 4)))" :note "Filter cyclic groups.")
  )
  :caveats ("Requires computing element orders; O(|G|^2).")
  :drawbacks ("Slow for large groups.")
  :usecases ("Test whether G is generated by a single element." "Classify small groups.")
  :related ("alg/is-abelian?" "alg/element-order" "alg/generators")
  :learn (:concept "Cyclic groups — generated by one element." :prerequisites ("alg/element-order") :progression "is-cyclic? -> classification of finite abelian groups.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Iterate G; check for element of order |G|." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(|G|^2), space O(1)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/is-subgroup?"
  :library "alg"
  :kind "pure"
  :signature "(alg/is-subgroup? G H) -> boolean"
  :summary "Alias for alg/subgroup?: test whether H is a subgroup of G."
  :impl-status "wired"
  :explanation "Same as alg/subgroup?. Check subset, identity, closure, and inverse closure."
  :examples (
    (:tier "novice" :code "(alg/is-subgroup? (alg/cyclic 6) '(0 3))" :note "#t.")
    (:tier "apprentice" :code "(alg/is-subgroup? (alg/cyclic 6) '(0 1 2))" :note "#f — not closed.")
    (:tier "intermediate" :code "(equal? (alg/is-subgroup? (alg/cyclic 6) '(0 2 4)) (alg/subgroup? (alg/cyclic 6) '(0 2 4)))" :note "Alias.")
    (:tier "expert" :code "(alg/is-subgroup? (alg/cyclic 6) '(0))" :note "#t — trivial subgroup.")
    (:tier "master" :code "(alg/is-subgroup? (alg/cyclic 6) '(1 2 3))" :note "#f — no identity.")
  )
  :caveats ("Alias of alg/subgroup?.")
  :drawbacks ("Redundant.")
  :usecases ("Match textbook conventions.")
  :related ("alg/subgroup?" "alg/subgroup-gen")
  :learn (:concept "Subgroup verification." :prerequisites ("alg/subgroup?") :progression "same.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Same as alg/subgroup?." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(|H|^2), space O(|H|)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/left-cosets"
  :library "alg"
  :kind "pure"
  :signature "(alg/left-cosets G H) -> list-of-lists"
  :summary "Return the left cosets gH of H in G."
  :impl-status "wired"
  :explanation "The left cosets are the sets { gH : g in G }, which partition G into disjoint pieces of size |H|. Deduplicated by sorted-set key. There are exactly [G:H] = |G|/|H| distinct cosets (Lagrange's theorem)."
  :examples (
    (:tier "novice" :code "(alg/left-cosets (alg/cyclic 6) '(0 3))" :note "((0 3) (1 4) (2 5)) — 3 cosets.")
    (:tier "apprentice" :code "(length (alg/left-cosets (alg/cyclic 12) '(0 4 8)))" :note "4 cosets.")
    (:tier "intermediate" :code "(alg/left-cosets (alg/cyclic 4) '(0))" :note "((0) (1) (2) (3)) — 4 cosets.")
    (:tier "expert" :code "(alg/left-cosets (alg/cyclic 6) '(0 1 2 3 4 5))" :note "One coset containing all of G.")
    (:tier "master" :code "(define (lagrange-check G H) (= (length (alg/left-cosets G H)) (/ (length G) (length H)))) (lagrange-check (alg/cyclic 12) '(0 4 8))" :note "|cosets| = |G|/|H|.")
  )
  :caveats ("Coset equality via sorted-set key comparison.")
  :drawbacks ("O(|G|*|H|) time.")
  :usecases ("Enumerate cosets for quotient construction." "Verify Lagrange's theorem.")
  :related ("alg/right-cosets" "alg/quotient" "alg/is-normal?")
  :learn (:concept "Cosets partition G." :prerequisites ("alg/op") :progression "left-cosets -> quotient -> homomorphism theorems.")
  :+eng (:impl-file "src/alg.js" :impl-notes "For each g in G, compute gH; dedupe by sorted-set key." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(|G|*|H|), space O(|G|)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))


(verb
  :name "alg/right-cosets"
  :library "alg"
  :kind "pure"
  :signature "(alg/right-cosets G H) -> list-of-lists"
  :summary "Return the right cosets Hg of H in G."
  :impl-status "wired"
  :explanation "The right cosets are the sets { Hg : g in G }. When H is normal, left and right cosets coincide; when H is non-normal, they generally differ. Same partitioning structure as left cosets: [G:H] distinct pieces of size |H|."
  :examples (
    (:tier "novice" :code "(alg/right-cosets (alg/cyclic 6) '(0 3))" :note "In abelian Z_6, right = left cosets.")
    (:tier "apprentice" :code "(length (alg/right-cosets (alg/cyclic 12) '(0 4 8)))" :note "4.")
    (:tier "intermediate" :code "(alg/right-cosets (alg/cyclic 4) '(0))" :note "4 singleton cosets.")
    (:tier "expert" :code "(equal? (alg/right-cosets (alg/cyclic 6) '(0 3)) (alg/left-cosets (alg/cyclic 6) '(0 3)))" :note "#t for abelian groups.")
    (:tier "master" :code "(define (normal-check G H) (equal? (map length (alg/left-cosets G H)) (map length (alg/right-cosets G H)))) (normal-check (alg/cyclic 6) '(0 3))" :note "Left and right coset sizes agree (both partition G).")
  )
  :caveats ("For non-abelian G, right cosets may differ from left cosets.")
  :drawbacks ("O(|G|*|H|) time.")
  :usecases ("Complement to left-cosets for normality checks.")
  :related ("alg/left-cosets" "alg/quotient" "alg/is-normal?")
  :learn (:concept "Right cosets — dual of left cosets." :prerequisites ("alg/left-cosets") :progression "right-cosets -> compare-to-left -> normal-subgroup detection.")
  :+eng (:impl-file "src/alg.js" :impl-notes "Hg via multiplying each h on the right by g." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t) :+cs (:complexity "time O(|G|*|H|), space O(|G|)" :effects "none" :pure #t) :+ai (:deterministic #t :cacheable #t))
