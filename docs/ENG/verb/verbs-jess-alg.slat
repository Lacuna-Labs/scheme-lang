(verb
  :name "alg/group-from-table"
  :library "alg"
  :kind "pure"
  :signature "(alg/group-from-table tbl) -> group"
  :summary "Wrap a raw Cayley table into a group — currently a passthrough."
  :impl-status "wired"
  :explanation "Given a raw Cayley table (list of lists of integers), return it as a group. The current impl is a passthrough — it does not validate the axioms. Downstream verbs (alg/op, alg/order) work directly on the table. For explicit axiom validation, add a wrapper that checks closure + identity row + inverses."
  :examples (
    (:tier "novice" :code "(alg/group-from-table '((0 1) (1 0)))" :note "Z_2 table: passes through.")
    (:tier "apprentice" :code "(alg/order (alg/group-from-table '((0 1) (1 0))))" :note "Order 2.")
    (:tier "intermediate" :code "(alg/op (alg/group-from-table '((0 1 2) (1 2 0) (2 0 1))) 1 2)" :note "In Z_3: 1 + 2 = 0.")
    (:tier "expert" :code "(alg/group-from-table (alg/cyclic 4))" :note "Wrap an existing Cayley table.")
    (:tier "master" :code "(equal? (alg/group-from-table (alg/cyclic 5)) (alg/cyclic 5))" :note "Passthrough: table unchanged.")
  )
