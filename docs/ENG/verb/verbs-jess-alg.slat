(verb
  :name "alg/cycles->perm"
  :library "alg"
  :kind "pure"
  :signature "(alg/cycles->perm cycles) -> perm"
  :summary "Build a permutation from a list of disjoint cycles."
  :impl-status "wired"
  :explanation "Given a list of cycles, each cycle a list of moved elements, construct the permutation. A cycle (a b c) means a->b, b->c, c->a. Unlisted elements are fixed. Inverse of alg/perm->cycles. The degree is inferred from the maximum element mentioned in the cycles."
  :examples (
    (:tier "novice" :code "(alg/cycles->perm (list (list 0 1)))" :note "Swap 0 and 1: (1 0).")
    (:tier "apprentice" :code "(alg/cycles->perm (list (list 0 1 2)))" :note "3-cycle: (1 2 0).")
    (:tier "intermediate" :code "(alg/cycles->perm (list (list 0 1) (list 2 3)))" :note "Product of two transpositions: (1 0 3 2).")
    (:tier "expert" :code "(alg/cycles->perm '())" :note "Empty cycles: empty permutation.")
    (:tier "master" :code "(equal? (alg/perm->cycles (alg/cycles->perm (list (list 0 1 2)))) (list (list 0 1 2)))" :note "Round-trip.")
  )
  :caveats ("Cycles must be disjoint." "Unlisted elements are fixed.")
  :drawbacks ("Doesn't validate disjointness.")
  :usecases ("Build permutations from readable cycle notation." "Inverse of perm->cycles.")
  :related ("alg/perm->cycles" "alg/perm-order")
  :learn (:concept "Cycle notation for permutations." :prerequisites ("alg/perm->cycles") :progression "cycles->perm -> full permutation manipulation.")
  :+eng (:impl-file "src/reference-impls.js" :impl-notes "Build image array by walking each cycle." :permission "read" :latency-class "sync-fast" :since "1.0")
  :+math (:total #t)
  :+cs (:complexity "time O(sum cycle lengths), space O(max element + 1)" :effects "none" :pure #t)
  :+ai (:deterministic #t :cacheable #t))


