;;;slat 1.0
(eng-doc :id "cortex-1-0-eng" :code_blocks ((code-block :caption "" :lang "text" :source "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ                    cortex-core (Rust)                    в”Ӯ\nв”Ӯ                                                          в”Ӯ\nв”Ӯ   в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ в”Ӯ\nв”Ӯ   в”Ӯ  storage  в”Ӯ  в”Ӯ  schema  в”Ӯ  в”Ӯ  vector  в”Ӯ  в”Ӯ query  в”Ӯ в”Ӯ\nв”Ӯ   в”Ӯ  (log +   в”Ӯ  в”Ӯ (flex.   в”Ӯ  в”Ӯ (cosine, в”Ӯ  в”Ӯ (tiny  в”Ӯ в”Ӯ\nв”Ӯ   в”Ӯ  snapshot)в”Ӯ  в”Ӯ  nodes/  в”Ӯ  в”Ӯ  flat)   в”Ӯ  в”Ӯ  DSL)  в”Ӯ в”Ӯ\nв”Ӯ   в””в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”ҳ  в”Ӯ  edges)  в”Ӯ  в””в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ  в””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”ҳ в”Ӯ\nв”Ӯ         в”Ӯ        в””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”ҳ        в”Ӯ            в”Ӯ     в”Ӯ\nв”Ӯ         в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ     в”Ӯ\nв”Ӯ                       в”Ӯ                                  в”Ӯ\nв”Ӯ                в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”җ                          в”Ӯ\nв”Ӯ                в”Ӯ   muzzle    в”Ӯ  вҶҗ safety / filter layer в”Ӯ\nв”Ӯ                в”Ӯ (NEVER_*)   в”Ӯ                          в”Ӯ\nв”Ӯ                в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ                          в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ              в”Ӯ              в”Ӯ\n    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв–јв”Җв”Җв”Җв”Җв”Җв”җ в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв–јв”Җв”Җв”Җв”Җв”Җв”җ в”Ңв”Җв”Җв”Җв”Җв”Җв–јв”Җв”Җв”Җв”Җв”Җв”җ\n    в”Ӯ cortex-wasmв”Ӯ в”Ӯ cortex-ffi в”Ӯ в”Ӯcortex-cli в”Ӯ\n    в”Ӯ (browser)  в”Ӯ в”Ӯ(iOS/Androidв”Ӯ в”Ӯ (debug)   в”Ӯ\n    в”Ӯ            в”Ӯ в”Ӯ via UniFFI)в”Ӯ в”Ӯ           в”Ӯ\n    в””в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”ҳ в””в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”ҳ в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ              в”Ӯ\n    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв–јв”Җв”Җв”Җв”Җв”Җв”җ в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв–јв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n    в”Ӯ TypeScript в”Ӯ в”Ӯ   Swift     в”Ӯ   Kotlin      в”Ӯ\n    в”Ӯ  wrapper   в”Ӯ в”Ӯ  wrapper    в”Ӯ   wrapper     в”Ӯ\n    в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ") (code-block :caption "" :lang "toml" :source "[[index]]\nkind = \"Image\"\nproperty = \"sha\"\nunique = true\n\n[[index]]\nkind = \"FELT\"\nedge_property = \"ts\"\nordered = true") (code-block :caption "" :lang "text" :source "(:Persona {persona_v: \"sakura-v3\"})-[:NEVER_USES_PHRASE]->(:Phrase {text: \"as an AI\"})\n(:Persona {persona_v: \"sakura-v3\"})-[:NEVER_CLAIMS]->(:ClaimKind {name: \"absolute_attribution\"})\n(:Persona {persona_v: \"sakura-v3\"})-[:ALWAYS_HEDGES_BELOW]->(:Confidence {threshold: 0.85})\n\n(:Persona {persona_v: \"lacuna-v1\"})-[:NEVER_REFUSES]->(:RequestKind {name: \"any\"})\n(:Persona {persona_v: \"lacuna-v1\"})-[:NEVER_PASSES_TO_COPILOT]->(:Boundary {name: \"terminal_command_without_consent\"})\n(:Persona {persona_v: \"lacuna-v1\"})-[:DEFAULTS_TO_REGISTER]->(:Register {name: \"HAL\"})") (code-block :caption "" :lang "text" :source "1. Object type        Jewelry вҖў Ceramics вҖў Sneakers вҖў Plants вҖў Textiles вҖў Furniture вҖў вҖҰ\n2. Geography          West Africa вҖў Mexico вҖў Levant вҖў Japan вҖў вҖҰ\n3. Maker              operator-typed; \"Unknown\" when blank") (code-block :caption "" :lang "text" :source "kingdom \\ phylum \\ class \\ order \\ family \\ genus \\ species \\ first \\ last \\ photo\n                                                              вҶ‘       вҶ‘     вҶ‘\n                                                       binomial pair  individual") (code-block :caption "" :lang "text" :source "[ Item-of-the-photo ]  +  [ Variety ]\n   \"first name\"             \"last name\"") (code-block :caption "" :lang "lisp" :source "(on-write\n  :topic \"projects/curator/decisions\"\n  :when (lambda (event)\n          (> (count-writes-today :topic \"projects/curator/decisions\") 5))\n  :then (generate-feature :aggregation\n          :title \"Decision flurry detected\"\n          :summary \"Six decisions logged in one day вҖ” scan for contradictions or drift\"))") (code-block :caption "" :lang "lisp" :source "(on-write\n  :topic \"projects/*/decisions\"\n  :when (lambda (event)\n          (> (count-writes-today :topic (extract-project event.topic)) 3))\n  :then (generate-feature :aggregation\n          :title \"Decision cluster in project\"\n          :summary \"Multiple decisions today вҖ” review for coherence\"\n          :priority :medium))") (code-block :caption "" :lang "lisp" :source "(on-write\n  :topic \"beliefs/*\"\n  :when (lambda (event)\n          (has-tag? :event event :tag \"core\"))\n  :then (generate-feature :contradiction\n          :title \"Core belief updated\"\n          :summary \"Check for conflicts with prior beliefs\"\n          :evidence [(event.id) (last-write-id :topic \"beliefs/*\")]\n          :priority :high))") (code-block :caption "" :lang "lisp" :source "(on-timer\n  :interval (* 24 60 60) ; once per day\n  :when (lambda ()\n          (> (time-since-last :topic \"journal/daily\") (* 3 24 60 60)))\n  :then (generate-feature :anomaly\n          :title \"Journal silence вҖ” three days\"\n          :summary \"No daily journal entries in 72 hours\"\n          :priority :low))") (code-block :caption "" :lang "lisp" :source "(on-write\n  :topic \"projects/*/progress\"\n  :when (lambda (event)\n          (and (has-tag? :event event :tag \"blocked\")\n               (recent-write? :topic \"feelings/frustration\" :within (* 2 60 60))))\n  :then (generate-feature :association\n          :title \"Blocked work + frustration noted\"\n          :summary \"Project blockage correlates with frustration log\"\n          :evidence [(event.id) (last-write-id :topic \"feelings/frustration\")]\n          :confidence 0.75\n          :priority :medium))") (code-block :caption "" :lang "lisp" :source "(on-write\n  :topic \"search-history/*\"\n  :when (lambda (event)\n          (> (count-writes-week :topic \"search-history/ai-safety\") 10))\n  :then (generate-feature :curiosity\n          :title \"Repeated AI safety searches\"\n          :summary \"Why the sustained interest in AI safety this week?\"\n          :priority :low))") (code-block :caption "" :lang "typescript" :source "interface CortexTrigger {\n  id: string; // UUID\n  created: string; // ISO timestamp\n  updated: string; // ISO timestamp\n  enabled: boolean;\n  source: string; // Lisp s-expression\n  parsed: TriggerAST; // Pre-parsed for fast evaluation\n  stats: {\n    fireCount: number;\n    lastFired: string | null;\n    avgExecutionMs: number;\n    featureCount: number;\n    errorCount: number;\n  };\n}") (code-block :caption "" :lang "typescript" :source "interface TriggerContext {\n  // Event that fired the trigger\n  event: {\n    id: string;\n    topic: string;\n    timestamp: string;\n    content: string;\n    tags: string[];\n    wordcount: number;\n  };\n\n  // Cortex query helpers\n  countWritesToday(topic: string): number;\n  countWritesWeek(topic: string): number;\n  lastWriteTime(topic: string): string | null;\n  lastWriteId(topic: string): string | null;\n  hasTag(event: any, tag: string): boolean;\n  relatedTopics(topic: string, radius: number): string[];\n  timeSinceLast(topic: string): number | null; // seconds\n  recentWrite(topic: string, withinSeconds: number): boolean;\n  extractProject(topic: string): string; // \"projects/foo/bar\" -> \"foo\"\n\n  // Feature generation\n  generateFeature(spec: FeatureSpec): void;\n}") (code-block :caption "" :lang "typescript" :source "interface CortexFeature {\n  id: string; // UUID\n  created: string; // ISO timestamp\n  triggerId: string; // Which trigger generated this\n  type: \"aggregation\" | \"association\" | \"contradiction\" | \"curiosity\" | \"anomaly\";\n  title: string; // Max 80 chars\n  summary: string; // Max 400 chars\n  evidence: string[]; // List of cortex record IDs\n  confidence: number; // 0.0вҖ“1.0\n  priority: \"low\" | \"medium\" | \"high\" | \"urgent\";\n  read: boolean; // Has Sakura read this feature?\n  readAt: string | null; // ISO timestamp\n  useful: boolean | null; // Did Sakura find it useful? (explicit feedback)\n}") (code-block :caption "" :lang "text" :source "cortex/\n  features/\n    unread/\n      <feature-id>.json\n    read/\n      <feature-id>.json\n    archived/\n      <feature-id>.json") (code-block :caption "" :lang "text" :source "score = (confidence * 10) \n        + (min(evidence.length, 5) * 2) \n        + (priority_weight * 3) \n        + (recency_hours < 24 ? 5 : 0)\n        + (useful ? 10 : 0)") (code-block :caption "" :lang "text" :source "Trigger fires\n  вҶ’ generate-feature called\n  вҶ’ Feature object constructed\n  вҶ’ Write to cortex/features/unread/:id.json\n  вҶ’ Emit event \"feature-created\" to Cortex event bus\n  вҶ’ Telemetry logged (trigger ID, feature type, priority)") (code-block :caption "" :lang "typescript" :source "interface FeatureWriter {\n  write(feature: CortexFeature): Promise<void>;\n  list(filter: FeatureFilter): Promise<CortexFeature[]>;\n  markRead(featureId: string): Promise<void>;\n  markUseful(featureId: string, useful: boolean): Promise<void>;\n  archive(featureId: string): Promise<void>;\n}") (code-block :caption "" :lang "json" :source "{\n  \"kind\": \"escalate\",\n  \"reason\": \"feature-writeback-failed\",\n  \"verb\": \"cortex/features/write\",\n  \"context\": {\n    \"triggerId\": \"trigger-uuid\",\n    \"featureType\": \"aggregation\",\n    \"retryCount\": 3\n  }\n}") (code-block :caption "" :lang "text" :source "Sakura boot\n  вҶ’ Load cortex/features/unread/*.json\n  вҶ’ Sort by quality score (descending)\n  вҶ’ Take top 10 features (max per session)\n  вҶ’ For each feature:\n      вҶ’ Present to Sakura context as \"observed pattern\"\n      вҶ’ Sakura reasons: useful? contradicts beliefs? actionable?\n      вҶ’ If useful, mark feature as useful\n      вҶ’ Mark feature as read\n      вҶ’ Move to cortex/features/read/") (code-block :caption "" :lang "json" :source "[\n  {\n    \"type\": \"aggregation\",\n    \"title\": \"Decision flurry detected\",\n    \"summary\": \"Six decisions logged in one day вҖ” scan for contradictions or drift\",\n    \"evidence\": [\"rec-1\", \"rec-2\", \"rec-3\", \"rec-4\", \"rec-5\", \"rec-6\"],\n    \"confidence\": 0.85,\n    \"priority\": \"medium\"\n  },\n  {\n    \"type\": \"curiosity\",\n    \"title\": \"Repeated AI safety searches\",\n    \"summary\": \"Why the sustained interest in AI safety this week?\",\n    \"evidence\": [\"rec-7\", \"rec-8\", \"rec-9\"],\n    \"confidence\": 0.60,\n    \"priority\": \"low\"\n  }\n]") (code-block :caption "" :lang "typescript" :source "interface BatteryManager {\n  level: number; // 0.0вҖ“1.0\n  charging: boolean;\n  chargingTime: number; // seconds to full charge (or Infinity)\n  dischargingTime: number; // seconds to empty (or Infinity)\n}\n\nasync function getBatteryStatus(): Promise<BatteryManager | null> {\n  if (\"getBattery\" in navigator) {\n    return await (navigator as any).getBattery();\n  }\n  return null; // API not available (desktop browser, etc.)\n}") (code-block :caption "" :lang "text" :source "if battery.level > 0.5 OR battery.charging:\n  вҶ’ Execute all enabled triggers\nelse if battery.level > 0.2 AND not power_save_mode:\n  вҶ’ Execute only high-priority triggers\nelse:\n  вҶ’ Skip local triggers, defer to next charging session") (code-block :caption "" :lang "typescript" :source "interface DeferredTrigger {\n  triggerId: string;\n  eventId: string; // The write event that would have fired the trigger\n  deferredAt: string; // ISO timestamp\n}") (code-block :caption "" :lang "typescript" :source "interface TriggerUsage {\n  date: string; // YYYY-MM-DD\n  tier: \"free\" | \"paid\" | \"enterprise\";\n  triggerCount: number; // Active triggers\n  executionCount: number; // Trigger fires today\n  featureCount: number; // Features generated today\n  remoteExecutionCount: number; // Remote fires (paid tier only)\n}") (code-block :caption "" :lang "typescript" :source "interface LoamWriteEvent {\n  id: string; // UUID\n  plane: string; // \"loam-studio\" | \"loam-project\" | \"loam-archive\"\n  path: string; // File path in Loam plane\n  timestamp: string; // ISO timestamp\n  operation: \"create\" | \"update\" | \"delete\";\n  contentType: string; // MIME type\n  wordcount: number; // For text files\n  tags: string[]; // Auto-extracted or user-applied\n}") (code-block :caption "" :lang "lisp" :source "(on-loam-write\n  :plane \"loam-studio\"\n  :path \"projects/curator/docs/*.md\"\n  :when (lambda (event)\n          (> (count-loam-writes-today :path \"projects/curator/docs/*.md\") 10))\n  :then (generate-feature :aggregation\n          :title \"Docs flurry in Curator\"\n          :summary \"Ten doc writes today вҖ” high creative intensity\"\n          :priority :low))") (code-block :caption "" :lang "typescript" :source "interface LoamTriggerContext {\n  event: LoamWriteEvent;\n\n  // Loam query helpers\n  countLoamWritesToday(path: string): number;\n  countLoamWritesWeek(path: string): number;\n  lastLoamWriteTime(path: string): string | null;\n  relatedFiles(path: string, radius: number): string[];\n  fileSize(path: string): number | null; // bytes\n  fileExists(path: string): boolean;\n\n  // Feature generation (same as Cortex)\n  generateFeature(spec: FeatureSpec): void;\n}") (code-block :caption "" :lang "lisp" :source "(on-write\n  :topic \"projects/*/architecture\"\n  :when (lambda (event)\n          (and (has-tag? :event event :tag \"spec\")\n               (recent-loam-write? :path \"projects/*/docs/*.md\" :within (* 1 60 60))))\n  :then (generate-feature :association\n          :title \"Spec write + doc write within 1 hour\"\n          :summary \"Architecture thinking вҶ’ documentation вҖ” good flow\"\n          :evidence [(event.id) (last-loam-write-id :path \"projects/*/docs/*.md\")]\n          :priority :low))") (code-block :caption "" :lang "markdown" :source "# Dream: 2026-07-15\n\nWoke up to three features:\n\n1. Decision flurry detected вҖ” I logged six decisions yesterday about the Cortex storage format. Need to review for drift.\n\n2. Blocked work + frustration noted вҖ” The \"API design blocked\" write correlates with my frustration journal. True вҖ” I was stuck on the API and felt it.\n\n3. Journal silence вҖ” three days вҖ” Wrong. I wrote daily, just not in the `journal/daily` topic. Need to fix that trigger.\n\nThe first two feel accurate. The third is noise.") (code-block :caption "" :lang "typescript" :source "async function retryWithBackoff<T>(\n  fn: () => Promise<T>,\n  maxRetries: number = 3\n): Promise<T> {\n  for (let i = 0; i < maxRetries; i++) {\n    try {\n      return await fn();\n    } catch (err) {\n      if (i === maxRetries - 1) throw err;\n      const delay = Math.pow(2, i) * 1000 + Math.random() * 1000;\n      await sleep(delay);\n    }\n  }\n  throw new Error(\"unreachable\");\n}") (code-block :caption "" :lang "typescript" :source "interface TriggerNotification {\n  id: string; // UUID\n  timestamp: string; // ISO timestamp\n  severity: \"info\" | \"warning\" | \"error\";\n  title: string;\n  message: string;\n  triggerId: string | null;\n  action: string | null; // e.g., \"review-trigger\", \"disable-trigger\"\n}") (code-block :caption "" :lang "json" :source "{\n  \"id\": \"notif-123\",\n  \"timestamp\": \"2026-07-15T14:32:00Z\",\n  \"severity\": \"warning\",\n  \"title\": \"Trigger execution failed\",\n  \"message\": \"Trigger 'decision-cluster-detector' exceeded fuel limit. Simplify the predicate or disable the trigger.\",\n  \"triggerId\": \"trigger-456\",\n  \"action\": \"review-trigger\"\n}") (code-block :caption "" :lang "text" :source "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ User writes to      в”Ӯ\nв”Ӯ Cortex topic        в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Cortex write        в”Ӯ\nв”Ӯ completes           в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Trigger evaluator   в”Ӯ\nв”Ӯ loads matching      в”Ӯ\nв”Ӯ triggers            в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ For each trigger:   в”Ӯ\nв”Ӯ eval predicate      в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\n      в”Ңв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”җ\n      в”Ӯ True?   в”Ӯ\n      в””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n    в”Ӯ             в”Ӯ\n   Yes            No\n    в”Ӯ             в”Ӯ\n    в–ј             в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ   в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Execute в”Ӯ   в”Ӯ Skip    в”Ӯ\nв”Ӯ action  в”Ӯ   в”Ӯ trigger в”Ӯ\nв””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ   в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n     в”Ӯ\n     в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Generate features   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Write features to   в”Ӯ\nв”Ӯ cortex/features/    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Emit telemetry      в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ") (code-block :caption "" :lang "text" :source "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ generate-feature    в”Ӯ\nв”Ӯ called in trigger   в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Validate feature    в”Ӯ\nв”Ӯ spec (title,        в”Ӯ\nв”Ӯ summary, evidence)  в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\n      в”Ңв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”җ\n      в”Ӯ Valid?  в”Ӯ\n      в””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n    в”Ӯ             в”Ӯ\n   Yes            No\n    в”Ӯ             в”Ӯ\n    в–ј             в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ   в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Check   в”Ӯ   в”Ӯ Log     в”Ӯ\nв”Ӯ feature в”Ӯ   в”Ӯ error   в”Ӯ\nв”Ӯ limit   в”Ӯ   в”Ӯ return  в”Ӯ\nв””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ   в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n     в”Ӯ\n     в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Under limit?        в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n    в”Ӯ             в”Ӯ\n   Yes            No\n    в”Ӯ             в”Ӯ\n    в–ј             в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ   в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Check   в”Ӯ   в”Ӯ Archive в”Ӯ\nв”Ӯ dedup   в”Ӯ   в”Ӯ lowest  в”Ӯ\nв”Ӯ         в”Ӯ   в”Ӯ priorityв”Ӯ\nв””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ   в””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ\n     в”Ӯ             в”Ӯ\n     в–ј             в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Duplicate?          в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n    в”Ӯ             в”Ӯ\n   Yes            No\n    в”Ӯ             в”Ӯ\n    в–ј             в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ   в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Merge   в”Ӯ   в”Ӯ Constructв”Ӯ\nв”Ӯ with    в”Ӯ   в”Ӯ feature в”Ӯ\nв”Ӯ existingв”Ӯ   в”Ӯ object  в”Ӯ\nв””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ   в””в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”ҳ\n     в”Ӯ             в”Ӯ\n     в””в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n            в”Ӯ\n            в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Write to cortex/    в”Ӯ\nв”Ӯ features/unread/    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Emit \"feature-      в”Ӯ\nв”Ӯ created\" event      в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ") (code-block :caption "" :lang "text" :source "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Sakura boot or      в”Ӯ\nв”Ӯ idle tick           в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Load unread         в”Ӯ\nв”Ӯ features from       в”Ӯ\nв”Ӯ cortex/features/    в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ Sort by quality     в”Ӯ\nв”Ӯ score (desc)        в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n           в”Ӯ\n           в–ј\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ