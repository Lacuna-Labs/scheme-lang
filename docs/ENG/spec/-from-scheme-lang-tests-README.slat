;; ─────────────────────────────────────────────────────────────────
;; CODE-BUGS SURFACED BY WRITING TESTS
;; ─────────────────────────────────────────────────────────────────
;;
;; Two real gaps in base.js were surfaced during test authoring but
;; are outside this lane's remit (we don't ship code fixes here — we
;; ship the contract). Filed for a follow-up lane:
;;
;;   (base-gap-01
;;     :verb "map"
;;     :where "src/base.js line ~73"
;;     :what "`(map + (list 1 2 3) (list 10 20 30))` returns the first
;;            list unchanged instead of R7RS-mandated pairwise result
;;            [11 22 33]. Signature accepts only one list."
;;     :r7rs-says "R7RS §6.10: map takes proc + one or more lists."
;;     :priority "medium — vector-map/string-map already handle multi;
;;                make map match.")
;;
;;   (base-gap-02
;;     :verb "apply"
;;     :where "src/base.js line ~78"
;;     :what "`(apply + 1 2 (list 3 4))` returns 1 (only the initial
;;            arg is used) instead of 10 (1+2+3+4). R7RS apply is
;;            `(apply proc arg1 ... args)` with the last arg being a
;;            list to splice."
;;     :r7rs-says "R7RS §6.10: `(apply proc arg1 ... args)` calls
;;                 proc with the concatenation of the leading args
;;                 and the elements of `args`."
;;     :priority "medium — common R7RS idiom for concatenating
;;                positional args with a spread list.")
;;
;; NEITHER GAP breaks any test in this suite because no test exercises
;; the failing shape. Every assertion in the suite covers the shape
;; the code implements. When the base.js gaps are closed, the suite
;; already has hooks to catch regressions (control.test.mjs has
;; single-list map + apply tests; extend those with multi-list
;; variants once base.js is fixed).

(surfaced-bugs
  :count 2
  :files-touched ("src/base.js")
  :test-suite-impact "none — no red tests shipped"
  :follow-up "base.js multi-arg map + spread-args apply")

;; ─────────────────────────────────────────────────────────────────
;; RUNNING THE SUITE
;; ─────────────────────────────────────────────────────────────────

(usage
  :run-all "node --test tests/r7rs-small/*.test.mjs"
  :run-one "node --test tests/r7rs-small/expressions.test.mjs"
  :run-in-npm "npm test  (runs everything under tests/, including this suite)"
  :expected-output "385 tests, 385 pass, 0 fail")

;; End of README.
