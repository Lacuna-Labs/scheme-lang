; ─── SECTION 2 — GAPS PER AUDIENCE ─────────────────────────────────────────
(section :id 2 :title "Audience gaps — what Motoi 1.0 gives / still misses")
(audience :id "kids" :section 2 :gives ("all of core + arts fantasy console + math kit + light drawing + REPL + one-liner install + tutorial") :missing ("game recipes book — sits in curator/scheme-books/book-of-games-preserved, not in motoi repo" "kid-friendly REPL theme with big fonts" "installer walkthrough for Chromebook") :placement ("recipes = external books repo" "theme = base" "installer = base"))
(audience :id "artists" :section 2 :gives ("fantasy console + music driver + framebuffer + PNG/WAV emit + web IDE") :missing ("6 fantasy-console verbs (btn btnp print spr sfx palt/pal/camera)" "brush + fill primitives beyond Bresenham" "GIF/APNG encode") :placement ("6 verbs = base P09" "brush = base P09" "GIF = base or optional npm"))
(audience :id "math-folks" :section 2 :gives ("~250 wired math verbs including linalg + calc + stat + combinatorics + geom + number-theory") :missing ("5 new verbs: RK4 FFT random-normal random-choice curve-fit" "symbolic algebra beyond trivial simplification") :placement ("5 verbs = base P11" "symbolic = external package, not base"))
(audience :id "cs-majors" :section 2 :gives ("R7RS-small core + macros + TCO + REPL + testing + light ML") :missing ("61 CS verbs across algorithms / DS / PL-theory / formal-methods / systems" "concurrency beyond promise combinators (actor model, CSP)") :placement ("61 verbs = base P08" "actors/CSP = fork/variant"))
(audience :id "scientists" :section 2 :gives ("basic math + stats") :missing ("60 science verbs across physics chem bio astro inferential-stats" "unit system beyond a bundled table" "no dataframe primitive") :placement ("60 verbs = base P07" "dataframe = base P06 under data-formats subkit"))
(audience :id "system-builders" :section 2 :gives ("nothing today — everything ships in Motoi 1.0 P06") :missing ("all 173 system verbs across 13 subkits") :placement ("173 verbs = base P06 (largest unlocked audience per Alfred priority)"))
(audience :id "poets" :section 2 :gives ("string ops via base") :missing ("44 text-poetry verbs across prosody Markov templates spelling") :placement ("all 44 = base P10"))
(audience :id "language-enthusiasts" :section 2 :gives ("R7RS-small core + reader + macros + reference + engineering decisions + fork protocol") :missing ("LSP for editors" "WASM bundle for browser REPL" "package manager for verb layers" "public npm publication") :placement ("LSP = post-1.0" "WASM = post-1.0" "package manager = post-1.0" "npm publish = post-1.0 or Alfred's call"))
(audience :id "ai-researchers" :section 2 :gives ("light ML in base + machine-readable reference + structured errors + verb metadata") :missing ("no first-class embedding vector type" "no built-in tokenizer" "no lightweight vector search") :placement ("all three = base extension P07-P08 OR variant with sidecar; Motoi keeps self-contained rule"))
(audience :id "llm-builders" :section 2 :gives ("reference SLAT is directly ingestible + structured error records + doc metadata + example tiers per verb") :missing ("no SLAT→JSON tool exposed via CLI" "no fine-tune-ready dataset export" "Motoi Copilot seam unimplemented") :placement ("SLAT→JSON export = base P05 or P12" "dataset export = base P13 doc site" "Copilot seam = base P12 stub, model deferred"))
; ─── SECTION 3 — OVERLAP ARCHITECTURE: MOTOI ↔ SAKURA DIALECT ─────────────
(section :id 3 :title "Overlap architecture — how Sakura Dialect embeds Motoi")
(question :id "Q3-overlap" :section 3 :verbatim "How the overlap would work in Curator. Curator just gonna smuggle it and say, I'll do what I want. Remember, we want one to one parity. Right? Or is it that when Curator is gonna flip the switches if it sees certain libraries because it knows? Remember we said variant?" :author "Alfred")
(option :id "3.A" :section 3 :name "Smuggle-with-1:1-parity" :one-liner "Curator embeds Motoi verbatim; Sakura Dialect adds/overrides on top of the same runtime process." :how "npm dep or git submodule of motoi-scheme; Sakura's runtime imports Motoi's makeBaseEnv() then layers additions/overrides via env.define() before user code runs; no runtime dialect switch, one env." :pros ("simplest to implement" "1:1 parity guaranteed by construction — Motoi is literally the base env" "cartridge portability is trivial: a bare-Motoi cart just calls verbs that already exist" "no per-file dialect declaration required" "backwards compat maintained by not-overriding-most-verbs") :cons ("no way for a program to opt out of Sakura's overrides while running inside Curator" "no way to run a strict-Motoi verification pass to check portability without launching a second runtime" "harder to detect accidental Sakura-only verb use in a cart marketed as portable" "harder to run two dialects side-by-side in one process (e.g. Curator + Lacuna in the same tooling)"))
(option :id "3.B" :section 3 :name "Runtime-variance-switch" :one-liner "Program declares dialect at the top (or runtime infers from imports); runtime picks per-verb impl at dispatch time." :how "reader recognizes #!dialect <name> shebang → binds a dialect record; each verb dispatch checks the dialect record before invoking impl; adapters file resolves overrides; missing dialect defaults to motoi." :pros ("explicit portability guarantees — a cart tagged #!dialect motoi cannot accidentally call Sakura verbs" "one runtime can host multiple dialects (Curator + Lacuna + third-party) without process split" "verification and linting have a hard signal to check against" "future dialects (forks) plug in without touching the runtime — declare in dialect.slat and go" "matches the R5RS/R7RS declaration precedent Alfred cited") :cons ("more machinery upfront: dispatch checks a dialect record on every call (fuel-cheap but nonzero)" "requires a well-defined dialect.slat format + registry lookup path" "authors must remember to add the declaration OR runtime must infer, which is fuzzy" "backwards compat with existing bare-Motoi programs requires a graceful default (motoi if unspecified)"))
(mechanism :id "3.B.decl" :section 3 :description "Program dialect declaration" :syntax "First non-blank line: #!dialect <name> — e.g. #!dialect sakura · #!dialect motoi · #!dialect lacuna · #!dialect <fork-name>" :fallback "If absent, runtime defaults to :motoi in Motoi CLI; defaults to the host runtime's dialect inside Curator/Lacuna (Sakura or Lacuna respectively)." :reader-impact "reader recognizes the token and emits a (_dialect :name <sym>) sentinel form; interp reads sentinel and installs dialect record before evaluating body")
(mechanism :id "3.B.autodetect" :section 3 :description "Library-import auto-detection (optional layer atop 3.B.decl)" :rule "If a file imports any verb whose namespace matches an installed dialect's :adds prefix set, runtime activates that dialect for the file — but only if no explicit #!dialect declaration is present." :example "importing card/* → activates sakura dialect; importing sys/* → activates lacuna dialect" :caveats ("ambiguity when two dialects claim overlapping prefixes → error, not silent pick" "must be opt-in per host runtime; Motoi CLI can refuse auto-detection to enforce strict mode"))
(mechanism :id "3.B.dialect-slat" :section 3 :description "dialect.slat file format (extended from memory)" :canonical-shape "(dialect :name <sym> :display <str> :version <semver-str> :pins-motoi <version-str> :backwards-compat <full|partial|none> :runtime <app-name-or-cli> :adds (<prefix-list>) :refuses (<verb-list>) :modifies ((<verb> :reason <str>) ...) :adopts <all-or-list> :adapter-file <path> :reference-file <path> :parent <parent-dialect-or-nil> :owner <str> :license <str>)" :sakura-example "(dialect :name sakura :display \"Sakura Scheme\" :version \"1.0.0\" :pins-motoi \"1.0\" :backwards-compat full :runtime curator :adds (\"card/*\" \"shop/*\" \"shoppe/*\" \"radio/*\" \"cine/*\" \"flower/*\" \"afford/*\" \"ai/*\" \"cortex/*\") :refuses () :modifies ((tone :reason \"web-audio integration\") (note :reason \"polyphonic sampling\")) :adopts all :adapter-file \"adapters.slat\" :reference-file \"reference.slat\" :parent motoi :owner \"Lacuna Labs\" :license \"BUSL 1.1 → Apache 2.0 on 2030-07-13\")")
(mechanism :id "3.B.compat-fwd" :section 3 :description "Backwards compat: pure-Motoi program in Sakura runtime" :rule "Sakura runtime loads with :adopts all + :refuses (). Any Motoi verb call resolves to Motoi's impl unless :modifies overrides. Result: unchanged behavior for a bare-Motoi program running inside Curator.")
(mechanism :id "3.B.compat-rev" :section 3 :description "Reverse case: Sakura program in bare Motoi runtime" :rule "Runtime encounters unknown verb (e.g. card/open). Structured error record fires: (error :kind 'unknown-verb :symbol card/open :dialect-hint sakura :did-you-mean () :fix \"Add #!dialect sakura at top of file and run in Curator, or replace card/open with the closest motoi equivalent per adapters.slat.\" :examples (\"...\") :source-pos ...). No crash. LLM can consume the record and repair.")
(mechanism :id "3.B.fork-tree" :section 3 :description "Fork tree cascade — how a fork of Sakura declares itself" :approach "dialect.slat sets :parent to the immediate ancestor (motoi | sakura | lacuna | fork-name). Runtime walks the parent chain at load: motoi → sakura → your-fork. Overrides compose by nearest-wins; :refuses at any level unbinds; :modifies at your level supersedes ancestor's :modifies. Cycles are a load-time error.")
(recommendation :id "3.rec" :section 3 :pick "3.B — Runtime-variance-switch" :reasoning ("Alfred's fork-tree ambition needs a first-class dialect record — 3.A cannot express it" "Cartridge portability requires a hard portability signal (a strict-motoi verification pass); 3.B provides that; 3.A cannot" "The R5RS/R7RS precedent Alfred invoked in the doctrine is exactly 3.B" "3.A can be layered UNDER 3.B as an implementation shortcut for the common case where a program is unambiguous" "Cost is small: one hash-table lookup per dispatch") :hybrid-note "Implement 3.B as the spec; ship 3.A's fast path as a compiled shortcut when the dialect record is fully resolved at load time." :confidence "high")
; ─── SECTION 4 — FORK-TREE AS FIRST-CLASS FEATURE ──────────────────────────
(section :id 4 :title "Fork-tree graph as first-class language feature")
(spec :id "4.protocol-prologue" :section 4 :name "Fork protocol prologue chapter" :required-by "Reference manual — decision follows from doctrine" :location "docs/MOTOI-SCHEME-REFERENCE.slat prologue" :contents ("What a dialect is" "The four operations: adopt refuse modify add" "How to write dialect.slat" "How to write adapters.slat" "Backwards-compat stances (full/partial/none)" "How to publish a dialect (registry entry + repo link)" "How the runtime resolves dialects at load time" "Common pitfalls: cycles, prefix collisions, ambiguous auto-detect") :phase "P02")
(spec :id "4.dialect-slat" :section 4 :name "dialect.slat format" :template-record "See mechanism 3.B.dialect-slat" :required-fields ("name" "display" "version" "pins-motoi" "backwards-compat" "runtime" "parent") :optional-fields ("adds" "refuses" "modifies" "adopts" "adapter-file" "reference-file" "owner" "license") :phase "P04")
(spec :id "4.registry" :section 4 :name "Dialect registry" :location-options ("project-local: .motoi/dialects.slat" "global: ~/.motoi/dialects.slat" "network: motoi-dialects.lacunalabs.ai/registry.slat (post-1.0)") :entry-shape "(registry-entry :name <sym> :repo <url> :version <semver> :installed-at <path> :verified <bool> :hash <sha256>)" :phase "P04")
(spec :id "4.cascade" :section 4 :name "Adapter cascade down the tree" :rule "Load order: parent-first, self-last. Overrides win from self toward root. :refuses at any level is terminal (verb unbound below). Composition preserves determinism: no cross-branch merge; each fork is a chain, not a lattice." :phase "P04-P05")
(spec :id "4.validation" :section 4 :name "dialect.slat validation" :rules ("required fields present" "semver strings parseable" ":parent resolves to an installed dialect OR is 'motoi'" "no cycles in :parent chain" ":adds prefixes do not collide with parent's :adds (warn, not fail)" ":refuses references verbs that exist in an ancestor" ":modifies references verbs that exist in an ancestor and preserves the signature" ":adapter-file and :reference-file exist and load") :fail-mode "load-time error; runtime refuses to start with a malformed dialect" :phase "P04")
(spec :id "4.fork-example" :section 4 :name "Example: a third-party fork of Sakura" :scenario "Someone forks Sakura to add flower/*-emerald variants that talk to a private breeder DB" :dialect-slat-shape "(dialect :name emerald-sakura :display \"Emerald Sakura\" :version \"0.1.0\" :pins-motoi \"1.0\" :backwards-compat partial :runtime curator :parent sakura :adds (\"flower/emerald/*\") :refuses () :modifies ((flower/pick :reason \"require emerald-provenance token\")) :adopts all :adapter-file \"emerald-adapters.slat\")" :portability "cart written for emerald-sakura will NOT run in bare sakura or bare motoi; runtime errors clean")
; ─── SECTION 5 — LLM-FRIENDLY + HUMAN-FRIENDLY TOOLS ───────────────────────
(section :id 5 :title "LLM-friendly + human-friendly tools built-in")
(tool :id "5.metadata" :section 5 :name "Per-verb metadata" :fields ("doc" "contract" "examples (novice/intermediate/expert/advanced/master)" "tier" "perm" "atom" "namespace" "since" "variant" "arity" "source") :source "rippling-discovering-lobster.md verb metadata contract + reference SLAT records" :status "exists in reference; needs surfacing via CLI and REPL")
(tool :id "5.help-verb" :section 5 :name "(help 'verb)" :returns "hash-table with metadata fields" :callers ("Sakura persona runtime" "Motoi Copilot" "REPL ,help" "LLM tool calls") :phase "P12")
(tool :id "5.repl-meta" :section 5 :name "REPL meta-commands" :commands (",help" ",type" ",arity" ",doc" ",examples" ",source" ",namespace" ",apropos" ",expand" ",expand-1" ",trace" ",untrace" ",watch" ",inspect" ",time" ",save" ",load" ",undo" ",ask") :source "rippling-discovering-lobster.md super-REPL section" :phase "P12")
(tool :id "5.error-records" :section 5 :name "Structured error records" :shape "(error :kind <sym> :message <str> :source-pos <(line col)> :did-you-mean (<sym>...) :fix <str-or-form> :examples (<code-str>...))" :consumers ("Motoi Copilot" "Sakura persona" "IDE diagnostics" "CLI report") :phase "P02 minimal, expanded through P05")
(tool :id "5.slat-json-export" :section 5 :name "Reference SLAT → JSON export for LLM tool wiring" :cli-command "motoi docs export --format json --out reference.json" :consumers ("LLM training pipelines" "external tool authors" "IDE plugins") :phase "P05")
(tool :id "5.sakura-verbs" :section 5 :name "AI-collaboration verbs (sakura/ namespace)" :verbs ("sakura/complete" "sakura/rewrite" "sakura/explain" "sakura/fix") :placement "Sakura Dialect (not Motoi base) — depends on sidecar/model" :phase "post-1.0 for Sakura Dialect; Motoi wires seam only")
(tool :id "5.copilot-seam" :section 5 :name "Motoi Copilot CLI seam" :cli-command "motoi copilot" :phase "P12 stub only")
; ─── SECTION 6 — MOTOI COPILOT PLACEHOLDER ────────────────────────────────
(section :id 6 :title "Motoi Copilot — deferred savant helper")
(spec :id "6.mission" :section 6 :name "Mission" :description "A small LLM trained on exactly one thing: Motoi Scheme. Peer-programs at the CLI. Reads code buffer, suggests next line. Does not chat. Does not advocate. Does not represent user interest. Savant on the language." :source "Alfred verbatim in project_motoi_scheme_naming_and_dialects_2026_07_14")
(spec :id "6.cli-shape" :section 6 :name "CLI shape" :subcommand "motoi copilot [--file <path>] [--pos <line:col>] [--max-tokens <n>]" :io "reads current buffer state on stdin OR from --file; emits JSON completion suggestion on stdout with :suggestion :confidence :alternatives" :phase "P12 stub")
(spec :id "6.model" :section 6 :name "Model target" :size-params "1B-4B" :backend-options ("local llama.cpp binding embedded in Motoi CLI" "external sidecar over Unix socket" "HTTP endpoint to cloud service") :recommendation "local llama.cpp — matches savant-and-portable ethos; sidecar is fallback for large models; HTTP is out-of-spirit" :decision-owner "Alfred (see Section 10 Q5)" :phase "post-1.0")
(spec :id "6.training-data" :section 6 :name "Training corpus" :sources ("~/code/scheme-lang/docs/SAKURA-SCHEME-REFERENCE.slat (renamed to MOTOI)" "~/code/curator/scheme-books/ (1,339 chapters, 31 books)" "example carts from carts/") :note "Corpus is triple-purpose per publishable-prose doctrine: LLM training + kid reading + AI-builder reference" :phase "post-1.0")
(spec :id "6.stub-behavior" :section 6 :name "P12 stub behavior" :implementation "motoi copilot subcommand exists; on invocation prints JSON: {\"status\":\"unimplemented\",\"message\":\"Motoi Copilot is not yet trained. The CLI seam is reserved for the post-1.0 release.\",\"docs\":\"...\"}" :exit-code 2)
; ─── SECTION 7 — BOOKS = TRAINING MATERIAL ────────────────────────────────
(section :id 7 :title "Books as human tutorial AND LLM training corpus")
(spec :id "7.book-repo" :section 7 :name "Scheme-books cross-reference" :location "~/code/curator/scheme-books/" :chapter-count-est 1339 :book-count 31 :sample-books ("book-of-animation" "book-of-challenges" "book-of-cs-curriculum" "book-of-don-ts" "book-of-flower-stories" "book-of-hellosurface" "book-of-instruments" "book-of-items-and-scenarios" "book-of-jesse" "book-of-listening" "book-of-llm-philosophy" "book-of-marionette" "book-of-math" "book-of-money" "book-of-motion") :source "ls ~/code/curator/scheme-books")
(spec :id "7.dual-purpose" :section 7 :name "Publishable-prose doctrine applied" :rule "Every book is both: (a) SFT training pairs for Sakura and Motoi Copilot, (b) real publishable prose kids read to learn Motoi. Reader-first, LLM benefits second (LIMA hypothesis)." :source "project publishable-prose-doctrine memory")
(spec :id "7.rename-question" :section 7 :name "Book rename policy" :question "Books currently reference 'Sakura Scheme'. Should book text update to 'Motoi Scheme', or should Sakura stay as historical alias?" :options ("Full rename in book text" "Keep 'Sakura Scheme' as alias/historical name in books; new books use Motoi" "Selective: philosophy/persona books keep Sakura naming; technical/reference books use Motoi") :recommendation "Selective — persona-books (Book of Don-ts, Flower Stories, Marionette, Reason-Code) keep 'Sakura' because Sakura is the character; technical books (Math, CS-Curriculum, Motion, Extensions) rename to Motoi." :decision-owner "Alfred" :flagged-in "Section 10")
; ─── SECTION 8 — BACKWARDS ORIGIN (PRIVATE NOTE) ──────────────────────────
(section :id 8 :title "Backwards origin — private note")
(private-note :id "8.origin" :section 8 :verbatim "Technically we're doing it backwards. Sakura is the descendant. In reality, Matoy came out of Sakura, and that's why it has to keep ancestor privilege in a sense." :author "Alfred" :actual-history "Motoi was extracted FROM Sakura's runtime codebase (curator-web/src/scheme/) in 2026-07 as the base + variant split matured." :public-story "Motoi is the foundational language; Sakura descends from it as a dialect." :why "Motoi keeps ancestor privilege in all versioning and doc positioning — Sakura's backwards-compat is TO Motoi, not FROM. The reference manual is Motoi's; Sakura's dialect.slat pins it." :handling-rule "Do not surface the actual history publicly. In internal docs (this file, memory, engineering notes) it is preserved. In marketing, README, book text, reference prologue: Motoi came first.")
; ─── SECTION 9 — BURNDOWN PHASES ──────────────────────────────────────────
(section :id 9 :title "Burndown phases — dependency-ordered")
(phase :id "P01" :section 9 :name "Repo restructure + rename sweep" :goal "Move scheme-lang → lacuna-labs/motoi-scheme; rename Sakura Scheme → Motoi Scheme across code, docs, memory, reference, verb entries; keep provenance." :deliverables ("~/code/lacuna-labs/motoi-scheme/ populated" "MOTOI-SCHEME-REFERENCE.slat renamed and header updated" "ENGINEERING-DECISIONS.slat and CONVENTION.slat moved" "cross-repo grep for 'Sakura Scheme' returns only intentional persona uses" "provenance record on every renamed file per merge-not-throw doctrine") :depends-on () :gate "grep audit passes; all tests pass in new location; verbs still resolve" :loc-estimate "N/A (rename only)" :hours-estimate 6 :owner "Motoi Rename Lane" :priority "high" :status "awaits Alfred's explicit go")
(phase :id "P02" :section 9 :name "Fork-protocol prologue in reference" :goal "Author the fork-protocol chapter that opens the reference manual." :deliverables ("prologue chapter added to MOTOI-SCHEME-REFERENCE.slat covering all items in spec 4.protocol-prologue" "structured-error record shape frozen" "reader recognition of #!dialect declaration specified") :depends-on ("P01") :gate "Alfred reads and approves the prologue draft" :loc-estimate "N/A (docs)" :hours-estimate 5 :owner "Motoi Reference Lane" :priority "high")
(phase :id "P03" :section 9 :name "Variant-switch runtime mechanism" :goal "Implement #!dialect declaration parsing + dispatch-time dialect resolution + default-to-motoi fallback." :deliverables ("reader emits _dialect sentinel" "interp installs dialect record" "dispatch checks dialect record and picks impl" "structured error on unknown verb with :dialect-hint" "unit tests: bare motoi program in sakura runtime works; sakura program in bare motoi runtime errors cleanly") :depends-on ("P01" "P02") :gate "unit tests green; benchmark shows dispatch overhead under 5%" :loc-estimate "600-1000" :hours-estimate 14 :owner "Runtime Lane" :priority "high")
(phase :id "P04" :section 9 :name "dialect.slat format + Sakura's dialect.slat" :goal "Freeze dialect.slat schema; author Sakura's dialect.slat inside Curator; author Motoi's implicit-self dialect record." :deliverables ("dialect.slat parser + validator" "Sakura's dialect.slat committed in Curator" "Lacuna's placeholder dialect.slat committed in lacuna app repo" "registry mechanism (.motoi/dialects.slat) + loader" "fork-tree parent-chain resolver + cycle detector") :depends-on ("P02" "P03") :gate "parse-and-validate all three dialect files; cycle detection unit-tests pass" :loc-estimate "400-700" :hours-estimate 10 :owner "Runtime Lane + Curator lane" :priority "high")
(phase :id "P05" :section 9 :name "Adapter engine" :goal "Ship engine/adapters/*.slat format + adapter loader + Sakura↔Motoi first adapter file." :deliverables ("adapter.slat schema" "adapter loader in runtime" "first adapter file mapping Sakura's :modifies verbs to Motoi equivalents" "validator/rewriter that can rewrite Sakura source to Motoi source per rules" "SLAT → JSON reference exporter for LLM wiring") :depends-on ("P04") :gate "adapter round-trip test on a sample cart; JSON export loads in an LLM tool call" :loc-estimate "500-800" :hours-estimate 12 :owner "Adapter Engine Lane" :priority "high")
(phase :id "P06" :section 9 :name "System-builder kit" :goal "Ship all 13 subkits: net data-formats fs crypto compression time sqlite logging cli regex testing process cron." :deliverables ("173 new verbs implemented and reference-entered" "9 permissive npm deps audited and added" "npm-audit passes" "tests + tiered examples per verb") :depends-on ("P01" "P04" "P05") :gate "audit script confirms every verb has doc + examples + contract; system-builder audience hello-worlds run" :loc-estimate "13400-22200" :hours-estimate 60 :owner "System-Builder Kit Lane" :priority "high")
(phase :id "P07" :section 9 :name "Science kit" :goal "Ship 60 science verbs across physics chem bio astro inferential-stats." :deliverables ("60 verbs implemented + reference entries" "unit tables + element tables + codon tables + VSOP87 data bundled" "physics/chem/bio/astro/stats hello-worlds pass") :depends-on ("P01" "P02" "P11 partial") :gate "every science hello-world in the base-research doc runs" :loc-estimate "5600-9500" :hours-estimate 34 :owner "Science Kit Lane" :priority "high")
(phase :id "P08" :section 9 :name "CS kit" :goal "Ship 61 CS verbs across algorithms DS PL-theory formal-methods systems." :deliverables ("61 verbs" "mini-scheme + HM types + parser combinators + CEK" "property-testing framework + shrinker") :depends-on ("P01" "P02") :gate "CS hello-worlds run; property-tests catch a seeded regression" :loc-estimate "10500-17500" :hours-estimate 46 :owner "CS Kit Lane" :priority "high")
(phase :id "P09" :section 9 :name "Arts kit gaps + audio + framebuffer" :goal "Fill 6 fantasy-console verbs (btn btnp print spr sfx palt/pal/camera); ship music driver + framebuffer runtime + light ML." :deliverables ("6 fantasy-console verbs" "16-voice mixer + WAV writer + note table" "framebuffer modes/palette/sprite atlas/terminal + web renderers" "light ML primitives: 32-dim hash embed + tf-idf + string-search") :depends-on ("P01") :gate "kid can run breakout.scm from carts/ with sound and sprites" :loc-estimate "4500-7900" :hours-estimate 26 :owner "Arts Kit Lane" :priority "medium")
(phase :id "P10" :section 9 :name "Text/poetry kit" :goal "Ship 44 text-poetry verbs (string-ops + prosody + Markov + templates + spelling)." :deliverables ("44 verbs + reference" "syllable counter without dict" "meter classifier" "Markov generator" "template engine") :depends-on ("P01") :gate "poetry hello-worlds run; haiku classifier passes fixtures" :loc-estimate "2600-4400" :hours-estimate 18 :owner "Text Kit Lane" :priority "medium")
(phase :id "P11" :section 9 :name "Math wire-ups + 5 new" :goal "Wire 250 existing math descriptor entries to real impls; add RK4 FFT random-normal random-choice curve-fit." :deliverables ("250 wire-ups pass tiered examples" "5 new verbs with tests" "Levenberg-Marquardt curve fit works on a seeded dataset") :depends-on ("P01") :gate "math hello-worlds from research doc run; no descriptor-lies remain in math namespace" :loc-estimate "3000-5000" :hours-estimate 24 :owner "Math Wire-Up Lane" :priority "medium")
(phase :id "P12" :section 9 :name "CLI + REPL + IDE + Copilot seam" :goal "Ship motoi CLI with repl/eval/run/help/docs/version/slat subcommands; super-REPL with meta-commands; terminal IDE + web IDE stubs; copilot stub." :deliverables ("bin/motoi shebang + all subcommands" "super-REPL with tab-complete + inline signature help + ,help + ,ask stub + rich display" "6 themes" "terminal IDE (paredit-flavored)" "web IDE stub" "motoi copilot returns stub JSON per spec 6.stub-behavior") :depends-on ("P01" "P05" "P06") :gate "one-line hello prints; help card/open renders; REPL meta-commands work; copilot stub returns valid JSON" :loc-estimate "3000-5000" :hours-estimate 28 :owner "Tooling Lane" :priority "high")
(phase :id "P13" :section 9 :name "Doc site machinery" :goal "VitePress-flavored doc site built from reference SLAT + book chapters; auto-regen triggers." :deliverables ("docs.motoi-scheme site scaffolding" "SLAT → MD emitter with tiered examples" "triggers per rippling-discovering-lobster.md" "book chapter cross-links" "fine-tune dataset export from reference") :depends-on ("P05" "P12") :gate "docs regen adds a verb page end-to-end; book chapter renders; dataset JSON export loads in a training script" :loc-estimate "1500-2500" :hours-estimate 20 :owner "Doc Site Lane" :priority "medium")
(phase :id "P14" :section 9 :name "Install one-liners" :goal "brew tap + curl-sh installer + npm i -g flow." :deliverables ("homebrew formula in a lacuna-labs tap" "install.sh at motoi-scheme.lacunalabs.ai" "npm package (private or public per Alfred)" "motoi --version + motoi --tour verified fresh") :depends-on ("P12") :gate "fresh macOS box installs and runs motoi repl in under 60 seconds; fresh Linux VM same" :loc-estimate "300-500" :hours-estimate 8 :owner "Release Lane" :priority "medium")
(phase :id "P15" :section 9 :name "Release engineering" :goal "Version tag 1.0.0; CHANGELOG; CONSUMERS.md; CONTRIBUTING; CODE_OF_CONDUCT; LICENSE decision; git triggers." :deliverables ("1.0.0 tag" "CHANGELOG with keep-a-changelog format" "CONSUMERS.md listing curator + lacuna" "CONTRIBUTING with PR-not-cowboy policy" "CODE_OF_CONDUCT (Contributor Covenant)" "LICENSE per Alfred's call (MIT recommended)" "GitHub Actions per repo") :depends-on ("P14" "P13") :gate "release candidate builds green; three internal consumers pin and pass tests" :loc-estimate "N/A (release ops)" :hours-estimate 12 :owner "Release Lane" :priority "high")
(phase :id "P16" :section 9 :name "Sakura Dialect authoring inside Curator" :goal "Author Sakura Dialect verb layer (card/* shop/* radio/* cine/* flower/* afford/* ai/* cortex/*) with dialect.slat + adapters.slat, pinning Motoi 1.0." :deliverables ("sakura-scheme/ dir inside Curator with all Sakura-specific verbs migrated from current runtime" "dialect.slat + adapters.slat + reference.slat authored" "all Curator carts run unchanged under new dialect resolver" "zero-touch test: bare-Motoi cart runs in Curator") :depends-on ("P04" "P05" "P15") :gate "Curator's 10,762 carts all pass; a bare-Motoi cart runs unmodified" :loc-estimate "moves ~50k LOC (no new logic)" :hours-estimate 30 :owner "Curator Lane" :priority "high")
(phase :id "P17" :section 9 :name "Lacuna Dialect authoring inside Lacuna app" :goal "Author Lacuna Dialect verb layer (sys/* net/* docker/* deploy/*) with dialect.slat pinning Motoi 1.0; no backwards-compat requirement." :deliverables ("lacuna-scheme/ dir inside Lacuna app" "8-16 starter verbs" "dialect.slat with :backwards-compat none") :depends-on ("P04" "P05" "P15") :gate "SRE hello-worlds (ping URL + read env + docker ps + probe) run" :loc-estimate "1500-3000" :hours-estimate 16 :owner "Lacuna App Lane" :priority "medium")
(phase :id "P18" :section 9 :name "Verification + seal tests" :goal "Prove hermetic seal + backwards-compat + zero-touch." :deliverables ("rm -rf ~/code/lacuna → Curator builds and tests pass" "reverse test also passes" "bare-Motoi cart runs identically in Motoi CLI and Curator" "structured-error round-trip for Sakura-verb-in-Motoi" "adapter round-trip for a sample Sakura program → Motoi") :depends-on ("P16" "P17") :gate "all four verification tests pass in CI" :loc-estimate "500-800 test code" :hours-estimate 10 :owner "Verification Lane" :priority "high")
(phase :id "P19" :section 9 :name "Motoi Copilot training (deferred)" :goal "Train 1-4B param model on Motoi reference + scheme-books corpus; wire local llama.cpp binding into motoi copilot subcommand." :deliverables ("training script" "trained model artifact" "llama.cpp binding" "copilot subcommand returns real completions") :depends-on ("P15" "P16") :gate "copilot suggests a working next-line for a novice-tier reference example 80% of the time" :loc-estimate "3000-5000 + training infra" :hours-estimate 80 :owner "Copilot Lane (post-1.0)" :priority "low")
(phase :id "P20" :section 9 :name "Post-1.0 growth" :goal "LSP for editors + WASM bundle for browser REPL + package manager for verb layers + public npm publication." :deliverables ("motoi lsp subcommand + VS Code + Cursor plugins" "WASM bundle deployable in a static site" "motoi install <fork/dialect> from a registry" "npm publish sakura-scheme AND motoi-scheme packages if Alfred approves") :depends-on ("P15") :gate "one external contributor writes a fork and publishes it to the registry" :loc-estimate "8000-15000" :hours-estimate 100 :owner "Growth Lane (post-1.0)" :priority "low")
(rollup :id "9.totals" :section 9 :phase-count 20 :phase-count-in-1.0-scope 18 :hours-1.0-scope 397 :hours-post-1.0 180 :hours-total 577 :note "1.0 scope = P01–P18. Post-1.0 = P19 Copilot + P20 growth. Hours are Lacuna-Eng-agent-hours, not Alfred-hours. Team-parallelizable across 4-6 lanes if dispatched.")
(build-order-recommendation :id "9.order" :section 9 :sequence ("P01 → P02 → P03 → P04 → P05 (all serial, foundation)" "P06 P07 P08 P09 P10 P11 (parallelizable across 6 kit lanes)" "P12 P13 (parallelizable with kits after P05)" "P14 P15 (serial, gates release)" "P16 P17 (parallelizable with each other; blocked on P15)" "P18 (serial, verifies seal)" "P19 P20 (post-1.0)") :rationale "P01-P05 are the trunk everything hangs from. Kits (P06-P11) can fan out in parallel once dialect+adapter machinery lands. System-builder (P06) picked FIRST-among-kits per Alfred's memory doctrine because it unlocks the biggest audience.")
; ─── SECTION 10 — OPEN QUESTIONS ──────────────────────────────────────────
(section :id 10 :title "Open questions — need Alfred to decide before or during burndown")
(open-q :id "Q1" :section 10 :question "Monorepo vs three-repo split for Motoi + Sakura Dialect + Lacuna Dialect?" :context "Memory doctrine locates each dialect inside its host app (Sakura in Curator, Lacuna in Lacuna app). But Motoi itself could live at ~/code/lacuna-labs/motoi-scheme/ standalone or under a monorepo." :options ("Three repos: motoi-scheme + curator (owns sakura-scheme dir) + lacuna (owns lacuna-scheme dir)" "Monorepo lacuna-labs with motoi-scheme + variants/ subdir + apps subscribe by path" "Motoi standalone + variants live inside their host apps (current memory doctrine)") :recommendation "Option 3 — matches memory doctrine and Alfred's runtime-bound-dialect stance" :who-decides "Alfred" :blocks-phase "P01" :confidence "medium")
(open-q :id "Q2" :section 10 :question "CLI binary name: motoi vs motoi-scheme?" :context "Short name is friendlier; package name likely stays motoi-scheme." :options ("motoi (short binary + package motoi-scheme)" "motoi-scheme (verbose but explicit)") :recommendation "motoi (short) — matches convention of node/deno/bun; package name = motoi-scheme" :who-decides "Alfred" :blocks-phase "P12 and P14" :confidence "high")
(open-q :id "Q3" :section 10 :question "Book text rename: full / partial / historical-alias?" :context "31 books, 1,339 chapters reference Sakura Scheme. Persona books (Don-ts, Flower Stories, Marionette, Reason-Code) are about the character; technical books (Math, CS-Curriculum, Motion, Extensions) are about the language." :options ("Full rename to Motoi across all books" "Keep Sakura as historical alias in books; new books use Motoi" "Selective: persona books keep Sakura naming; technical books rename to Motoi") :recommendation "Option 3 (selective)" :who-decides "Alfred" :blocks-phase "P01 and P13" :confidence "medium")
(open-q :id "Q4" :section 10 :question "Where does Sakura Dialect physically live?" :context "Options: inside Curator repo as curator/sakura-scheme/, or as its own repo sakura-scheme-dialect/, or under lacuna-labs/dialects/sakura/." :options ("Inside Curator (memory doctrine)" "Own repo sakura-scheme-dialect pinning motoi-scheme@1.0" "Under lacuna-labs/dialects/sakura/") :recommendation "Inside Curator (memory doctrine + runtime-bound-dialect stance)" :who-decides "Alfred" :blocks-phase "P16" :confidence "high")
(open-q :id "Q5" :section 10 :question "Motoi Copilot model backend: local llama.cpp / sidecar / HTTP cloud?" :context "Copilot must be a savant on Motoi and nothing else; portability matters for the kid-with-a-Chromebook story." :options ("Local llama.cpp binding embedded in Motoi CLI (portable, offline)" "Sidecar over Unix socket (Python holds model)" "HTTP to cloud endpoint (fastest to ship, requires connectivity)") :recommendation "Local llama.cpp — matches savant + portable + offline ethos" :who-decides "Alfred" :blocks-phase "P19" :confidence "medium")
(open-q :id "Q6" :section 10 :question "Verb-count reconciliation for system-builder kit: 145 (memory) vs 173 (research itemization)?" :context "Memory doctrine says 145 new verbs; the itemized subkits in the research doc sum to 173. Discrepancy of 28 verbs. Neither source is obviously wrong — memory may be rounded or may exclude time wire-ups (7) and process wire-ups (5) and some deprecations." :options ("Take 173 as authoritative (itemized > rounded)" "Take 145 and prune 28 verbs from the itemization" "Reconcile: use 173 as target, treat gap as scope headroom") :recommendation "Option 3 — reconcile toward 173 and reduce during implementation if verbs turn out redundant" :who-decides "Alfred" :blocks-phase "P06" :confidence "medium")
(open-q :id "Q7" :section 10 :question "Library-import auto-detection: default-on or default-off?" :context "Mechanism 3.B.autodetect activates a dialect when a program imports its namespaces, unless #!dialect is explicit. This makes casual use pleasant but breaks portability guarantees for programs that meant to be strict-Motoi." :options ("Default-on in host runtimes (Curator/Lacuna); default-off in Motoi CLI (strict)" "Default-off everywhere; explicit declaration required" "Default-on everywhere") :recommendation "Option 1 — host runtimes are pleasant, CLI is strict" :who-decides "Alfred" :blocks-phase "P03 and P04" :confidence "medium")
(open-q :id "Q8" :section 10 :question "License for Motoi?" :context "Memory doctrine notes Sakura Dialect uses BUSL 1.1 → Apache 2.0 on 2030-07-13. Motoi as foundational open-source might want a different, simpler license." :options ("MIT (community-friendliest)" "Apache 2.0 (patent grant included)" "BUSL 1.1 like Sakura (aligned but restrictive for foundational)" "Dual MIT+Apache") :recommendation "MIT for maximum kid-and-fork-friendliness" :who-decides "Alfred" :blocks-phase "P15" :confidence "medium")
(open-q :id "Q9" :section 10 :question "Sakura's :modifies list — is polyphonic tone/note actually needed at Motoi 1.0?" :context "Memory doctrine's sample dialect.slat lists tone and note as :modifies for web-audio + polyphonic sampling. Motoi ships shell-out audio; Sakura might override for web-audio inside Curator. But does Motoi 1.0 need to allow polyphonic tone? If not, Sakura's override is a real value-add." :options ("Motoi ships mono shell-out only; Sakura polyphonic web-audio is an override" "Motoi ships polyphonic in shell-out + web-audio detection; Sakura barely overrides" "Motoi ships web-audio detection; polyphonic is a variant capability") :recommendation "Option 1 — Motoi stays minimal (mono shell-out); Sakura's override is a real dialect feature" :who-decides "Alfred" :blocks-phase "P09 and P16" :confidence "medium")
(open-q :id "Q10" :section 10 :question "Contradictory verb count: reference header says 1,157/1,160 but memory notes 1,157/70?" :context "Reference SLAT header line 3 says '1,160 verbs + 128 core language forms'; reference form on line 15 says :verb-count 1160 :core-form-count 120; memory note says 1,157 verbs + 70 core forms. Numbers don't agree across sources." :options ("Audit the reference and pick authoritative numbers" "Use reference header (1,160/128)" "Use memory (1,157/70)") :recommendation "Option 1 — audit before P01 rename; carry authoritative numbers into new manual" :who-decides "Alfred with Motoi Reference Lane doing the audit" :blocks-phase "P01" :confidence "high" :severity "concerning-discovery")
(open-q :id "Q11" :section 10 :question "npm publication: private, private-scoped, or public?" :context "Real-language positioning per rippling-discovering-lobster.md wants npm i -g motoi-scheme as a first-class install path." :options ("Public npm (community-friendly)" "Private-scoped @lacuna-labs/motoi-scheme (controlled)" "Private, install via git tag only") :recommendation "Public npm at 1.0 release" :who-decides "Alfred" :blocks-phase "P14 and P15" :confidence "medium")
(open-q :id "Q12" :section 10 :question "Where does the dialect registry live: project-local, global, or network?" :context "Spec 4.registry lists three options; pick one for 1.0." :options ("Project-local .motoi/dialects.slat only" "Global ~/.motoi/dialects.slat only" "Both, project-first fallback global" "Add network registry post-1.0") :recommendation "Both project-first + global fallback for 1.0; add network registry P20" :who-decides "Alfred" :blocks-phase "P04" :confidence "medium")
(open-q :id "Q13" :section 10 :question "Sakura's dialect.slat :adopts field — 'all' or explicit list?" :context "Sample memory template uses :adopts as implicit-all (via absence). Sakura is full-backwards-compat so :adopts all is right, but explicit list is auditable." :options (":adopts all (implicit full)" ":adopts (explicit verb list — 1,157 entries)" ":adopts all :except (<refuses list>)") :recommendation "Option 3 (:adopts all :except) — expresses intent + auditable" :who-decides "Alfred with Curator Lane" :blocks-phase "P04 and P16" :confidence "medium")
(open-q :id "Q14" :section 10 :question "Cortex bindings placement: adapter shim in Sakura Dialect vs base?" :context "Cortex is external. Base rules forbid external services. Sakura Dialect can have cortex/* verbs that talk to the Cortex daemon over a socket. But Motoi CLI + shell-out could ALSO reach Cortex if it's installed. Which world owns the surface?" :options ("Cortex is Sakura-Dialect-only; Motoi CLI cannot reach Cortex" "Motoi CLI has an optional cortex/* subkit if cortex daemon is installed; Sakura provides richer shim" "Cortex is a peer dialect (cortex-scheme)") :recommendation "Option 1 — matches memory doctrine, Cortex-is-external rule, and hermetic-Motoi rule" :who-decides "Alfred" :blocks-phase "P05 and P16" :confidence "high")
(open-q :id "Q15" :section 10 :question "Rename sweep — merge-not-throw obligations for old 'Sakura Scheme' string occurrences in code?" :context "Merge-not-throw doctrine says never delete content. A rename sweep changing 'Sakura Scheme' → 'Motoi Scheme' technically deletes the old string in code comments and doc headers." :options ("Rename in place + record provenance in a top-level ARCHIVE.slat noting the pre-rename state" "Rename in place + git history is the archive" "Preserve old strings as second-line aliases: 'Motoi Scheme (originally Sakura Scheme)'") :recommendation "Option 1 for docs (explicit ARCHIVE.slat) + Option 2 for code (git history is archive)" :who-decides "Alfred" :blocks-phase "P01" :confidence "medium")
; ─── SECTION 11 (bonus) — CONCERNING DISCOVERIES ──────────────────────────
(section :id 11 :title "Concerning discoveries surfaced during this pass")
(finding :id "F1" :section 11 :severity "medium" :description "Reference SLAT has inconsistent verb counts in its own headers (line 3 says 1,160/128; line 15 says 1,160/120; memory note says 1,157/70). Needs an audit before P01 rename." :source "docs/SAKURA-SCHEME-REFERENCE.slat lines 3, 15 vs memory")
(finding :id "F2" :section 11 :severity "medium" :description "System-builder kit verb count differs between memory doctrine (145) and itemized research (173). ~28-verb gap unexplained." :source "project_motoi_scheme_naming_and_dialects vs sakura-scheme-base-research-2026-07-14.slat")
(finding :id "F3" :section 11 :severity "low" :description "Sakura's sample dialect.slat template in memory doctrine says :adopts implicitly by absence; the spec should make :adopts explicit (all / except / list) so validators can enforce." :source "project_motoi_scheme_naming_and_dialects_2026_07_14.md :adds section")
(finding :id "F4" :section 11 :severity "low" :description "Text/poetry Markov and spelling subkits are not itemized in size-estimate section of research doc; verb count is inferred from the memory doctrine total (44) minus itemized subkits (35 = string-ops 20 + prosody 10 + template 5). Inference tagged in spec records above." :source "sakura-scheme-base-research-2026-07-14.slat size-estimate section")
(finding :id "F5" :section 11 :severity "medium" :description "Fantasy-console kit contradiction: base-research says 30 new + 113 wire-ups; itemized size-estimate says 6 new + 40 wire-ups. Two different subkit definitions may be at play (arts umbrella vs fantasy-console alone). Reconcile at P09 kickoff." :source "sakura-scheme-base-research-2026-07-14.slat vs memory rollup table")
(finding :id "F6" :section 11 :severity "low" :description "No SLAT loader is currently wired to the runtime — verbs still hardcoded in base.js per lang notes memory. Reference-manual-IS-the-language doctrine wants runtime to READ the reference SLAT. This is architectural for post-P05." :source "project_lang_notes_2026_07_13")
(finding :id "F7" :section 11 :severity "low" :description "Existing scheme-lang/dialect.json exists at ~/code/scheme-lang/dialect.json — pre-doctrine artifact, may collide with new dialect.slat format. Should be inventoried during P01." :source "ls ~/code/scheme-lang/")
