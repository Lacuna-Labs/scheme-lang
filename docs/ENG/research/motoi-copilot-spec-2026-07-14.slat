  :sakura-namespaces-excluded (
    (:ns "ai"        :verbs 45)
    (:ns "phys"      :verbs 19)
    (:ns "card"      :verbs 10)
    (:ns "radio"     :verbs 14)
    (:ns "cine"      :verbs 7)
    (:ns "world"     :verbs 39)
    (:ns "entity"    :verbs 40)
    (:ns "motion"    :verbs 10)
    (:ns "scene"     :verbs 5)
    (:ns "weather"   :verbs 1)
    (:ns "surface"   :verbs 5)
    (:ns "artifact"  :verbs 4)
