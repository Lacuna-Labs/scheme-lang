;;;slat 1.0
; ═══════════════════════════════════════════════════════════════════════════
; MOTOI COPILOT — DESIGN + SPEC — 2026-07-14
;
; Lane:    Motoi Scheme Copilot
; Author:  Lacuna Eng lane (Claude Opus 4.7, 1M-ctx), dispatched by Alfred
; Date:    2026-07-14
;
; Purpose. Specify the Motoi Copilot: a tiny savant language model that
; only knows Motoi Scheme. It reads a Scheme buffer and suggests the next
; form. It is a peer-programmer at the command line. It is NOT a chatbot,
; NOT a Sakura persona, NOT wired to Cortex. Its whole personality is
; being extremely good at one language.
;
; Tonight (2026-07-14) we do design + CLI stub, NOT training. Training is
; weeks of GPU work and its own lane. This SLAT is the contract the
; training lane will honor.
;
; Composes with:
;   project_motoi_scheme_naming_and_dialects_2026_07_14
;   project_sakura_scheme_base_variant_doctrine_2026_07_14
;   project_reference_manual_IS_the_language_2026_07_13
;   research/motoi-scheme-spec-and-gaps-burndown-2026-07-14.slat
;   curator/scheme-books/book-of-lang-eng/12-motoi-copilot-slot.book.slatl
;
; SLAT rules obeyed: one form per line, LF terminators, kebab-case symbols,
; keyword-value pairs.
;
; No hallucinations. Where a number is not measurable tonight, the field
; carries :confidence "unknown-needs-measurement" and the reasoning path
; for arriving at it.
; ═══════════════════════════════════════════════════════════════════════════

(doc
  :id "motoi-copilot-spec-2026-07-14"
  :status "draft-for-alfred-review"
  :audience "Alfred, Lacuna Labs, future training lane"
  :author "lacuna-eng-lane"
  :date "2026-07-14"
  :section-count 11
  :composes-with (
    "project_motoi_scheme_naming_and_dialects_2026_07_14"
    "project_sakura_scheme_base_variant_doctrine_2026_07_14"
    "project_reference_manual_IS_the_language_2026_07_13"
    "research/motoi-scheme-spec-and-gaps-burndown-2026-07-14.slat"
    "curator/scheme-books/book-of-lang-eng/12-motoi-copilot-slot.book.slatl"
  )
)

; ═══════════════════════════════════════════════════════════════════════════
; SECTION 1 — WHAT THE COPILOT IS (AND ISN'T)
; ═══════════════════════════════════════════════════════════════════════════
(section :id 1 :title "The Copilot's shape")

(shape
  :name "motoi-copilot"
  :one-line "A tiny savant model that reads a Motoi Scheme buffer and suggests the next form."
  :personality "savant — extremely good at one language, no character, no voice"
  :chatbot? #f
  :sakura-persona? #f
  :cortex-connected? #f
  :first-person-voice? #f
  :emojis? #f
  :greetings? #f
  :advocacy? #f
  :represents-anyone? #f
  :interface "CLI subcommand — reads Scheme text on stdin or from a file, emits completions on stdout"
)

(purpose
  :primary "Fork/variant authors get help staying inside the Motoi base."
  :secondary "Cart authors get portable completions that don't leak into Sakura Dialect verbs."
  :tertiary "Adapter authors get translation candidates between variants."
  :not-purpose (
    "General programming help across languages"
    "Natural conversation"
    "Emotional support, teaching pedagogy, character interaction — that's Sakura"
    "Long-form reasoning about business logic, taste, or design tradeoffs"
    "Anything requiring world knowledge beyond the Motoi reference"
  )
)

(distinction-from-sakura
  :sakura "A character. Speaks in first person. Has a voice. Persona-trained. Wired to Cortex for memory + tools."
  :motoi-copilot "A tool. No first person. No voice. Completion-trained only. No persistent memory. No Cortex."
  :training-data-sakura "Curator books (32 canon books, personality prose, philosopher lenses, listening/silence/self-model)."
  :training-data-motoi-copilot "Reference manual verbs + examples + book-of-lang-eng + tests + carts. Zero persona prose."
  :why "One artifact should do one job. Mixing them makes both worse. Sakura is warm; Copilot is precise. Different systems."
)

; ═══════════════════════════════════════════════════════════════════════════
; SECTION 2 — MODEL ARCHITECTURE TARGET
; ═══════════════════════════════════════════════════════════════════════════
(section :id 2 :title "Model architecture — recommendation")

(model
  :name "motoi-copilot-1"
  :param-range "1B–4B"
  :recommended-target "≈3B parameters (dense transformer)"
  :rationale (
    "1B is too small to hold 1,000+ verb signatures + 3,500+ examples reliably; hallucination risk is high even after fine-tuning."
    "7B+ is overkill for a single-language completion task and blows the local-inference budget; a 7B model at 4-bit needs ~4.5 GB RAM and pushes into GPU-only territory for latency."
    "3B at 4-bit quantization fits in ≈2 GB RAM, runs CPU-only on a modern laptop at usable interactive latency, and has enough capacity to memorize the reference surface."
  )
  :architecture "dense decoder-only transformer, standard causal LM"
  :context-window-min 4096
  :context-window-target 8192
  :context-window-rationale "Enough to hold a Motoi source file (typical carts are 200–800 LOC) plus a few reference entries surfaced by the runtime as system-prompt context."
  :base-model-family-preference "small open-weight code-adjacent model, licensed for commercial use, from the small-open-model landscape circa knowledge cutoff — final vendor selection is a training-lane decision documented in a follow-on SLAT"
  :confidence "medium — architecture size is defensible; base-model choice awaits training-lane audit of license + tokenizer + throughput on target hardware"
)

(quantization
  :method "GGUF 4-bit (Q4_K_M) for release; Q5_K_M offered for users with more RAM"
  :size-on-disk-est "≈1.7–2.0 GB at Q4_K_M for a 3B model"
  :size-in-ram-est "≈2.0–2.5 GB working set"
  :rationale "Q4_K_M is the widely-adopted quality/size sweet spot for small models on CPU; Q5_K_M gives noticeably better completion quality at ≈25% more RAM."
  :confidence "medium — final quant choice validated by perplexity + completion-accuracy measurement on Motoi eval set (task for training lane)"
)

(deployment-target
  :primary "local CPU inference via llama.cpp (GGUF format)"
  :why-llama-cpp (
    "Single-binary distribution — no runtime dependency hell."
    "CPU-first — the kid on the Chromebook doesn't have CUDA."
    "GGUF is the de-facto small-model quantization format; wide tooling support."
    "MIT-licensed and self-contained; we can vendor a static build with `motoi copilot`."
    "Supports streaming token output natively, which the CLI needs for interactive feel."
  )
  :alternatives-considered (
    "ONNX Runtime — heavier, more complex distribution, no clear win for our shape."
    "MLX (Apple only) — excellent perf on Apple silicon, but forks the deployment story two ways."
    "Bring-your-own-server (Ollama, LM Studio) — good for power users, but we want zero-friction default."
  )
  :fallback "Users on Apple silicon can point the Copilot at a local MLX build via `motoi copilot --backend mlx` in a later phase."
  :confidence "high"
)

; ═══════════════════════════════════════════════════════════════════════════
; SECTION 3 — TRAINING CORPUS COMPOSITION
; ═══════════════════════════════════════════════════════════════════════════
(section :id 3 :title "Training corpus composition")

(corpus-principle
  :single "Every training pair MUST come from a source that would land in the Motoi base (not Sakura Dialect surface)."
  :dual "Corpus is DERIVED from the reference and books. Reference wins on conflict."
  :triple "Zero persona prose. Zero first-person voice. Zero character material. The Copilot cannot say 'I think' because it never sees 'I think' in training."
)

(corpus-source
  :id "reference-verbs"
  :path "scheme-lang/docs/SAKURA-SCHEME-REFERENCE.slat"
  :size-mb 3.36
  :line-count 21843
  :verb-count-total 1167
  :example-count-total 3573
  :motoi-verb-count-est 960
  :motoi-verb-count-calc "1167 total minus Sakura Dialect namespaces (ai 45 + phys 19 + card 10 + radio 14 + cine 7 + world 39 + entity 40 + motion 10 + scene 5 + weather 1 + surface 5 + artifact 4 + shoppe 7 + afford 1 = 207) = 960 base verbs"
  :motoi-namespace-inventory (
