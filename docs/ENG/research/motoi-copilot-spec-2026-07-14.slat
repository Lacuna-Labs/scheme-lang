    (:ns "afford"    :verbs 1)
    (:ns "flower"    :verbs 1)
  )
  :pair-shapes (
    (:shape "verb-signature-completion"
      :input "(verb-name arg1 arg2"
      :output "(verb-name arg1 arg2 arg3)"
      :yield-per-verb 3
      :total-est 2880)
    (:shape "verb-summary-lookup"
      :input ";; What does <verb> do?"
      :output "<summary sentence from :summary field>"
      :yield-per-verb 1
      :total-est 960)
    (:shape "verb-explanation-lookup"
      :input ";; Explain <verb>"
