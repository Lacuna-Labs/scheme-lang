  :roots-scanned ("BOOK/A-branch-scheme-books/"
                  "BOOK/B-main-scheme-books/scheme-books/"
                  "BOOK/D-remote-branches/")
  :threshold ":wc >20 more than canonical AND same-slug OR -rN variant"
  :restore-applied 0
  :next-action "alfred-review-then-per-chapter-decision")

