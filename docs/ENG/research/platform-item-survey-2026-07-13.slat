  ;; ============================================================
  ;; 2. EBAY
  ;; ============================================================
  (platform
    :name "eBay"
    :rank-in-lacuna-order 2

    :total-listings 2500000000
    :total-listings-qualifier :reported
    :total-listings-source "eBay Q4 2025 Earnings Presentation; Chargeflow eBay statistics report 2026; 2.5B live listings globally at year-end 2025, up 8.7% YoY"
    :active-buyers 135000000
    :gms-2025-usd 80000000000
    :gms-source "eBay 2025 Q4 press release; ~$80B GMV, 51% international"

    :category-tree-size 20000
    :category-tree-size-qualifier :approximate
    :category-tree-source "eBay Taxonomy API developer docs; getCategoryTree returns ~20,000 categories (leaf + non-leaf) for US default tree; historically 19K-32K depending on marketplace"
    :top-level-category-count 34
    :top-level-note "eBay's US site exposes ~34 top-level 'meta' categories on browse (Motors, Electronics, Fashion, Collectibles, Home & Garden, Toys & Hobbies, Sporting Goods, etc.)"

    :top-categories-by-volume
    ((:rank 1  :name "Electronics"                :gmv-share-pct 28 :source "eBay Q4 2025 earnings; category focus disclosure. Statista eBay-GMV-by-category 2025")
     (:rank 2  :name "Fashion"                    :gmv-share-pct 17 :source "eBay Q4 2025 earnings; Statista")
     (:rank 3  :name "Home & Garden"              :gmv-share-pct 14 :source "eBay Q4 2025 earnings; Statista")
     (:rank 4  :name "Motors / Parts & Accessories" :gmv-share-pct 12 :source "eBay Q4 2025 earnings")
     (:rank 5  :name "Collectibles / Trading Cards" :gmv-share-pct-est 10 :source "eBay Q4 2025 earnings; 'biggest GMV growth driver, 9 consecutive quarters' :estimate")
     (:rank 6  :name "Toys & Hobbies"             :gmv-share-pct-est 5 :source "Marketplace Pulse eBay top-categories :estimate")
     (:rank 7  :name "Health & Beauty"            :gmv-share-pct-est 4 :source "ElectroIQ eBay stats 2025 :estimate")
     (:rank 8  :name "Sporting Goods"             :gmv-share-pct-est 3 :source "Marketplace Pulse :estimate")
     (:rank 9  :name "Business & Industrial"      :gmv-share-pct-est 2 :source "Marketplace Pulse :estimate")
     (:rank 10 :name "Books, Movies & Music / Media" :gmv-share-pct-est 2 :source "Marketplace Pulse :estimate")
     (:rank 11 :name "Jewelry & Watches"          :gmv-share-pct-est 1.5 :source "Marketplace Pulse :estimate")
     (:rank 12 :name "Coins & Paper Money"        :gmv-share-pct-est 1 :source "Marketplace Pulse :estimate")
     (:rank 13 :name "Cameras & Photo"            :gmv-share-pct-est 0.5 :source "Marketplace Pulse :estimate")
     (:rank 14 :name "Pet Supplies"               :gmv-share-pct-est 0.5 :source "Marketplace Pulse :estimate")
     (:rank 15 :name "Musical Instruments & Gear" :gmv-share-pct-est 0.5 :source "Marketplace Pulse :estimate"))

    :80pct-coverage-set
    (:categories 5
     :names ("Electronics" "Fashion" "Home & Garden" "Motors / Parts & Accessories" "Collectibles")
     :cumulative-share-pct 81
     :note "Top-5 disclosed categories cover ~81% of eBay 2025 GMV. Alfred's 'twelve-ish' recall is TOO HIGH for eBay — it is closer to five.")

