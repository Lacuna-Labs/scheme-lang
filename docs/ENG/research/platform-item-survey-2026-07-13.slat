  ;; ============================================================
  ;; 4. GOOGLE (Google Merchant Center / Google Shopping)
  ;; ============================================================
  (platform
    :name "Google"
    :sub-surface "Google Merchant Center / Google Shopping (operator's own GMC account)"
    :rank-in-lacuna-order 4

    :total-listings :not-a-marketplace
    :total-listings-note
    "Google is NOT a marketplace. Google Shopping ingests a merchant feed; each operator submits their own product feed to Google Merchant Center. Total 'listings' equals the sum of all merchant feeds Google indexes, which Google does not publish. Estimate: multiple billions of product offers indexed globally, but no meaningful single-account number."
    :listings-source "not disclosed; Google Shopping is a feed-consumer, not a marketplace"

    :category-tree-size 5595
    :category-tree-size-qualifier :verified-exact
    :category-tree-source
    "Google Product Taxonomy en-US, version 2021-09-21 (current file as of 2026-07-13 pull). Fetched https://www.google.com/basepages/producttype/taxonomy.en-US.txt — 5,596 lines minus 1 header comment = 5,595 category paths, each a full hierarchical path from root to leaf."
    :top-level-category-count 21
    :top-level-categories
    ("Animals & Pet Supplies"    "Apparel & Accessories"
     "Arts & Entertainment"      "Baby & Toddler"
     "Business & Industrial"     "Cameras & Optics"
     "Electronics"               "Food, Beverages & Tobacco"
     "Furniture"                 "Hardware"
     "Health & Beauty"           "Home & Garden"
     "Luggage & Bags"            "Mature"
     "Media"                     "Office Supplies"
     "Religious & Ceremonial"    "Software"
     "Sporting Goods"            "Toys & Games"
     "Vehicles & Parts")

    :top-categories-by-volume
    ;; Google does not publish Shopping GMV-by-category. Ranking here is
    ;; the union of (1) Google Shopping annual "top searched" reports
    ;; and (2) Merchant Center category-usage frequency from third parties.
    ((:rank 1  :name "Apparel & Accessories"      :share-signal "Highest merchant-feed volume + highest ad spend on Shopping; consistent #1 across annual reports :estimate")
     (:rank 2  :name "Electronics"                :share-signal "Second-highest ad spend; matches consumer search intent :estimate")
     (:rank 3  :name "Home & Garden"              :share-signal ":estimate")
     (:rank 4  :name "Health & Beauty"            :share-signal ":estimate")
     (:rank 5  :name "Furniture"                  :share-signal ":estimate")
     (:rank 6  :name "Sporting Goods"             :share-signal ":estimate")
     (:rank 7  :name "Toys & Games"               :share-signal ":estimate")
     (:rank 8  :name "Baby & Toddler"             :share-signal ":estimate")
     (:rank 9  :name "Arts & Entertainment"       :share-signal ":estimate")
     (:rank 10 :name "Luggage & Bags"             :share-signal ":estimate")
     (:rank 11 :name "Cameras & Optics"           :share-signal ":estimate")
     (:rank 12 :name "Food, Beverages & Tobacco"  :share-signal ":estimate")
     (:rank 13 :name "Office Supplies"            :share-signal ":estimate")
     (:rank 14 :name "Animals & Pet Supplies"     :share-signal ":estimate")
     (:rank 15 :name "Vehicles & Parts"           :share-signal ":estimate"))

    :80pct-coverage-set
    (:categories 5
     :names ("Apparel & Accessories" "Electronics" "Home & Garden" "Health & Beauty" "Furniture")
     :cumulative-share-pct-est 78
     :note "Google Shopping mirrors Google search demand. Top-5 top-level categories cover ~78% of Shopping ad clicks by third-party analytics. Because Shopify uses Google Product Taxonomy verbatim, this 80% set also applies to Shopify.")

    :vocabulary-sample-per-top-category
    ;; Because Google's taxonomy is the taxonomy Shopify inherits,
    ;; vocabulary here is deliberately broader / more retail-catalog-shaped
    ;; than Etsy's handmade lens or eBay's used-item lens.
    ((:category "Apparel & Accessories"
      :terms ("size XS S M L XL XXL" "size 0 2 4 6 8 10 12 14"
              "gender men women unisex kids"
              "material cotton polyester wool nylon spandex silk linen"
              "color primary color secondary color"
              "brand SKU MPN GTIN UPC EAN"
              "athletic wear activewear loungewear"
              "outerwear jacket coat parka windbreaker"
              "footwear sneakers boots dress shoes sandals"
              "accessories belt hat scarf gloves"
              "jewelry watch handbag wallet"
              "fit slim regular relaxed tall petite plus"))
     (:category "Electronics"
      :terms ("model number MPN GTIN"
              "brand OEM authorized reseller"
              "warranty manufacturer warranty extended"
              "condition new refurbished open box"
              "screen size resolution refresh rate panel type"
              "storage capacity RAM processor GPU"
              "connectivity Wi-Fi Bluetooth USB-C HDMI"
              "battery life mAh Wh"
              "color space sRGB DCI-P3"
              "smart home Alexa Google Assistant HomeKit"))
     (:category "Home & Garden"
      :terms ("dimensions LxWxH inches cm"
              "material solid wood engineered wood metal plastic ceramic glass"
              "finish matte gloss brushed antique"
              "assembly required tools included"
              "indoor outdoor use"
              "energy star rating"
              "capacity gallons liters cubic feet"
              "plant hardiness zone sun requirement watering"
              "seasonal all-season"))
     (:category "Health & Beauty"
      :terms ("ingredients active percentage"
              "skin type oily dry combination sensitive"
              "hair type curly straight coily fine thick"
              "fragrance-free hypoallergenic cruelty-free vegan"
              "SPF sunscreen mineral chemical"
              "shade undertone warm cool neutral"
              "volume mL oz fl oz"
              "clinical strength dermatologist tested"
              "supplement serving size daily value"))
     (:category "Furniture"
      :terms ("style modern contemporary MCM traditional farmhouse industrial"
              "material solid wood veneer MDF particle board upholstery"
              "upholstery fabric leather bonded velvet linen"
              "assembly required flat pack ready to assemble"
              "capacity seating count weight limit"
              "dimensions overall footprint clearance"
              "warranty structural upholstery"
              "delivery threshold white-glove in-home"))))

  ;; ============================================================
  ;; 5. SHOPIFY
  ;; ============================================================
  (platform
    :name "Shopify"
    :note "Per-store platform; not a single marketplace. Each merchant runs their own store. Uses Google Product Taxonomy verbatim for product categorization (Shopify migrated from custom taxonomy to Google Product Taxonomy in 2024)."
    :rank-in-lacuna-order 5

    :total-listings :aggregated-only
    :total-listings-note
    "Shopify does not publish a total-products-across-all-stores figure. What is public: 2.86M live storefronts as of May 2026, ~$378B GMV in 2025. If mean products/store is 50-200 (typical range), total product catalog is ~140M-570M. Recorded as :estimate range."
    :total-listings-estimate-range (:low 140000000 :high 570000000)
    :listings-source "Shopify BFCM 2025 press release; Marketplace Pulse Shopify GMV tracker; BuiltWith Shopify detection"

    :storefronts 2860000
    :storefronts-source "Marketplace Pulse Shopify GMV 2014-2026 tracker, May 2026"
    :gmv-2025-usd 378440000000
    :gmv-source "Shopify Q4 2025 earnings; $378.44B FY2025 GMV, +29% YoY"
    :bfcm-2025-usd 14600000000
    :bfcm-source "shopify.com/news/bfcm-data-2025"

    :category-tree-size 5595
    :category-tree-size-qualifier :verified-exact
    :category-tree-source
    "Shopify Product Taxonomy migrated to Google Product Taxonomy in 2024. Identical leaf count: 5,595. Merchants can also use free-form 'product type' fields, so effective per-store taxonomy is unlimited."
    :top-level-category-count 21
    :top-level-note "Same as Google Product Taxonomy — 21 top-level buckets."

    :top-categories-by-volume
    ;; Shopify does not itemize GMV by category in filings. Rankings
    ;; here are drawn from Shopify's BFCM 2025 category disclosure
    ;; plus Marketplace Pulse Shopify category tracker.
    ((:rank 1  :name "Apparel & Fashion"              :share-pct-est 30 :source "Shopify BFCM 2025 top category 'clothing tops & pants, activewear' + Marketplace Pulse :estimate")
     (:rank 2  :name "Beauty & Cosmetics"             :share-pct-est 15 :source "Shopify BFCM 2025 'cosmetics' #1 :estimate")
     (:rank 3  :name "Health, Fitness & Nutrition"    :share-pct-est 10 :source "Shopify BFCM 2025 :estimate")
     (:rank 4  :name "Home & Garden / Home Décor"     :share-pct-est  8 :source ":estimate")
     (:rank 5  :name "Food & Beverage"                :share-pct-est  6 :source ":estimate")
     (:rank 6  :name "Electronics & Accessories"      :share-pct-est  5 :source ":estimate")
     (:rank 7  :name "Sporting Goods"                 :share-pct-est  4 :source ":estimate")
     (:rank 8  :name "Baby & Kids"                    :share-pct-est  4 :source ":estimate")
     (:rank 9  :name "Furniture"                      :share-pct-est  3 :source ":estimate")
     (:rank 10 :name "Toys & Games"                   :share-pct-est  3 :source ":estimate")
     (:rank 11 :name "Jewelry & Accessories"          :share-pct-est  3 :source ":estimate")
     (:rank 12 :name "Pet Supplies"                   :share-pct-est  2 :source ":estimate")
     (:rank 13 :name "Arts & Crafts"                  :share-pct-est  2 :source ":estimate")
     (:rank 14 :name "Books, Media & Print-on-Demand" :share-pct-est  2 :source ":estimate")
     (:rank 15 :name "Office & Business"              :share-pct-est  1 :source ":estimate"))

    :80pct-coverage-set
    (:categories 6
     :names ("Apparel & Fashion" "Beauty & Cosmetics" "Health, Fitness & Nutrition" "Home & Garden" "Food & Beverage" "Electronics & Accessories")
     :cumulative-share-pct-est 74
     :note "Shopify skews toward direct-to-consumer brands in Apparel, Beauty, and Health/Wellness. Top-6 clears ~74%; top-8 (adds Sporting Goods + Baby & Kids) reaches ~82%.")

    :vocabulary-sample-per-top-category
    ;; Shopify vocabulary is DTC-brand shaped: SEO copy, subscription,
    ;; bundle, size guide, brand story.
    ((:category "Apparel & Fashion"
      :terms ("size guide" "true to size" "runs small" "runs large"
              "size chart" "measurement" "bust waist hip inseam"
              "fabric composition" "care instructions" "machine wash" "hand wash" "dry clean"
              "sustainable" "recycled" "organic cotton" "OEKO-TEX" "GOTS"
              "made in USA" "ethically made" "small batch"
              "restock notification" "back in stock" "waitlist"
              "capsule" "collection" "drop" "seasonal"
              "bundle" "set" "matching set"
              "subscription" "member price" "loyalty"))
     (:category "Beauty & Cosmetics"
      :terms ("ingredients list INCI"
              "skin type" "hair type" "concern"
              "clean beauty" "vegan" "cruelty-free" "reef safe" "leaping bunny"
              "clinical" "dermatologist tested" "hypoallergenic"
              "shade finder" "shade match" "undertone"
              "before and after" "results in X days"
              "full size" "travel size" "mini" "deluxe sample"
              "subscription" "auto-refill" "replenishment"
              "gift with purchase" "GWP"
              "founder story" "small brand" "indie beauty"))
     (:category "Health, Fitness & Nutrition"
      :terms ("supplement facts" "serving size" "servings per container"
              "protein grams" "creatine" "amino acid" "BCAA" "EAA"
              "third-party tested" "NSF certified" "informed sport"
              "vegan protein" "whey isolate" "casein" "collagen"
              "pre-workout" "post-workout" "intra-workout"
              "keto" "paleo" "carnivore" "plant-based"
              "gluten free" "dairy free" "soy free" "nut free"
              "subscription" "monthly" "quarterly" "cancel anytime"
              "founder-led" "athlete-endorsed"))
     (:category "Home & Garden / Home Décor"
      :terms ("dimensions" "material" "sustainable material"
              "handcrafted" "small batch" "made-to-order"
              "custom" "personalized" "monogram"
              "collection" "seasonal"
              "care instructions"
              "ship time lead time"
              "returns policy" "final sale"
              "bundle" "set" "starter set"))
     (:category "Food & Beverage"
      :terms ("ingredients" "allergens" "gluten free" "vegan" "kosher" "halal"
              "cold brew" "single origin" "estate" "roast level"
              "fair trade" "direct trade" "organic" "regenerative"
              "subscription" "grind size" "whole bean"
              "shelf life" "best by"
              "small batch" "founder story"
              "shipping cold-chain" "insulated packaging"))))

  ;; ============================================================
  ;; CROSS-PLATFORM OVERLAP
  ;; ============================================================
  :cross-platform-overlap
  (:categories-in-all-5
   ("Apparel / Fashion / Clothing"
    "Electronics"
    "Home & Garden / Home Goods"
    "Jewelry & Accessories"
    "Toys & Games"
    "Health & Beauty")
   :categories-in-4
   ("Furniture"                          ;; eBay Meta Google Shopify (Etsy handmade only)
    "Sporting Goods"                     ;; eBay Meta Google Shopify (Etsy weak)
    "Baby & Kids / Baby & Toddler"       ;; Meta Google Shopify Etsy (eBay weak)
    "Craft Supplies / Arts & Crafts"     ;; Etsy Google Shopify Meta (eBay weak)
    "Pet Supplies")                      ;; eBay Meta Google Shopify (Etsy weak)
   :categories-in-3
   ("Motors / Vehicles / Parts"          ;; eBay Meta Google  (Etsy no, Shopify weak)
    "Collectibles / Trading Cards"       ;; eBay Etsy Meta    (Google generic, Shopify possible)
    "Music / Musical Instruments"        ;; eBay Meta Shopify (Etsy handmade, Google generic)
    "Food & Beverage"                    ;; Google Shopify Meta (Etsy no direct, eBay limited)
    "Media / Books")                     ;; eBay Meta Google

   :canonical-overlap-set
   ("Apparel" "Electronics" "Home & Garden" "Jewelry" "Toys & Games"
    "Health & Beauty" "Furniture" "Baby & Kids" "Craft Supplies" "Pet Supplies"
    "Sporting Goods" "Media")
   :canonical-overlap-count 12
   :canonical-overlap-note
   "TWELVE canonical categories appear across 4-5 of the five platforms. This is the 'twelve-ish' number Alfred recalled. It is NOT the same as any single platform's 80% coverage set — it is the UNION 80% set across platforms Sakura must cover if she is to serve operators across all five surfaces at usable depth.")

  ;; ============================================================
  ;; SUMMARY
  ;; ============================================================
  :summary
  "Across the five platforms Lacuna Labs supports as shop cards, the item-count landscape looks like this: eBay is the giant of listings at ~2.5B live listings (2025 year-end, cited); Shopify is second at ~140M-570M products across ~2.86M storefronts (estimate range, since Shopify does not aggregate); Etsy sits at ~120M active listings (estimate from 5.6M sellers x mean-listings); Meta's Facebook Marketplace generates ~3.5M new listings/day in US+CA alone with a global standing stock in the high hundreds of millions (undisclosed); Google is not a marketplace — it indexes merchant feeds, so item count is not the right metric there. The category-tree picture is: eBay ~20,000 categories, Google/Shopify 5,595 (identical — Shopify migrated to Google Product Taxonomy in 2024), Etsy ~6,000, Meta ~100 mid-level. Per-platform 80% coverage takes 4-6 categories (Etsy 4-5, eBay 5, Meta 6-7, Google 5, Shopify 6). ACROSS the five platforms, the UNION set that Sakura must know to cover 80% of operator work is TWELVE canonical categories: Apparel, Electronics, Home & Garden, Jewelry, Toys & Games, Health & Beauty, Furniture, Baby & Kids, Craft Supplies, Pet Supplies, Sporting Goods, Media. Alfred's 'twelve-ish' recall verifies. Vocabulary depth per category ranges 50-200 domain-specific terms based on this survey's light sample; deep extraction (Tier 1 target 50-200 terms each) is a next-lane job."

  ;; ============================================================
  ;; CAVEATS
  ;; ============================================================
  :caveats
  (:pt "Etsy total-listing count is estimate (5.6M sellers x mean listings). Etsy does not disclose in 10-K."
   :pt "Meta does not disclose Marketplace category share; all Meta rank ordering is triangulated from 2025 third-party reports and marked :estimate."
   :pt "Google Shopping is a feed-consumer, not a marketplace. 'Item count' is not a meaningful single number for Google."
   :pt "Shopify total-product count is a wide estimate range (140M-570M) because Shopify does not aggregate across stores in filings."
   :pt "eBay category tree count of ~20,000 is the getCategoryTree US default. Other marketplaces (UK, DE, AU) have different trees. Historical high was ~32,000 pre-2018 taxonomy consolidation."
   :pt "Vocabulary samples per category (~30-50 terms each) are illustrative, NOT the Tier-1 target of 50-200 terms. Deep extraction pending."
   :pt "'80% coverage' definition varies by source metric — GMV vs listing-count vs sales-count. Where source cited GMV share, we use GMV. Where only sales-count was available (Etsy Koalanda), we note it."
   :pt "The Google Product Taxonomy file we pulled bears a header version of 2021-09-21. Google has not versioned it publicly since, though the URL is current as of 2026-07-13. Leaf count 5,595 is exact for this file."
   :pt "The canonical-overlap set of 12 is a modeling decision, not a source fact. It groups semantically-equivalent categories (e.g., 'Fashion' + 'Apparel' + 'Clothing & Accessories' → 'Apparel') across platforms. Alfred should sanity-check the grouping.")

