;; platform-item-survey-2026-07-13.slat
;; Lacuna Labs Engineering research artifact
;; Written 2026-07-13. Dispatched by lacuna-eng. Requested by alfred.
;; Purpose: authoritative survey of item counts + category depth across
;; the five commerce platforms Lacuna Labs supports as shop cards.
;; Anti-hallucination: every number is cited or tagged :estimate.

(platform-survey
  :date "2026-07-13"
  :platforms 5
  :dispatched-by "lacuna-eng"
  :requested-by "alfred"
  :purpose "count of items + categories across the 5 supported shop platforms; 80%-coverage set for Sakura vocabulary training"

  ;; ============================================================
  ;; 1. ETSY
  ;; ============================================================
  (platform
    :name "Etsy"
    :rank-in-lacuna-order 1

    :total-listings 120000000
    :total-listings-qualifier :estimate
    :total-listings-note
    "Etsy does not publish a total-listings figure in its 10-K. Third-party trackers (eRank, Marketmaid, Statista) triangulate ~100M-140M active listings from the ~5.6M active sellers x ~20-25 listings/seller mean. We record 120M as midpoint estimate."
    :listings-source "Etsy Inc. 2025 Form 10-K (filed 2026-02-19); active-seller figure 5.6M cited directly; listing count derived."

    :active-sellers 5600000
    :active-buyers 86500000
    :gms-2025-usd 10500000000
    :gms-source "Etsy Q4 2025 press release, 2026-02-19"

    :category-tree-size 6000
    :category-tree-size-qualifier :approximate
    :category-tree-source "Etsy Engineering blog 'An Introduction to Structured Data at Etsy'; taxonomy contains 6,000+ categories, 400+ attributes, 3,500+ values"
    :top-level-category-count-approx 50

    :top-categories-by-volume
    ((:rank 1 :name "Home & Living"              :gms-share-pct 34 :gms-usd-est 3710000000 :source "Etsy 10-K FY2025 category disclosure")
     (:rank 2 :name "Jewelry & Personal Accessories" :gms-share-pct 18 :gms-usd-est 1960000000 :source "Etsy 10-K FY2025")
     (:rank 3 :name "Apparel"                    :gms-share-pct 14 :gms-usd-est 1530000000 :source "Etsy 10-K FY2025")
     (:rank 4 :name "Craft Supplies"             :gms-share-pct  9 :gms-usd-est  980000000 :source "Etsy 10-K FY2025")
     (:rank 5 :name "Paper & Party Supplies"     :gms-share-pct  8 :gms-usd-est  870000000 :source "Etsy 10-K FY2025")
     (:rank 6 :name "Toys & Games"               :gms-share-pct  4 :gms-usd-est  440000000 :source "Etsy 10-K FY2025")
     ;; ranks 7-15 are Etsy-internal and not itemized in filings.
     ;; Marketplace-Pulse and Koalanda seller-tools report these next tiers by sales volume:
     (:rank 7  :name "Weddings"                  :gms-share-pct-est 3 :source "Koalanda Etsy sales report Dec 2025 :estimate")
     (:rank 8  :name "Bath & Beauty"             :gms-share-pct-est 3 :source "Koalanda :estimate")
     (:rank 9  :name "Art & Collectibles"        :gms-share-pct-est 2 :source "Koalanda :estimate")
     (:rank 10 :name "Pet Supplies"              :gms-share-pct-est 1 :source "Koalanda :estimate")
     (:rank 11 :name "Bags & Purses"             :gms-share-pct-est 1 :source "Koalanda :estimate")
     (:rank 12 :name "Shoes"                     :gms-share-pct-est 1 :source "Koalanda :estimate")
     (:rank 13 :name "Books, Movies & Music"     :gms-share-pct-est 0.5 :source "Koalanda :estimate")
     (:rank 14 :name "Electronics & Accessories" :gms-share-pct-est 0.5 :source "Koalanda :estimate")
     (:rank 15 :name "Vintage"                   :gms-share-pct-est 0.5 :source "Etsy 10-K FY2025 notes vintage as a distinct policy category :estimate"))

    :80pct-coverage-set
    (:categories 4
     :names ("Home & Living" "Jewelry & Personal Accessories" "Apparel" "Craft Supplies")
     :cumulative-share-pct 75
     :note "The Etsy 10-K states the top-6 categories account for ~85% of GMS. The top-4 clear ~75%. To reach true 80%, use top-5 (Home & Living, Jewelry, Apparel, Craft Supplies, Paper & Party Supplies) = 83% cumulative.")

    :vocabulary-sample-per-top-category
    ((:category "Home & Living"
      :terms ("throw pillow" "duvet" "wall art" "print" "poster" "canvas" "framed"
              "candle" "soy wax" "beeswax" "wick" "vase" "planter" "terracotta"
              "wall hook" "shelf" "welcome mat" "doormat" "runner" "tapestry"
              "macrame" "mid-century" "boho" "farmhouse" "minimalist"
              "personalized" "monogram" "custom"))
     (:category "Jewelry & Personal Accessories"
      :terms ("14k gold" "18k gold" "gold fill" "gold plated" "sterling silver" "925"
              "rose gold" "vermeil" "rhodium" "brass" "copper"
              "solitaire" "halo" "pave" "prong" "bezel" "channel-set"
              "cabochon" "faceted" "raw" "rough" "polished"
              "cubic zirconia" "moissanite" "lab-grown" "natural diamond"
              "birthstone" "amethyst" "aquamarine" "peridot" "topaz" "opal" "turquoise"
              "hoop" "stud" "drop" "huggie" "chandelier"
              "pendant" "chain" "cable chain" "figaro" "curb" "rope"
              "cuff" "bangle" "tennis bracelet" "charm bracelet"
              "signet ring" "eternity band" "engagement ring"
              "handmade" "wire-wrapped" "beaded" "resin" "polymer clay"
              "personalized" "engraved" "birthstone" "initial"))
     (:category "Apparel"
      :terms ("tee" "tank" "hoodie" "crewneck" "long sleeve" "raglan"
              "cotton" "tri-blend" "bamboo" "linen" "flannel" "fleece"
              "unisex" "youth" "toddler" "onesie" "bodysuit"
              "graphic tee" "vintage tee" "band tee" "novelty"
              "screen printed" "DTG" "sublimation" "embroidered" "cut and sew"
              "size chart" "S M L XL XXL" "true to size" "oversized" "relaxed fit"
              "made to order" "ships in 3-5 days"
              "wedding" "bachelorette" "matching" "couples" "family"))
     (:category "Craft Supplies"
      :terms ("bead" "seed bead" "miyuki" "delica" "swarovski" "czech glass"
              "gemstone bead" "spacer" "bead cap"
              "jump ring" "clasp" "lobster claw" "toggle" "crimp"
              "wire" "gauge" "dead soft" "half hard"
              "yarn" "worsted" "DK" "bulky" "roving" "sock weight"
              "fabric" "quarter yard" "fat quarter" "bundle" "flannel" "muslin"
              "vinyl" "HTV" "iron-on" "sublimation blank"
              "SVG" "PNG" "digital download" "print at home" "cut file" "cricut" "silhouette"
