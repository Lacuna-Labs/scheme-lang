  ;; ============================================================
  ;; 3. META (Facebook Marketplace + Facebook Shop + Instagram Shop)
  ;; ============================================================
  (platform
    :name "Meta"
    :sub-surfaces ("Facebook Marketplace" "Facebook Shop" "Instagram Shop")
    :rank-in-lacuna-order 3

    :total-listings :not-publicly-disclosed
    :daily-new-listings 3500000
    :daily-new-listings-note "Meta reports 3.5M new listings per DAY in US+Canada on Facebook Marketplace alone (March 2026 Meta Newsroom). Global stock estimate: 500M-1B+ live listings, but Meta does not confirm."
    :listings-source "Meta Newsroom 'Facebook Marketplace New Meta AI Tools' 2026-03; TechCrunch 2025-11-13"

    :monthly-users 1100000000
    :monthly-buyer-seller-connections 3000000000
    :gmv-est-2025-usd 12000000000
    :gmv-source "sqmagazine + Statista aggregated :estimate — Meta does not disclose Marketplace GMV separately in 10-Q"

    :category-tree-size 100
    :category-tree-size-qualifier :estimate
    :category-tree-source "Facebook Marketplace category directory at facebook.com/marketplace/categories/ — ~15 top-level buckets, ~100 mid-level sub-categories. No public leaf-count. Instagram Shop uses a subset of Meta's product-catalog taxonomy which mirrors Google Product Taxonomy for feed uploads."
    :top-level-category-count 15
    :top-level-categories
    ("Vehicles" "Property Rentals" "Apparel" "Classifieds"
     "Electronics" "Entertainment" "Family" "Free Stuff"
     "Garden & Outdoor" "Hobbies" "Home Goods" "Home Improvement"
     "Home Sales" "Musical Instruments" "Office Supplies"
     "Pet Supplies" "Sporting Goods" "Toys & Games")

    :top-categories-by-volume
    ;; Meta does not publish share-by-category. Rank is inferred from
    ;; multiple 2025 third-party reports (Accio, Spocket, Adnabu, Swoopa, sqmagazine).
    ((:rank 1  :name "Vehicles"                  :share-pct-est 20 :source "Multiple 2025 reports; largest single-item GMV category :estimate")
     (:rank 2  :name "Furniture & Home Goods"    :share-pct-est 15 :source "Meta 2025 category signals :estimate")
     (:rank 3  :name "Apparel / Clothing & Accessories" :share-pct-est 12 :source "Accio + Spocket 2025 :estimate")
     (:rank 4  :name "Electronics"               :share-pct-est 10 :source "Accio 2025 :estimate")
     (:rank 5  :name "Baby & Kids"               :share-pct-est  8 :source "Accio 2025 :estimate")
     (:rank 6  :name "Home Improvement"          :share-pct-est  6 :source "Meta category directory + third-party :estimate")
     (:rank 7  :name "Garden & Outdoor"          :share-pct-est  5 :source ":estimate")
     (:rank 8  :name "Sporting Goods"            :share-pct-est  4 :source ":estimate")
     (:rank 9  :name "Toys & Games"              :share-pct-est  4 :source ":estimate")
     (:rank 10 :name "Musical Instruments"       :share-pct-est  3 :source ":estimate")
     (:rank 11 :name "Pet Supplies"              :share-pct-est  3 :source ":estimate")
     (:rank 12 :name "Beauty (mostly Instagram Shop)" :share-pct-est 3 :source "Instagram Shopping stats 2025 :estimate")
     (:rank 13 :name "Hobbies & Collectibles"    :share-pct-est  2 :source ":estimate")
     (:rank 14 :name "Books / Media"             :share-pct-est  2 :source ":estimate")
     (:rank 15 :name "Office & Business Supplies" :share-pct-est 1 :source ":estimate"))

    :80pct-coverage-set
    (:categories 6
     :names ("Vehicles" "Furniture & Home Goods" "Apparel" "Electronics" "Baby & Kids" "Home Improvement")
     :cumulative-share-pct-est 71
     :note "Meta needs 6-7 categories for ~80% coverage — more than eBay because volume is more distributed and Vehicles dominates but doesn't cross 25%. Instagram Shop skews to Fashion + Beauty; Facebook Marketplace skews to Vehicles + Furniture. Combined surface is broader than eBay's top-heavy distribution.")

    :vocabulary-sample-per-top-category
    ((:category "Vehicles"
      :terms ("year" "make" "model" "trim" "mileage" "odometer"
              "clean title" "salvage" "rebuilt title" "lien"
              "VIN" "CarFax" "AutoCheck"
              "automatic" "manual" "CVT" "AWD" "4WD" "FWD" "RWD"
