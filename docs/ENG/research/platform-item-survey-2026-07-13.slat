              "polymer clay" "sculpey" "premo"
              "wood blank" "unfinished" "laser-ready"))
     (:category "Paper & Party Supplies"
      :terms ("invitation" "save the date" "RSVP" "envelope liner"
              "escort card" "place card" "menu card" "seating chart"
              "birthday banner" "cake topper" "cupcake topper" "party hat"
              "balloon garland" "backdrop" "photo booth prop"
