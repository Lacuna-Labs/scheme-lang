  :examples (
    (:tier "novice" :code "*[verify]*" :note "*[verify]* — exact behavior unconfirmed; check live examples in the codebase.")
    (:tier "intermediate" :code "*[verify]*" :note "*[verify]* — requires inspection of actual time/across usage.")
