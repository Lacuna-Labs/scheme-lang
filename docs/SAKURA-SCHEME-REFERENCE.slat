; ─── library: tick (9 verbs) ───

(verb
  :name "tick/ease"
  :library "tick"
  :kind "meta"
  :signature "(tick/ease name t) → scalar | 'nan"
  :summary "Apply a named Penner easing function to t ∈ [0, 1]; unknown name yields 'nan."
  :explanation "Penner easing functions smooth time-based animations. Given a name (symbol) and a normalized time `t` between 0 and 1, this verb returns the eased value. Common names: 'linear, 'ease-in-quad, 'ease-out-quad, 'ease-in-out-cubic, etc. Unknown names return the symbol 'nan; invalid `t` also yields 'nan. Use this to control animation curves in motion, morphs, and choreography."
  :examples (
    (:tier "novice" :code "(tick/ease 'linear 0.5)" :note "Linear easing at 50% progress returns 0.5.")
    (:tier "intermediate" :code "(define (ease-card-in frame duration easing-name)\n  (let ((t (/ frame duration)))\n    (if (<= t 1.0)\n      (tick/ease easing-name t)\n      1.0)))\n(ease-card-in 30 60 'ease-out-quad)" :note "Compute eased progress over a 60-frame duration with ease-out-quad.")
    (:tier "expert" :code "(define (morph-position t easing-name start end)\n  (let ((eased-t (tick/ease easing-name t)))\n    (if (eq? eased-t 'nan)\n      start\n      (+ start (* eased-t (- end start))))))\n(morph-position 0.3 'ease-in-out-cubic 100 200)" :note "Interpolate between two values using an eased time; fallback to start on invalid easing.")
  )
  :caveats ("Named easing functions are case-insensitive symbols." "`t` should be in [0, 1]; values outside this range return 'nan." "Unknown easing name returns 'nan, not an error; check result before using." "Easing names are registered by the system; custom easing is not (yet) supported.")
  :drawbacks ("Only works with `t` normalized to [0, 1]; you must handle time rescaling." "No support for easing vectors or colors directly; use for each dimension or channel separately." "Limited easing library; if a specific curve is needed, may need to interpolate or combine.")
  :usecases ("Smooth card transitions and morphs." "Create expressive motion timing (ease-in-out for natural acceleration)." "Animate HUD elements with polish." "Build dialogue or narrative sequences with paced reveals.")
  :related ("tick/osc" "tick/sine" "tick/phase" "motion/with-feel" "motion/with-pace")
  :learn (:concept "Easing curves: how to map linear time into nonlinear (perceptually smoother) motion." :prerequisites ("(core)" "tick/phase") :progression "Learn tick/sine and tick/osc to generate periodic motion; then motion/with-feel to apply easing to card transitions."))

(verb
  :name "tick/lissajous"
  :library "tick"
  :kind "meta"
  :signature "(tick/lissajous freq-x freq-y phase-x phase-y t) → [x y] | 'nan"
  :summary "Compute a 2-D Lissajous orbit at time `t`; any bad numeric yields 'nan."
  :explanation "A Lissajous curve is traced by two independent sinusoidal oscillators with different frequencies and phases. Given frequencies, phases, and a time `t`, this verb returns the [x, y] point on the curve. Use it for orbital motion, decorative paths, or parametric animation. If any input is non-numeric or invalid, returns 'nan."
  :examples (
    (:tier "novice" :code "(tick/lissajous 1 1 0 0 0.5)" :note "1:1 frequency ratio at 50% of one cycle; phase offset 0—returns [x y] on the diagonal.")
    (:tier "intermediate" :code "(define (orbit-entity entity-id freq-x freq-y t scale-x scale-y)\n  (let ((pt (tick/lissajous freq-x freq-y 0 0 t)))\n    (if (not (eq? pt 'nan))\n      (entity/set-pos! entity-id\n                      (* (car pt) scale-x)\n                      (* (cadr pt) scale-y)))))\n(orbit-entity 'eye 3 5 0.2 100 80)" :note "Move an entity along a 3:5 Lissajous curve; scale to fit the screen.")
    (:tier "expert" :code "(define (lissajous-trail entity-id freq-x freq-y t-start t-end steps)\n  (let loop ((i 0) (t t-start) (pts '()))\n    (if (< i steps)\n      (let ((dt (/ (- t-end t-start) steps))\n            (pt (tick/lissajous freq-x freq-y 0 0 t)))\n        (loop (+ i 1) (+ t dt)\n              (if (eq? pt 'nan) pts (cons pt pts))))\n      pts)))\n(lissajous-trail 'eye 2 3 0 1 20)" :note "Sample the Lissajous curve at 20 points over [0, 1]; collect into a trail for visualization.")
  )
  :caveats ("Frequencies control oscillation speed; large freq values produce tight, fast curves." "Phase offsets are in radians (0 to 2π); offset by π/2 to shift 90°." "`t` is typically in [0, 1] or [0, period]; values outside repeat." "Any non-numeric input (including 'nan) returns 'nan; always validate inputs.")
  :drawbacks ("Result is normalized to [-1, 1]; must scale and offset for screen coordinates." "No direct support for 3-D orbits; only 2-D." "Frequency ratios create repeating patterns; if you need a smooth aperiodic path, consider splines instead.")
  :usecases ("Animate a decorative orbiting element (e.g., floating gem, camera rig)." "Create parametric backgrounds or visual effects." "Design choreography with synchronized orbital motion." "Prototype animated paths for cameras or particles.")
  :related ("tick/sine" "tick/osc" "tick/phase" "motion/arc" "entity/set-pos!")
  :learn (:concept "Parametric curves: how to compute points on 2-D orbital paths using frequency ratios." :prerequisites ("(core)" "tick/sine") :progression "Learn tick/sine for 1-D oscillation; then motion/arc for polynomial motion; then world/each to apply the path to many entities."))

(verb
  :name "tick/mod-n"
  :library "tick"
  :kind "meta"
  :signature "(tick/mod-n frame n) → int ∈ [0, n-1] | 'nan"
  :summary "Bucket a frame index into [0, n-1] using modulo; n ≤ 0 yields 'nan."
  :explanation "Frame-based timing often needs to cycle through `n` buckets or states. This verb returns frame mod n, clamping the result to [0, n-1]. Use it to drive cycles, loops, or state machines without floating-point math. If `n` ≤ 0 or `frame` is not an integer, returns 'nan."
  :examples (
    (:tier "novice" :code "(tick/mod-n 7 3)" :note "7 mod 3 = 1; bucket index 1 in a 3-state cycle.")
    (:tier "intermediate" :code "(define (cycle-sprite sprite-id frame num-frames)\n  (let ((frame-index (tick/mod-n frame num-frames)))\n    (if (not (eq? frame-index 'nan))\n      (sprite-set! sprite-id frame-index))))\n(on-frame (lambda (ctx) (cycle-sprite 'walk-cycle (on-frame ctx) 8)))" :note "Animate a sprite by cycling through 8 frames; wrap at 8.")
    (:tier "expert" :code "(define (multi-phase-state frame num-phases phase-fn)\n  (let ((phase (tick/mod-n frame num-phases)))\n    (cond ((eq? phase 'nan) 'error)\n          ((= phase 0) (phase-fn 'start))\n          ((= phase (- num-phases 1)) (phase-fn 'end))\n          (else (phase-fn 'middle)))))\n(multi-phase-state 15 4 display)" :note "Use mod-n to dispatch to different phase handlers in a loop.")
  )
  :caveats ("`frame` must be an integer; floats return 'nan." "`n` must be > 0; n ≤ 0 returns 'nan." "Result is in [0, n-1], not [1, n]; adjust if 1-indexed logic is needed." "Negative `frame` is valid; -1 mod n = n-1.")
  :drawbacks ("Integer-only; if you need floating-point cycling, use `tick/sine` or `tick/triangle` instead." "No built-in phase offset; add frame offset before calling if needed." "Limited to simple modulo; for weighted or non-uniform cycles, use `tick/pattern`.")
  :usecases ("Cycle through sprite frames in an animation loop." "Distribute events across multiple lanes (e.g., every 4th frame goes to lane 0, etc.)." "Implement turn-based game logic (frame mod num-players determines whose turn)." "Pulse or flicker effects with integer cycle counts.")
  :related ("tick/pattern" "tick/phase" "tick/pulse" "on-frame")
  :learn (:concept "Integer-based timing: how to use modulo arithmetic for discrete cycles without floating-point rounding." :prerequisites ("(core)" "modulo") :progression "Learn tick/pulse for duty-cycle timing; then tick/pattern to cycle through lists; then on-frame to tie logic to the render loop."))

(verb
  :name "tick/osc"
  :library "tick"
  :kind "meta"
  :signature "(tick/osc frame period lo hi) -> number"
  :summary "Maps a sine wave into a range [lo, hi] over a given period in frames."
  :explanation "This verb wraps a sine oscillator and remaps its natural [-1, 1] output to any target range. It's useful for animating properties that need smooth, periodic motion: color fades, position sways, scale pulses. The period controls how many frames one complete cycle takes. Pass frame (typically the current frame number from on-tick or similar) and it returns a value smoothly interpolated between lo and hi. If period ≤ 0, returns 'nan to signal invalid input."
  :examples (
    (:tier "novice" :code "(on-tick (lambda ()\n  (let ((val (tick/osc (frame) 60 0.5 2.0)))\n    (entity/scale! 'my-sprite val))))" :note "Scales a sprite smoothly up and down over 60 frames, cycling between 0.5× and 2.0×.")
    (:tier "intermediate" :code "(on-tick (lambda ()\n  (let* ((phase (tick/osc (frame) 120 0 1))\n         (r (+ 200 (* 50 (tick/osc (frame) 60 -1 1))))\n         (theta (* 6.28 phase)))\n    (entity/set-pos! 'player (list (* r (cos theta)) (* r (sin theta)))))))" :note "Circular motion with variable radius: uses osc to animate radius and phase separately.")
    (:tier "expert" :code "(define (breathing-camera ctx)\n  (let ((breath (tick/osc (frame) 180 0.9 1.1)))\n    (camera-zoom-to (* (ctx-get 'base-zoom ctx) breath))))\n\n(on-tick breathing-camera)" :note "Camera zoom gently pulses in and out; state function reads base-zoom from context.")
  )
  :caveats ("Period must be > 0; period ≤ 0 returns 'nan." "Frame input is typically an integer (0, 1, 2, ...) but any number is accepted." "The oscillation is continuous: frame wraps naturally (frame=120 with period=60 is the same phase as frame=0)." "lo and hi can be any numbers; if lo > hi, the wave inverts.")
  :drawbacks ("Only outputs a single scalar; for multi-axis motion, call tick/osc multiple times with different periods." "Sine is smooth but not tunable to custom easing curves; use tick/ease for named Penner easings instead." "No built-in amplitude clipping; very large range values will produce very large outputs.")
  :usecases ("Sprite scale/opacity pulses." "Smooth camera pan or zoom." "Parameter animation (color hue shift, audio filter sweep)." "Gentle breathing or floating effects on UI elements.")
  :related ("tick/sine" "tick/triangle" "tick/pulse" "tick/phase" "tick/ease" "on-tick")
  :learn (:concept "Periodic motion via sine remapping: the workhorse for smooth oscillation in a bounded range." :prerequisites ("on-tick" "frame") :progression "After mastering osc, explore tick/sine (raw amplitude), tick/triangle (sharp peaks), and tick/ease (easing curves) for more expressive animation."))

(verb
  :name "tick/pattern"
  :library "tick"
  :kind "meta"
  :signature "(tick/pattern frame xs) -> element"
  :summary "Cycles through a list, selecting one element per frame using modular indexing."
  :explanation "This verb treats a list as a repeating sequence and returns one element per frame. The frame number is taken modulo the list length, so frame 0 gives xs[0], frame 1 gives xs[1], and when frame reaches the list length, it wraps back to xs[0]. It's the discrete analog of tick/osc: useful for cycling through sprite frames, animation states, color palettes, or note sequences. If the list is empty, returns 'nan."
  :examples (
    (:tier "novice" :code "(on-tick (lambda ()\n  (let ((frame-idx (tick/pattern (frame) '(0 1 2 1))))\n    (entity/sprite! 'player frame-idx))))" :note "Cycles through sprite frames 0, 1, 2, 1, 0, 1, 2, 1, ... forever.")
    (:tier "intermediate" :code "(define walk-cycle '((0 0) (1 0) (2 0) (1 0)))\n(on-tick (lambda ()\n  (let ((step (tick/pattern (/ (frame) 5) walk-cycle)))\n    (entity/sprite! 'hero step))))" :note "Slows the cycle by dividing frame by 5; steps through walk frames, changing every 5 ticks.")
    (:tier "expert" :code "(define (color-pulse ctx)\n  (let ((palette '((255 0 0) (255 128 0) (255 255 0) (128 255 0)))\n        (color (tick/pattern (frame) palette)))\n    (entity/set! 'aura 'color color)))\n\n(on-tick color-pulse)" :note "Cycles through a color palette, changing every frame; stores palette in a closure.")
  )
  :caveats ("Empty list returns 'nan; always ensure xs has at least one element." "Frame must be a non-negative integer; negative frames wrap from the end (standard modulo behavior)." "List elements are NOT type-checked; any Scheme value is valid." "Mutation of xs during execution (if supported) will affect future cycles; treat xs as read-only.")
  :drawbacks ("No built-in interpolation: stepping is discrete, not smooth. Use tick/osc or tick/ease for smooth animation." "Cycle always starts at frame 0; no phase offset. Divide or shift the frame input to start at a different point." "Performance is O(list length) if the list is very large; prefer smaller palettes for performance-critical code.")
  :usecases ("Sprite frame animation (walk cycles, blinking, idle poses)." "Color cycling (LED pulse, gradient sweep, mood lighting)." "State machine stepping (discrete FSM transitions)." "Melody sequencing (repeating note patterns).")
  :related ("tick/osc" "tick/phase" "tick/mod-n" "on-tick" "frame")
  :learn (:concept "Discrete cyclic indexing: select from a list using frame modulo to create repeating sequences." :prerequisites ("on-tick" "frame" "list") :progression "Combine tick/pattern with tick/phase or tick/osc to blend discrete and smooth animation, or use tick/ease for smooth transitions between list elements."))

(verb
  :name "tick/phase"
  :library "tick"
  :kind "meta"
  :signature "(tick/phase frame period) -> number"
  :summary "Generates a rising sawtooth [0, 1) that repeats every period frames."
  :explanation "This verb returns a ramp that climbs from 0 to just below 1, then resets to 0 each period. Unlike tick/osc (which is wavy) or tick/triangle (which peaks), phase is purely linear: it's the fundamental time parameter. It's useful as a base input to other functions, or directly for controlling fade-in/fade-out, progress bars, or position along a path. If period ≤ 0, returns 'nan."
  :examples (
    (:tier "novice" :code "(on-tick (lambda ()\n  (let ((t (tick/phase (frame) 100)))\n    (entity/set! 'sprite 'opacity t))))" :note "Fades in from opacity 0 to 1 over 100 frames, then snaps back to 0 and repeats.")
    (:tier "intermediate" :code "(on-tick (lambda ()\n  (let* ((t (tick/phase (frame) 200))\n         (x (+ 100 (* 300 t)))\n         (y (+ 50 (* 100 (sin (* 6.28 t))))))\n    (entity/set-pos! 'projectile (list x y)))))" :note "Linear horizontal motion combined with sinusoidal vertical motion; both sync to the same period.")
    (:tier "expert" :code "(define (progress-bar ctx)\n  (let* ((period (ctx-get 'duration ctx))\n         (t (tick/phase (frame) period))\n         (width (* 200 t)))\n    (card/draw 'progress-bar (list 0 0 width 20))))\n\n(on-tick progress-bar)" :note "Progress bar grows linearly over context-controlled duration; phase ensures 0→1 repeatability.")
  )
  :caveats ("Period must be > 0; period ≤ 0 returns 'nan." "Output is [0, 1), never quite reaching 1.0 (due to modulo); if you need exactly 1.0 at the peak, clamp or add epsilon." "The sawtooth is instantaneous at the reset; there is no smoothing. Use tick/triangle for a smooth peak.")
  :drawbacks ("Only outputs a raw [0, 1) ramp; remapping to a custom range requires manual arithmetic (e.g., lo + t·(hi−lo))." "No easing curve applied; it is always linear. Pair with tick/ease if you need acceleration/deceleration." "Resets abruptly; unsuitable for continuous cyclic motion. Use tick/osc or tick/sine instead.")
  :usecases ("Linear fade-in or fade-out." "Progress bar or loading indicator." "Parametric interpolation along a path (e.g., from A to B as t goes 0→1)." "Base phase input to combine with multiple easing curves in one animation.")
  :related ("tick/osc" "tick/sine" "tick/ease" "tick/mod-n" "on-tick")
  :learn (:concept "Linear ramp phase: the fundamental sawtooth clock for time-based animation and parameter blending." :prerequisites ("on-tick" "frame") :progression "Use phase as input to tick/ease (easing), or multiply/add it to create custom parametric curves. Combine multiple phases with different periods for complex timing."))

(verb
  :name "tick/pulse"
  :library "tick"
  :kind "meta"
  :signature "(tick/pulse frame period duty) -> number"
  :summary "Generates a square wave: 1 for the first duty fraction of each period, 0 otherwise."
  :explanation "This verb outputs a binary (or near-binary) signal that is high (1) for the first duty·period frames of each cycle, then low (0) for the remainder. Duty is a number in [0, 1] controlling the fraction of time the signal is high. It's useful for on/off animations, blinking effects, or rhythm-gated animations. If period ≤ 0, returns 'nan."
  :examples (
    (:tier "novice" :code "(on-tick (lambda ()\n  (let ((on? (tick/pulse (frame) 20 0.5)))\n    (entity/set! 'led 'visible? (= on? 1)))))" :note "LED blinks: on for 10 frames, off for 10 frames, repeating every 20 frames.")
    (:tier "intermediate" :code "(on-tick (lambda ()\n  (let* ((blink (tick/pulse (frame) 30 0.3))\n         (alpha (if (= blink 1) 1.0 0.2)))\n    (entity/set! 'sprite 'opacity alpha))))" :note "Sprite flickers brighter for 30% of each 30-frame cycle, dimmer for 70%.")
    (:tier "expert" :code "(define (gated-animation ctx)\n  (let* ((gate (tick/pulse (frame) 60 0.5))\n         (phase (if (= gate 1) (tick/phase (frame) 60) 0))\n         (y (+ 100 (* 50 phase))))\n    (entity/set-pos! 'bouncer (list 100 y))))\n\n(on-tick gated-animation)" :note "Animation plays only during the high part of the pulse; pauses during the low part.")
  )
  :caveats ("Period must be > 0; period ≤ 0 returns 'nan." "Duty should be in (0, 1]; duty ≤ 0 or duty ≥ 1 may cause unexpected results." "Output is a hard 0 or 1; there is no smoothing at the transitions. Use tick/triangle or tick/osc for smooth waves." "Rounding errors near the duty boundary may cause occasional skips; round duty·period to an integer if frame-perfect timing is critical.")
  :drawbacks ("Binary output only; no intermediate values. Blend manually with other oscillators if you need gradual transitions." "Duty is fixed per call; no dynamic duty modulation without recalculating each frame." "Sharp edges cause aliasing if period is very short; smooth with a low-pass filter or use tick/triangle.")
  :usecases ("Blinking or flickering effects." "Pulse-width modulation (PWM) gating." "Rhythm-gated animation (movements synchronized to a beat)." "On/off switching at a given frequency.")
  :related ("tick/osc" "tick/triangle" "tick/sine" "on-tick" "frame")
  :learn (:concept "Square wave with variable duty cycle: a basic control signal for gating and rhythm." :prerequisites ("on-tick" "frame") :progression "Combine tick/pulse with tick/phase or other smooth oscillators to gate animations on/off. Experiment with duty to control the balance of activity to rest."))

(verb
  :name "tick/sine"
  :library "tick"
  :kind "meta"
  :signature "(tick/sine frame period amp phase) -> number"
  :summary "Generates a raw sinusoidal oscillation: amp·sin(2π·frame/period + phase)."
  :explanation "This verb applies a sine function with explicit control over amplitude, period, and phase offset. It is the raw sine before any range remapping; tick/osc wraps this into [lo, hi]. Use tick/sine when you need fine-grained control over the wave parameters or when you want to combine multiple sine waves (e.g., for FM synthesis or Lissajous figures). Phase is in radians and lets you offset the start of the cycle. If period ≤ 0, returns 'nan."
  :examples (
    (:tier "novice" :code "(on-tick (lambda ()\n  (let ((y (+ 100 (tick/sine (frame) 60 50 0))))\n    (entity/set-pos! 'ball (list 200 y)))))" :note "Ball bobs up and down 50 pixels around y=100, with a 60-frame period.")
    (:tier "intermediate" :code "(on-tick (lambda ()\n  (let* ((x (+ 200 (tick/sine (frame) 100 80 0)))\n         (y (+ 150 (tick/sine (frame) 100 80 1.57))))\n    (entity/set-pos! 'orbit (list x y)))))" :note "Circular orbit: x and y sine waves with 90° phase offset (1.57 rad ≈ π/2).")
    (:tier "expert" :code "(define (fm-synthesis ctx)\n  (let* ((carrier (tick/sine (frame) 40 1.0 0))\n         (mod (tick/sine (frame) 100 0.5 0))\n         (modulated (tick/sine (frame) 40 1.0 mod)))\n    (audio/play 'synth (+ carrier modulated))))\n\n(on-tick fm-synthesis)" :note "Frequency modulation: modulation sine modulates the phase of the carrier.")
  )
  :caveats ("Period must be > 0; period ≤ 0 returns 'nan." "Phase is in radians (not degrees); 2π radians = one full cycle." "Amplitude can be negative, flipping the wave upside down; this is intentional." "Very large amplitude or very small period may produce numerical artifacts.")
  :drawbacks ("Output range is [-amp, +amp], centered at 0; use tick/osc to remap to [lo, hi]." "Phase offset is awkward to compute if you think in degrees; divide by 180·π or precompute common angles (π/2 = 1.57, π = 3.14, etc.)." "No built-in damping or filtering; very rapid oscillations may alias if sampled infrequently.")
  :usecases ("Parametric wave synthesis (audio or visual)." "Lissajous figures and orbital paths." "FM synthesis (modulating phase or amplitude)." "Fine-grained control over oscillator parameters.")
  :related ("tick/osc" "tick/triangle" "tick/lissajous" "on-tick" "frame")
  :learn (:concept "Raw sine oscillator with explicit phase and amplitude: the building block for waveform synthesis." :prerequisites ("on-tick" "frame") :progression "Master tick/sine, then learn tick/osc (bounded remapping), tick/lissajous (2-D composition), and modulation techniques (amplitude, frequency, phase)."))

(verb
  :name "tick/triangle"
  :library "tick"
  :kind "meta"
  :signature "(tick/triangle frame period) -> number"
  :summary "Generates a symmetric triangle wave oscillating between 0 and 1."
  :explanation "This verb outputs a piecewise-linear wave that ramps from 0 to 1 in the first half of the period, then ramps back down to 0 in the second half. It's smoother than tick/pulse (which is binary) but sharper than tick/sine (which has curved peaks). The triangle is useful for animations that need a smooth peak without the soft round top of a sine wave. If period ≤ 0, returns 'nan."
  :examples (
    (:tier "novice" :code "(on-tick (lambda ()\n  (let ((scale (+ 1.0 (tick/triangle (frame) 40))))\n    (entity/scale! 'pulse scale))))" :note "Sprite scales from 1.0 to 2.0 and back, with sharp peaks every 40 frames.")
    (:tier "intermediate" :code "(on-tick (lambda ()\n  (let ((intensity (tick/triangle (frame) 60)))\n    (card/draw 'glow (list 100 100 (* 200 intensity) (* 200 intensity))))))" :note "Glow effect grows to full size in 30 frames, shrinks back in 30 frames, repeating.")
    (:tier "expert" :code "(define (breathing-opacity ctx)\n  (let ((tri (tick/triangle (frame) 120)))\n    (entity/set! 'foreground 'opacity (+ 0.3 (* 0.7 tri)))))\n\n(on-tick breathing-opacity)" :note "Opacity oscillates from 0.3 to 1.0 and back, symmetric and smooth.")
  )
  :caveats ("Period must be > 0; period ≤ 0 returns 'nan." "Output is always [0, 1]; to scale to a different range, multiply and add (e.g., lo + tri·(hi−lo))." "Peaks are sharp, not rounded; if you need a smooth, curved peak, use tick/sine or tick/osc." "Slopes are linear; no easing at the turning points.")
  :drawbacks ("Fixed [0, 1] range; remapping requires arithmetic." "Linear slopes may look mechanical; sine or custom easing curves are more organic." "Discontinuous derivative at peaks; very fast animations may show a visible 'kink'.")
  :usecases ("Pulsing scale or size effects." "Intensity modulation (glow, brightness)." "Attention-drawing animations that peak sharply." "Linear up-and-down motion (e.g., bouncing with constant speed).")
  :related ("tick/sine" "tick/osc" "tick/pulse" "tick/ease" "on-tick")
  :learn (:concept "Linear triangle wave: a sharp-peaked oscillator between sine (smooth) and pulse (binary)." :prerequisites ("on-tick" "frame") :progression "Compare tick/triangle with tick/sine and tick/pulse to build intuition for waveform shape trade-offs. Use tick/ease for more sophisticated curves."))

; ─── library: time (7 verbs) ───

(verb
  :name "time/across"
  :library "time"
  :kind "null"
