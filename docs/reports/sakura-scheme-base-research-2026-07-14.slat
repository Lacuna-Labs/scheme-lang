     "cli/prompt — (cli/prompt msg [default]) -> string           — stdin readline"
     "cli/prompt-secret — (cli/prompt-secret msg) -> string       — hidden input"
     "cli/confirm — (cli/confirm msg [default]) -> boolean         — y/n"
     "cli/select — (cli/select msg choices) -> choice              — arrow-key menu"
     "cli/table — (cli/table rows [header]) -> void                — formatted table"
     "cli/color — (cli/color 'red str) -> ansi-string             — 8/16/256/truecolor"
     "cli/spinner — (cli/spinner msg thunk) -> result             — while running"
     "cli/progress-bar — (cli/progress-bar total) -> bar-handle"
     "cli/clear-screen — (cli/clear-screen) -> void"
     "cli/cursor-hide, cli/cursor-show — cursor control")
  :have
    ("Nothing (there's a bin/sakura-scheme entrypoint but no exposed CLI
     verbs for authors).")
  :missing
    ("The whole kit.  All node:readline + node:process built-ins.  Zero
     deps for basic; optional deps for color/spinner niceties.")
  :deps
    ("Optional: `chalk` (MIT) for color — or hand-roll ANSI escape codes.
     Optional: `cli-spinners` (MIT) for spinner frames.")
  :hello-world
    "(let* ((spec (cli/spec
                    'flags '((--verbose bool) (--count int 1))
                    'positional '(url)))
            (args (cli/parse (system/argv) spec)))
       (dotimes (_ (cli/get args 'count))
         (say (http/get (cli/get args 'url)))))"
  :not-base
    ("TUI framework (like tview / ratatui) — variant."
     "GUI framework — variant."))

