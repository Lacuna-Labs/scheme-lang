     "fs/rename — (fs/rename! src dst) -> #t"
     "fs/copy — (fs/copy! src dst) -> #t"
     "fs/watch — (fs/watch path handler) -> watcher           — file changes"
     "fs/tempdir — (fs/tempdir) -> string"
     "fs/tempfile — (fs/tempfile [prefix]) -> string"
     "path/join — (path/join parts...) -> string"
     "path/split — (path/split p) -> (dir base ext)"
     "path/dirname, path/basename, path/extname"
     "path/absolute — (path/absolute p) -> string"
     "path/relative — (path/relative from to) -> string"
     "path/glob — (path/glob pattern [dir]) -> list           — glob matching")
  :have
