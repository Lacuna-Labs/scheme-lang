(kit
  :audience "system"
  :subkit "sqlite"
  :ship
    ("sqlite/open — (sqlite/open path [opts]) -> db           — see :deps decision"
     "sqlite/close — (sqlite/close! db) -> #t"
     "sqlite/exec — (sqlite/exec db sql) -> #t                — no result rows"
     "sqlite/query — (sqlite/query db sql params) -> rows     — parameterized"
     "sqlite/one — (sqlite/one db sql params) -> row-or-#f    — single row"
     "sqlite/prepare — (sqlite/prepare db sql) -> stmt        — prepared"
     "sqlite/bind! — (sqlite/bind! stmt name value) -> stmt"
     "sqlite/step! — (sqlite/step! stmt) -> row-or-eof"
     "sqlite/tx — (sqlite/tx db thunk) -> result              — transaction wrapper"
     "sqlite/migrate — (sqlite/migrate db migrations) -> version — schema versioning")
  :have
    ("Nothing.")
  :missing
    ("A SQLite integration.  See :deps for the fork question.")
  :deps
    ("OPTION A: `sql.js` — MIT — pure JS SQLite compiled to WASM.
       Pros: zero native deps, cross-platform, actually IN the bundle.
       Cons: ~1.5MB WASM download, no true concurrency, all in-memory
       or filesystem-adapter-bounded.
     OPTION B: `better-sqlite3` — MIT — native compile of SQLite.
       Pros: fast, real filesystem support, mature.
       Cons: node-gyp compile at install time → we said no native.
     OPTION C: shell-out to system `sqlite3` binary.
       Pros: zero deps.
       Cons: awful ergonomics, subprocess overhead per query.
     RECOMMEND: Option A (sql.js).  Base ships one binary.  Variant can
     override to Option B for perf.")
  :hello-world
    "(let ((db (sqlite/open \":memory:\")))
       (sqlite/exec db \"create table notes (id integer primary key, body text)\")
       (sqlite/exec db \"insert into notes (body) values ('hello')\")
       (sqlite/query db \"select * from notes\" '()))
     ; -> (((id . 1) (body . \"hello\")))"
  :not-base
    ("Postgres, MySQL, MongoDB — variant + native drivers."
     "ORMs — variant."))

