     "fs/delete — (fs/delete! path) -> #t                     — decision-025 needs verb form"
     "fs/exists? — (fs/exists? path) -> boolean"
     "fs/stat — (fs/stat path) -> record{size mtime mode ...}"
     "fs/list — (fs/list dir) -> list-of-string               — non-recursive"
     "fs/walk — (fs/walk dir [filter]) -> list-of-string      — recursive"
     "fs/mkdir — (fs/mkdir! path [recursive?]) -> #t"
