(kit
  :audience "text-poetry"
  :subkits ("string-ops" "prosody" "template" "markov" "spelling"))

(kit
  :audience "text-poetry"
  :subkit "string-ops"
  :ship
    ("string/split, string/join — R7RS-adjacent, missing from R7RS-small"
     "string/trim, string/trim-left, string/trim-right"
     "string/replace, string/replace-all"
     "string/starts-with?, string/ends-with?, string/contains?"
     "string/upcase, string/downcase, string/capitalize, string/titlecase"
     "string/pad-left, string/pad-right, string/center"
     "string/words, string/lines, string/paragraphs — split by whitespace/newline/blank"
     "string/lorem — (string/lorem [words]) -> string          — placeholder"
     "string/format — (string/format fmt args...) -> string    — printf-shape"
     "string/repeat — (string/repeat str n) -> string"
     "string/reverse — R7RS-small has this"
     "string/damerau-levenshtein, string/hamming, string/jaro-winkler — string metrics"
     "string/edit-distance — synonym"
     "string/count-substring — occurrences")
  :have
    ("R7RS-small has string, string?, string-length, string-ref, string->symbol,
     symbol->string, make-string, string-copy, substring, string-append,
     list->string, string->list, string=?, string<?, etc.  Missing all the
     idiomatic split/join/trim/replace/contains? verbs.")
  :missing
    ("The idiomatic string ops.  All ~15 lines each, zero deps.  We should
     ship these — every scripting language does, and R7RS-small alone is
     famously austere for text work.")
  :hello-world
    "(map string/capitalize
          (string/words \"the quick brown fox\"))
     ; -> (\"The\" \"Quick\" \"Brown\" \"Fox\")"
  :not-base
    ("ICU-level Unicode segmentation — variant + native."
