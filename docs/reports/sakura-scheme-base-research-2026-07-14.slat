;; ═══════════════════════════════════════════════════════════════
;; SECTION 3 — WHAT'S IN BASE VS WHAT'S IN A VARIANT
;; ═══════════════════════════════════════════════════════════════

(research :section 3 :title "Base vs variant boundary")

(rule
  :name "the-base-boundary"
  :statement
    "A verb belongs in Base if and only if:
       (a) it's pure JS or uses a permissively-licensed npm package we've read;
       (b) it does not require a native compile (no node-gyp);
       (c) it does not require an external service, network host, or account;
       (d) it does not require credentials, an API key, or a login;
       (e) it does not require hardware (audio device, GPU, camera, sensor).
     A verb that violates any of (a)–(e) moves to a variant.  There is no
     partial exception: if the verb needs a variant to make it real, it is
     a variant verb.")

(rule
  :name "one-binary-invariant"
  :statement
    "The Base binary is one JS bundle.  When a kid downloads
     sakura-scheme, everything in Base works with no post-install step.
     If a proposed verb breaks this — say it needs `pip install` or
     `docker pull` or `brew install libfoo` — the verb is not in Base.
     A variant may set up its own install story.")

(rule
  :name "the-transparent-fallback"
  :statement
    "Where Base can ship a pure-JS impl of something a variant might
     later override natively (e.g. sql.js in Base, better-sqlite3 in a
     variant), the Scheme surface stays the same.  A cart written against
     Base's sqlite/* verbs runs identically on Curator with the native
     driver.  This is the whole point of the adapter layer.")

(examples
  :yes-in-base
    ("http/get               — Node fetch built-in"
     "sqlite/open            — sql.js WASM (bundled)"
     "server/make            — node:http built-in"
     "ws/connect             — `ws` npm package, MIT, permissive"
     "gzip/encode            — node:zlib built-in"
     "json/parse, csv/parse  — JSON is built-in; CSV is 100 LOC"
     "hash/sha256, hash/hmac — node:crypto built-in"
     "prosody/syllable-count — rules-based, no dict"
     "bio/translate          — codon table is 64 lines"
     "astro/planet-position  — truncated VSOP87 series in a data file")

  :no-in-base
    ("audio/mic-in           — hardware, variant"
     "gpu/compile-shader     — GPU, variant"
     "ai/embed               — needs sidecar, Curator"
     "ai/decide              — needs sidecar, Curator"
     "afford/deep-think      — external service, Curator"
     "card/emit              — Curator marketplace concept"
     "shop/list-items        — needs eBay/Etsy credentials, Curator"
     "cortex/write           — Cortex external, comes back as an adapter shim"
     "postgres/connect       — native driver, variant"
     "docker/run             — external binary, Lacuna variant"))

;; ═══════════════════════════════════════════════════════════════
;; SECTION 4 — VERB NAMING + STYLE
;; ═══════════════════════════════════════════════════════════════

(research :section 4 :title "Verb naming + style")

(style-rules
  :from ("decision-013" "decision-001" "decision-002" "decision-014" "decision-018")
  :rules
    ("kebab-case names throughout"
     "namespace prefix + / + verb: `sqlite/open`, `bio/translate`"
     "predicates end in ? — `sqlite/exists?`, `regex/matches?`"
     "mutators end in ! — `hash-set!`, `sqlite/exec!`, `fs/write!`"
     "positional args ≤5; alist or hash-table as last arg beyond"
     "no polymorphic `get`; shape-specific accessors — hash-ref, vector-ref, cons"
     "return values match declared :signature exactly (no descriptor lies)"
     "all example code in the reference uses only R7RS-small forms + registered verbs"
     "no [square brackets]; no true/false; no first/rest; no bare nil"
     "SRFI-1 helpers are NOT in Base; users compose from named-let + fold"))

(naming-audit
  :proposal-lints-passing-so-far
    ("Every verb in Section 2 uses namespace/verb form."
     "Mutators (server/stop, fs/write, cron/cancel) end in ! per convention."
     "Predicates end in ? (spell/check, prosody/haiku?, sqlite/exists?)."
     "No `get` in any verb name I proposed — all use shape-specific names.")
  :places-i-was-tempted-to-cheat
    ("cli/get in the hello-world example — should be `hash-ref` or a
      record accessor like cli-args-count.  I'll fix that phrasing when the
      spec lands as an actual reference entry."
     "date/plus and date/minus — reads well but `date/add` and `date/sub`
      might be more consistent with math naming.  Bikeshed at spec time."
     "process/exec vs process/spawn — the naming should stay parallel with
      node:child_process to avoid surprise for people coming from JS."))

