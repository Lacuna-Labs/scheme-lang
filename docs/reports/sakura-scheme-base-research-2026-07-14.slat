;; ═══════════════════════════════════════════════════════════════
;; SAKURA SCHEME BASE — BREADTH RESEARCH · 2026-07-14
;;
;; Lane:   Sakura Scheme Base Research (mapping the batteries)
;; Author: Base-Research lane (Claude Opus 4.7, 1M-ctx, dispatched by Alfred)
;; Date:   2026-07-14
;;
;; Alfred, dispatch quote:
;;   "Scheme isn't just for games. It's for all the ideas our little
;;    language can do in this env. Separate our commercial concerns in
;;    this context while maximizing the language itself and the tooling
;;    around it."
;;
;; ─── What this file is ────────────────────────────────────────────
;; A written proposal. Not code, not a spec, not a decision — a map of
;; the surface Sakura Scheme Base could plausibly cover if the goal is
;; "batteries Python has, applied to arts + math + science + CS +
;; system-building + writers/poets."
;;
;; Every proposal here is scoped so it can be turned into a lane brief
;; later. Nothing here modifies src/ or the reference manual.
;;
;; ─── Composition with prior doctrine ──────────────────────────────
;;   Base + Variant doctrine (2026-07-14 evening)  —  Base is stable;
;;     Curator and Lacuna subclass. All verbs published in the reference.
;;     Cortex is external. Adapters translate without an LLM.
;;   Compliance directive 2026-07-14  —  R7RS-small first, no diverging,
;;     fix in book. Every new verb here obeys.
;;   Reference-manual-is-the-language  —  If a verb is proposed here and
;;     later shipped, it lands in the reference before it lands in src/.
;;   Operators-are-first-class-Scheme-authors  —  Every verb in Base is
;;     available to operator scripts, same runtime as Sakura.
;;
;; ─── File format ──────────────────────────────────────────────────
;; SLAT.  One record per line-blob.  Comments start with `;`.  Each
;; section is a (research :section "..." ...) record for programmatic
;; consumption.  Prose reads left-to-right as normal.
;; ═══════════════════════════════════════════════════════════════

(research
  :doc-id "sakura-scheme-base-research-2026-07-14"
  :status "draft-for-alfred-review"
  :audience "Alfred (Scheme + product lead), plus future lane briefs"
  :composes-with
    ("project_sakura_scheme_base_variant_doctrine_2026_07_14"
     "docs/COMPLIANCE-DIRECTIVE-2026-07-14.slat"
     "docs/ENGINEERING-DECISIONS.slat"
     "docs/CONVENTION.slat"
     "docs/reports/descriptor-shape-sweep-2026-07-14.slat")
  :non-goals
    ("Not implementing anything."
     "Not touching src/."
     "Not editing SAKURA-SCHEME-REFERENCE.slat."
     "Not enumerating every possible verb — enumerating the shape of the roster."
     "Not committing Alfred to any of it — this is a menu, not an order."))

;; ═══════════════════════════════════════════════════════════════
;; SECTION 1 — THE FRAMING
;; ═══════════════════════════════════════════════════════════════

(research :section 1 :title "The framing")

;; ─── One-sentence pitch ───────────────────────────────────────────
;;
;;   Sakura Scheme Base is a small, self-contained, R7RS-small-conformant
;;   Scheme with the batteries Python has — arts, math, science, CS,
;;   system-building, prose — one binary, no native modules, all verbs
;;   published in the reference manual so a kid can pick it up and never
;;   hit a wall marked "install a package first."
;;
;; Every phrase in that sentence carries weight:
;;
;;   "small"               — 145 R7RS-small procs + ~600 base verbs total.
;;                            Not thousands. A kid can read the reference.
;;   "self-contained"      — one JS bundle, one binary, no compilation.
;;                            No node-gyp, no Python sidecar, no CUDA.
;;   "R7RS-small-conformant" — the base tower reads like Scheme.  A
;;                             reader who learned Chez or Chibi can sit
;;                             down and write.
;;   "batteries Python has" — HTTP, JSON, SQLite, dates, regex, hashing,
;;                            gzip, CSV, testing, CLI — the everyday.
;;   "arts, math, ...prose" — six audiences, six kits, one language.
;;   "one binary"          — a kid on a chromebook can run it.
;;   "all verbs published in the reference" — no hidden surface, no
;;                            "the Curator variant has more."  If it's
;;                            in Base, it's documented in Base.
;;   "the kid never hits a wall" — Alfred's north star.  The wall
;;                            marked "install a package" is the moment
;;                            Apple BASIC lost the kid.  We don't
;;                            build that wall.

;; ─── Audience map ─────────────────────────────────────────────────
;;
;; Base serves seven audiences.  Each audience is a person, not a
;; feature bucket.

(research
  :subsection "audience-map"
  :audiences
    ((arts        "kid + hobbyist making games, animation, drawings, tunes")
     (math        "kid learning arithmetic; college student doing linear algebra; researcher toy-modelling")
     (science     "high-schooler simulating a pendulum; biology student aligning DNA; astro hobbyist locating Jupiter tonight")
     (cs          "CS major implementing a red-black tree for fun; language nerd writing a tiny interp; the operator who wants a retry queue")
     (system      "shop operator whose cart POSTS to Etsy nightly; the SRE who wants to ping URLs and roll up latencies; the writer who wants to publish a static site")
     (text-poetry "poet counting syllables; writer using templates; teacher generating quizzes; scholar analyzing scansion")
     (education   "Alfred teaching Scheme via the reference manual; the kid from North Georgia after school; a college class using Sakura for the semester")))

;; ─── Doctrine (composed from prior decisions) ─────────────────────

(research
  :subsection "doctrine"
  :points
    ("Base is stable.  Any change forces every variant to update — that friction
     is the FEATURE, not the bug.  Variants version independently while pinned
     to a base version."
     "Variants subclass base.  They can refuse features, adopt others, modify
     many, add their own.  Refusing is a first-class operation."
     "All verbs published in the Sakura Scheme reference.  The reference is
     one document; a variant is a lens on top.  Variants tag entries with
     :variant.  A verb never disappears from the reference; it moves shelves."
     "Adapters translate between variants without an LLM.  Small contract
     files (SLAT) live at engine/adapters/*.slat.  A validator can rewrite a
     Curator program to Base, mechanically, per rule."
     "Cortex is external.  Sakura Scheme's CLI can call it via shell/API;
     Cortex is not IN Sakura Scheme.  Any verb that requires Cortex is a
     variant verb, not Base."
     "Anything requiring a native compile, an external service, credentials,
     or hardware is a variant verb, not Base.  Base is pure JS + permissively-
     licensed npm packages we've read."
     "Every verb in Base has 5 tiered reference examples (novice→master),
     obeys R7RS-small in its example code, and lists what it :raises."))

;; ═══════════════════════════════════════════════════════════════
;; SECTION 2 — AUDIENCE-BY-AUDIENCE KIT PROPOSALS
;; ═══════════════════════════════════════════════════════════════

(research :section 2 :title "Audience-by-audience kit proposals")

;; Each kit proposal has five parts:
;;   :ship          — what Base ships (verb roster with signatures)
;;   :have          — what already exists in the current reference
;;   :missing       — the gap, specifically named
;;   :hello-world   — one runnable example
;;   :not-base      — what belongs in a variant instead

;; ─── ARTS KIT ─────────────────────────────────────────────────────

(kit
  :audience "arts"
  :subkits ("fantasy-console" "music" "visual")

  :fantasy-console
    (:ship
       ("btn         — (btn code)              -> boolean, is-button-held"
        "btnp        — (btnp code [delay [rate]]) -> boolean, is-button-just-pressed"
        "_init/_update/_draw loader — the PICO-8-style entry-point contract"
        "print       — (print str [x y [col]]) -> void, framebuffer text"
        "spr         — (spr n x y [w h [flip-x flip-y]]) -> void, atlas sprite"
        "sfx         — (sfx n [channel [offset [length]]]) -> void, sound bank"
        "music       — (music n [fade-ms [channel-mask]]) -> void, music track"
        "camera      — (camera [x y]) -> void, framebuffer offset"
        "palt        — (palt [col transp?]) -> void, transparent color"
        "pal         — (pal [src dst [palette]]) -> void, palette remap"
        "flr/ceil    — (flr x) / (ceil x) — arts idioms alongside R7RS floor")
     :have
       ("Framebuffer runtime largely present (see :library \"world\", \"surface\", \"sprite\")."
        "Sound: audio/*, note/*, synth/*, beat/*, radio/* — all substrate-deferred per descriptor-shape-sweep."
        "Sprite atlas and camera — partial (sprite/* has 3 entries)."
        "Palette — not clearly present.")
     :missing
       ("Complete PICO-8-shaped input verbs (btn/btnp), _init/_update/_draw loader hook."
        "print-as-framebuffer-verb (not the R7RS-small `write` — a graphical print)."
        "Palette remap primitives."
        "A minimal, wired sound bank (sfx N) even before the full synth story lands.")
     :hello-world
       "(define (_draw)
          (cls 0)
          (spr 1 (* 8 (sin (/ (tick) 30))) 40)
          (print \"hi\" 30 60 7))
        (define (_update) (if (btnp 5) (say \"jump!\")))
        (game-loop!)"
     :not-base
       ("Card lifecycle (card/*) — Curator variant."
        "Marketplace hooks — Curator variant."
        "GPU shaders — deferred, no variant yet."
        "MIDI-adjacent tracker (song/track/pattern beyond tone/note/chord/melody)
         — open question 2 for Alfred; leaning Curator variant."))

  :music
    (:ship
       ("tone   — (tone freq dur) -> descriptor              — pure sine at freq for dur ms"
        "note   — (note pitch dur) -> descriptor             — MIDI-pitch or note-name"
        "chord  — (chord notes dur) -> descriptor            — parallel notes"
        "melody — (melody notes) -> descriptor               — sequential notes"
        "beat   — (beat pattern bpm) -> descriptor           — kick/snare/hi-hat grid"
        "rhythm-parse  — (rhythm-parse str) -> pattern       — \"x-x-x---x-x-x---\""
        "pitch->hz     — (pitch->hz p) -> number             — MIDI to Hz"
        "name->pitch   — (name->pitch \"C4\") -> number      — note-name to MIDI"
        "mix    — (mix voice ...) -> descriptor              — parallel voices"
        "render-wav    — (render-wav voice path) -> #t       — synth to WAV file")
     :have
       ("audio (13) + note (3) + synth (9) + beat (1) + radio (14) — 40+ entries.
         All descriptor-shape-deferred per the sweep (yuki lane assignment).")
     :missing
       ("Wired substrate — a small pure-JS oscillator + envelope + WAV writer
         so `render-wav` produces bytes without shell-out."
        "A permissively-licensed sample bank the sfx/music verbs draw from."
        "Coord with Alfred's open question 2 on music-kit depth.")
     :hello-world
       "(define hello-tune
          (melody '((\"C4\" 250) (\"E4\" 250) (\"G4\" 250) (\"C5\" 500))))
        (render-wav hello-tune \"hello.wav\")"
     :not-base
       ("Full DAW — never.  Even in a variant, this is out of scope for a Scheme."
        "Live audio-in (microphone) — hardware, variant."))

  :visual
    (:ship
       ("cls     — (cls [col]) -> void                       — clear framebuffer"
        "pset    — (pset x y col) -> void                    — plot one pixel"
        "pget    — (pget x y) -> col                         — read one pixel"
        "line    — (line x0 y0 x1 y1 col) -> void            — Bresenham"
        "rect    — (rect x0 y0 x1 y1 col) -> void            — outline"
        "rectfill— (rectfill x0 y0 x1 y1 col) -> void        — filled"
        "circ    — (circ x y r col) -> void                  — Bresenham circle"
        "circfill— (circfill x y r col) -> void              — filled"
        "poly    — (poly points col) -> void                 — polyline"
        "fill    — (fill x y col) -> void                    — scanline flood-fill"
        "text/measure — (text/measure str) -> (w h)          — pixel bounds"
        "framebuffer/save — (framebuffer/save path) -> #t    — PNG dump"
        "framebuffer/load — (framebuffer/load path) -> fb    — PNG load")
     :have
       ("surface (5) + framebuffer verbs threaded through world/game — most
         present as descriptors, deferred wire-up (hana lane per sweep).")
     :missing
       ("PNG encoder/decoder — pure JS.  npm: `upng-js` (MIT) or `pngjs`
         (MIT).  Or hand-roll a minimal PNG encoder for framebuffers."
        "Scanline flood-fill — not registered anywhere I can find.")
     :hello-world
       "(cls 0)
        (for-each (lambda (a)
                    (let ((x (+ 64 (* 40 (cos a))))
                          (y (+ 64 (* 40 (sin a)))))
                      (pset x y 7)))
                  (map (lambda (i) (/ (* i 3.14159) 60)) (range 0 120)))
        (framebuffer/save \"circle.png\")"
     :not-base
       ("SVG rendering — variant or npm shell-out."
        "3D — variant."
        "GPU shaders — variant.")))

;; ─── MATH KIT ─────────────────────────────────────────────────────

(kit
  :audience "math"
  :subkits ("arithmetic" "linear-algebra" "calc" "stat" "combinatorics" "number-theory" "geometry" "topology" "symbolic")

  :ship
    ("Math is already deep — the current reference has 25+300+ verbs in the
      math family (see :library counts).  The proposal for Base is: audit
      what's descriptor-shape-deferred vs wired, then WIRE the deferred bits
      per the hana-lane assignment.  New surface is small; wire-up is large.")

  :have
    ("linalg (20) — linear-algebra verbs"
     "calc (30)  — calculus (derivative, integral, taylor, limit — many deferred)"
     "stat (18)  — descriptive stats + basic distributions"
     "comb (13)  — combinatorics (permutations, combinations, factorial)"
     "nt (29)    — number theory (primes, gcd, factor, totient)"
     "geom (57)  — geometry (points, lines, polygons)"
     "topo (27)  — topology (rin-topo lane)"
     "sym (20)   — symbolic (via marcus lane; deferred)"
     "num (2)    — numerics"
     "seq (12)   — sequences"
     "vec (13)   — vectors"
     "matrix (13) — matrix ops"
     "curve (37)  — curves"
     "exact (19)  — exact-arithmetic tooling (bounded by decision-011)"
     "complex (18) — complex numbers (bounded by decision-021)"
     "alg (59)    — algebra"
     "math (25)   — general math"
     "solve (13)  — solvers"
     "const (8)   — mathematical constants (pi, e, ...)")

  :missing
    ("Explicit stats-for-science distinctions — t-test, chi-square, ANOVA,
      linear-regression, curve-fit (Levenberg-Marquardt).  Present as symbols
      inside stat/*, need explicit wired verbs."
     "Explicit ODE integrator — RK4, adaptive-step, would live in calc/*
      but does not seem to be there.  Feeds science kit."
     "FFT — not registered.  Base kit unlocks physics + audio analysis.
      npm: `fft.js` (MIT).  Or hand-roll a radix-2 Cooley-Tukey."
     "Random-number primitives beyond `random` — `random-int`, `random-choice`,
      `random-normal` (Box-Muller), `random-seed!`, `srand`.  Present in
      base.js partially; unify."
     "BigInt escape hatch — decision-011 says NO to silent BigInt, but a
      `bigint/*` namespace that's opt-in would let number-theorists compute
      large factorials without a subtle overflow bug.  Open question for
      Alfred.")

  :hello-world
    "(let* ((xs '(1 2 3 4 5))
            (mean-x (/ (apply + xs) (length xs)))
            (var-x (/ (apply + (map (lambda (x) (expt (- x mean-x) 2)) xs))
                     (length xs))))
       (list 'mean mean-x 'variance var-x 'stddev (sqrt var-x)))"

  :not-base
    ("Symbolic CAS beyond simple simplification — variant (marcus lane already
      is a specialty).  Base carries enough sym/* for algebra tutorials."
     "Numerical linear-algebra at BLAS speed — variant, native compile territory."
     "Machine-precision arbitrary-precision — variant."))

;; ─── SCIENCE KIT ──────────────────────────────────────────────────

(kit
  :audience "science"
  :subkits ("physics" "chemistry" "biology" "astronomy" "stats-for-science"))

(kit
  :audience "science"
  :subkit "physics"
  :ship
    ("phys/quantity — (phys/quantity value unit) -> quantity            — 5.0 :meters"
     "phys/q+, phys/q-, phys/q*, phys/q/, phys/q= — dimensional arithmetic"
     "phys/same-dimension? — dimensional-consistency check"
     "phys/units — (phys/units 'SI) -> unit-registry                     — pluggable"
     "phys/convert — (phys/convert q 'from 'to) -> quantity              — unit conversion"
     "phys/constant — (phys/constant 'c) -> quantity                     — c, h, hbar, k, G, epsilon0, ..."
     "phys/dimension — (phys/dimension q) -> (:L 1 :T -2)                — decompose"
     "phys/kinematics — (phys/kinematics x0 v0 a t) -> quantity          — closed-form"
     "phys/rk4 — (phys/rk4 dydt y0 t0 t1 dt) -> trajectory               — ODE integrator"
     "phys/nbody — (phys/nbody bodies steps dt) -> trajectory            — gravitational sim"
     "phys/pendulum — (phys/pendulum length gravity t) -> angle"
     "phys/lagrangian-action — (phys/lagrangian-action L path) -> action"
     "phys/uncertainty-add, phys/uncertainty-mul — error propagation")
  :have
    ("phys (19) — dimension, kinematics, kinetic-energy, lagrange-*, gravity,
     nbody, quantity, rlc-damping, same-dimension?, uncertainty-* — all
     descriptor-shape-deferred; substrate not yet wired.")
  :missing
    ("Full unit-conversion table (SI, imperial, natural, atomic units)."
     "Numerical ODE integrator (RK4 minimum, adaptive step ideal)."
     "Coordinate-system transformations (Cartesian ↔ polar ↔ spherical ↔ cylindrical)."
     "A small canonical constants table with cited sources.")
  :hello-world
    "(define pendulum
       (lambda (theta omega t)
         (let ((g 9.81) (L 1.0))
           (list omega (- (* (/ g L) (sin theta)))))))
     (define trajectory (phys/rk4 pendulum '(0.1 0) 0 10 0.01))
     (plot/xy trajectory)"
  :not-base
    ("Molecular dynamics — variant or shell-out."
     "Fluid dynamics — variant."
     "Quantum simulation past 2-state — variant."))

(kit
  :audience "science"
  :subkit "chemistry"
  :ship
    ("chem/element — (chem/element 'H) -> record{symbol Z name mass electronegativity ...}"
     "chem/atomic-weight — (chem/atomic-weight 'C) -> number             — grams/mol"
     "chem/molar-mass — (chem/molar-mass \"H2O\") -> number"
     "chem/moles — (chem/moles grams formula) -> number"
     "chem/formula-counts — (chem/formula-counts \"C6H12O6\") -> alist"
     "chem/balance — (chem/balance \"H2 + O2 -> H2O\") -> equation      — balanced"
     "chem/pH — (chem/pH concentration) -> number                        — -log10"
     "chem/pOH — (chem/pOH concentration) -> number"
     "chem/henderson-hasselbalch — (chem/hh pKa acid base) -> pH"
     "chem/kinetics — (chem/kinetics 'first-order k C0 t) -> concentration"
     "chem/arrhenius — (chem/arrhenius A Ea T) -> rate-constant"
     "chem/equilibrium — (chem/equilibrium 'Kc reactants products) -> Q or K")
  :have
    ("chem (5) — atomic-weight, balance, formula-counts, molar-mass, moles.
     All descriptor-shape-deferred (jess lane per sweep).")
  :missing
    ("Element table (117 elements + isotope data).  Bundle as SLAT data file."
     "Balancing algorithm — Gauss-Jordan over stoichiometry matrix."
     "pH + kinetics + equilibrium — pure math, small code."
     "SMILES/InChI parsing — deferred to variant; too much surface for Base.")
  :hello-world
    "(define glucose \"C6H12O6\")
     (list 'formula glucose
           'molar-mass (chem/molar-mass glucose)
           'atoms (chem/formula-counts glucose))
     ; -> (formula \"C6H12O6\" molar-mass 180.156 atoms ((C . 6) (H . 12) (O . 6)))"
  :not-base
    ("Molecular structure visualization — variant."
     "Docking + MD — variant + shell-out."
     "Quantum chemistry — variant + shell-out."))

(kit
  :audience "science"
  :subkit "biology"
  :ship
    ("bio/complement — (bio/complement \"ATCG\") -> \"TAGC\""
     "bio/reverse-complement — (bio/reverse-complement \"ATCG\") -> \"CGAT\""
     "bio/transcribe — (bio/transcribe \"ATCG\") -> \"AUCG\"               — DNA→RNA"
     "bio/translate — (bio/translate \"AUGGCU\") -> \"MA\"                 — RNA→protein"
     "bio/codon-table — (bio/codon-table) -> alist                        — genetic code"
     "bio/gc-content — (bio/gc-content \"ATCG\") -> number                — fraction"
     "bio/hamming — (bio/hamming s1 s2) -> integer                        — mismatch count"
     "bio/levenshtein — (bio/levenshtein s1 s2) -> integer                — edit distance"
     "bio/align-global — (bio/align-global s1 s2 [scoring]) -> alignment  — Needleman-Wunsch"
     "bio/align-local — (bio/align-local s1 s2 [scoring]) -> alignment    — Smith-Waterman"
     "bio/find-orfs — (bio/find-orfs seq) -> list-of-orfs                 — reading frames"
     "bio/reverse-translate — (bio/reverse-translate protein) -> ambiguous-DNA"
     "bio/molecular-weight — (bio/molecular-weight seq) -> number         — protein or nucleotide")
  :have
    ("Nothing.  bio/* is not a registered library today.")
  :missing
    ("The entire kit.  ~13 verbs, ~400-600 lines of pure JS, zero deps.
     Codon table is 64 entries — bundle inline.  Alignments are textbook
     DP algorithms.")
  :hello-world
    "(let ((dna \"ATGGCCATTGTAATGGGCCGCTGAAAGGGTGCCCGATAG\"))
       (list 'gc (bio/gc-content dna)
             'orfs (bio/find-orfs dna)
             'protein (bio/translate (bio/transcribe dna))))"
  :not-base
    ("BLAST-scale search — variant + native + external DB."
     "Phylogenetics — variant."
     "Structure prediction — external service."))

(kit
  :audience "science"
  :subkit "astronomy"
  :ship
    ("astro/julian-date — (astro/julian-date year month day [hour min sec]) -> jd"
     "astro/date-from-julian — inverse"
     "astro/gst — (astro/gst jd) -> hours                                 — Greenwich sidereal time"
     "astro/lst — (astro/lst jd longitude) -> hours                       — local sidereal"
     "astro/ra-dec->alt-az — (astro/ra-dec->alt-az ra dec lat lst) -> (alt az)"
     "astro/alt-az->ra-dec — inverse"
     "astro/ecliptic->equatorial — coord xform"
     "astro/equatorial->ecliptic — inverse"
     "astro/precession — (astro/precession ra dec from-epoch to-epoch) -> (ra' dec')"
     "astro/planet-position — (astro/planet-position 'mars jd) -> (ra dec)  — VSOP87 truncated"
     "astro/moon-phase — (astro/moon-phase jd) -> (fraction age illumination)"
     "astro/sun-position — (astro/sun-position jd) -> (ra dec)"
     "astro/kepler-solve — (astro/kepler-solve M e) -> E                    — Newton's method"
     "astro/rise-set — (astro/rise-set body lat lon jd) -> (rise transit set)")
  :have
    ("Nothing.  astro/* is not a registered library today.")
  :missing
    ("The entire kit.  Truncated VSOP87 series for planets is a data file
     (~2000 rows); coord conversions are trig; Kepler solver is 20 lines
     of Newton iteration.  Zero deps.")
  :hello-world
    "(let* ((now (astro/julian-date 2026 7 14 22 30 0))
            (jup (astro/planet-position 'jupiter now)))
       (astro/ra-dec->alt-az (car jup) (cadr jup) 40.7 (astro/lst now -74.0)))"
  :not-base
    ("Full VSOP87 (thousands of terms) — variant."
     "Ephemeris downloads (JPL Horizons) — variant + net."
     "Deep-sky catalogs — variant + data files."))

(kit
  :audience "science"
  :subkit "stats-for-science"
  :ship
    ("stat/t-test-one — (stat/t-test-one xs mu) -> record{t df p-value}"
     "stat/t-test-two — (stat/t-test-two xs ys [equal-var?]) -> record"
     "stat/paired-t   — (stat/paired-t xs ys) -> record"
     "stat/chi-square — (stat/chi-square observed expected) -> record{chi2 df p}"
     "stat/anova-one  — (stat/anova-one groups) -> record{F df1 df2 p}"
     "stat/regression — (stat/regression xs ys) -> record{slope intercept r2 se}"
     "stat/mult-regression — (stat/mult-regression X y) -> record            — matrix form"
     "stat/curve-fit  — (stat/curve-fit model params xs ys) -> record         — Levenberg-Marquardt"
     "stat/confidence-interval — (stat/ci xs [alpha]) -> (lo hi)"
     "stat/pearson-r  — (stat/pearson-r xs ys) -> r"
     "stat/spearman-r — (stat/spearman-r xs ys) -> rho"
     "stat/bootstrap  — (stat/bootstrap xs stat [samples]) -> distribution"
     "stat/normal-cdf, stat/normal-pdf, stat/t-cdf, stat/chi2-cdf, stat/f-cdf — distributions")
  :have
    ("stat (18) — mean, variance, stddev, median, quantile, etc.  Present at
     descriptive level.")
  :missing
    ("Inferential statistics — t-test, chi-square, ANOVA, regression.
     Curve-fitting.  Bootstrap.  Distribution CDFs beyond normal.
     All are textbook, no deps beyond what's already in math/*.")
  :hello-world
    "(let* ((control  '(23.1 24.0 22.8 24.5 23.9))
            (treatment '(26.2 27.1 25.8 27.0 26.5))
            (result (stat/t-test-two control treatment)))
       (list 'p (stat/record-ref result 'p-value)
             'significant? (< (stat/record-ref result 'p-value) 0.05)))"
  :not-base
    ("Time-series with hidden states (Kalman, HMM) — variant."
     "Bayesian inference beyond conjugate priors — variant."))

;; ─── CS KIT ───────────────────────────────────────────────────────

(kit
  :audience "cs"
  :subkits ("algorithms" "data-structures" "pl-theory" "formal-methods" "systems"))

(kit
  :audience "cs"
  :subkit "algorithms"
  :ship
    ("sort/quicksort, sort/mergesort, sort/heapsort — (sort/* xs [cmp]) -> xs"
     "sort/topological — (sort/topological graph) -> ordering or #f"
     "search/binary — (search/binary vec key [cmp]) -> index or #f"
     "search/bfs — (search/bfs start neighbors goal?) -> path or #f"
     "search/dfs — (search/dfs start neighbors goal?) -> path or #f"
     "search/dijkstra — (search/dijkstra graph start [end]) -> distances-and-paths"
     "search/a-star — (search/a-star start neighbors heuristic goal?) -> path"
     "graph/adjacency — (graph/adjacency edges) -> graph"
     "graph/scc — Tarjan's strongly-connected-components"
     "graph/mst — Kruskal's or Prim's minimum spanning tree"
     "graph/max-flow — Ford-Fulkerson or Edmonds-Karp"
     "regex-nfa — pedagogical NFA regex (companion to system's regex verb)"
     "dp/lcs — longest common subsequence"
     "dp/knapsack — 0/1 knapsack")
  :have
    ("Currently R7RS-small ships nothing named `sort`.  base.js has for-each,
     map, range.  Users write their own sorts.  Ada-lane and topo lanes have
     graph-shaped verbs but they're descriptor-deferred.")
  :missing
    ("Almost the entire kit.  These are algorithms taught in CS 101.  A
     Scheme without them makes people write them by hand or reach for another
     language.  Alfred's north star says: they should be here.")
  :hello-world
    "(let* ((graph '((A . (B C)) (B . (C D)) (C . (D)) (D . ())))
            (path (search/bfs 'A (lambda (n) (cdr (assq n graph))) (lambda (n) (eq? n 'D)))))
       path)  ; -> (A B D)"
  :not-base
    ("Parallel algorithms — no threads in Scheme surface."
     "GPU-accelerated anything — variant + native."))

(kit
  :audience "cs"
  :subkit "data-structures"
  :ship
    ("Records:      define-record-type (SRFI-9, already have per decision-009)"
     "Hash tables:  hash-ref, hash-set!, hash-delete! (SRFI-69, already have)"
     "Vectors:      vector-ref, vector-set! (R7RS, already have)"
     "Trees:        tree/make, tree/insert, tree/find, tree/delete, tree/walk"
     "Binary heap:  heap/make, heap/push!, heap/pop-min, heap/peek"
     "Priority q:   pq/make, pq/push!, pq/pop!, pq/empty?"
     "Trie:         trie/make, trie/insert!, trie/find, trie/prefix-search"
     "Union-find:   uf/make, uf/find, uf/union!, uf/same?"
     "Deque:        deque/make, deque/push-front!, deque/push-back!, deque/pop-*"
     "Persistent map: pmap/empty, pmap/insert, pmap/lookup, pmap/delete   (Bagwell HAMT)"
     "Sorted set:   sset/make, sset/insert, sset/member?, sset/nearest"
     "Bit-vector:   bitvec/make, bitvec/ref, bitvec/set!, bitvec/count"
     "Bloom filter: bloom/make, bloom/add!, bloom/maybe-contains?")
  :have
    ("Records + hash tables + vectors + lists + pairs.  Nothing else.")
  :missing
    ("Trees, heaps, tries, union-find, deques, persistent maps, sorted sets,
     bit-vectors, bloom filters.  All are 30-100 lines of Scheme each — a
     kid can read the implementation.  Ship them wired in JS for speed;
     document the R7RS-small version alongside as :history.")
  :hello-world
    "(let ((h (heap/make <)))
       (heap/push! h 5) (heap/push! h 2) (heap/push! h 8) (heap/push! h 1)
       (let loop ((acc '()))
         (if (heap/empty? h) (reverse acc)
             (loop (cons (heap/pop-min h) acc)))))  ; -> (1 2 5 8)"
  :not-base
    ("Concurrent data structures — no threads."
     "Disk-backed structures (LSM, B-tree on disk) — variant + fs."))

(kit
  :audience "cs"
  :subkit "pl-theory"
  :ship
    ("interp/lambda — pedagogical lambda-calc interp — (interp/lambda expr) -> normal-form"
     "interp/mini-scheme — a mini Scheme interpreter in Scheme (SICP §4.1 shape)"
     "type/check — pedagogical Hindley-Milner type inference over mini-ml AST"
     "type/unify — unification algorithm"
     "parse/pratt — Pratt parser combinator"
     "parse/peg — PEG parser combinator"
     "cek/machine — CEK abstract machine (SICP §5)"
     "cesk/machine — CESK with store"
     "combinator/S, combinator/K, combinator/I — SKI combinators"
     "y-combinator — the fixed-point demo")
  :have
    ("Nothing explicitly.  Users can hand-roll from R7RS-small.")
  :missing
    ("A pedagogical PL-theory kit is not just nostalgia — it turns Sakura
     Scheme into a tool for teaching languages.  Every verb here is an
     example another lang would ship as `pip install`.  We can ship them
     in-language.")
  :hello-world
    "(define fact-y
       ((y-combinator)
        (lambda (rec)
          (lambda (n) (if (= n 0) 1 (* n (rec (- n 1))))))))
     (fact-y 6)  ; -> 720"
  :not-base
    ("Compiler for another target lang — variant.  A Scheme→JS compiler is a
      months-long project, not a Base verb."
     "LLVM bindings — variant + native."))

(kit
  :audience "cs"
  :subkit "formal-methods"
  :ship
    ("contract/require — (contract/require pred) -> void        — precondition or raise"
     "contract/ensure — (contract/ensure pred) -> void          — postcondition"
     "contract/invariant — (contract/invariant pred) -> void    — for loops + records"
     "contract/->  — (contract/-> arg-preds ret-pred) fn        — wrap a fn with checks"
     "assert — (assert expr) -> void                             — hard failure with msg"
     "prop/check — (prop/check gen pred [runs]) -> result        — QuickCheck-lite"
     "prop/gen-int, prop/gen-list, prop/gen-string, prop/gen-alist — generators"
     "prop/shrink — shrinking for failed cases"
     "logic/vars, logic/=, logic/run — miniKanren-shape logic programming (small)")
  :have
    ("Nothing formally.  R7RS `error` exists.")
  :missing
    ("Contracts + property-testing is the CS student's next tool after unit
     tests.  Small footprint (~300 lines JS), zero deps.  MiniKanren is a
     stretch — worth including as demo pedagogy per SICP tradition.")
  :hello-world
    "(define (safe-divide a b)
       (contract/require (number? a))
       (contract/require (number? b))
       (contract/require (not (= b 0)))
       (/ a b))
     (prop/check (prop/gen-int 1 100)
                 (lambda (n) (= (* 2 (/ n 2)) n)))  ; -> passes for evens, fails, shrinks"
  :not-base
    ("SAT/SMT solvers — variant + external."
     "Proof assistants — variant."))

(kit
  :audience "cs"
  :subkit "systems"
  :ship
    ("promise/all — (promise/all promises) -> promise         — parallel await"
     "promise/race — (promise/race promises) -> promise       — first-to-resolve"
     "promise/settle-all — (promise/settle-all promises) -> promise  — never rejects"
     "promise/timeout — (promise/timeout p ms) -> promise     — race with delay"
     "retry — (retry fn [max-attempts [delay-ms [backoff]]]) -> result"
     "rate-limit — (rate-limit fn count-per-sec) -> throttled-fn"
     "rate-limit/token-bucket — (rate-limit/token-bucket capacity refill-rate) -> limiter"
     "circuit-breaker — (circuit-breaker fn [threshold [reset-ms]]) -> wrapped-fn"
     "debounce, throttle — (debounce fn ms) / (throttle fn ms)"
     "queue/make, queue/push!, queue/pop!, queue/size — bounded/unbounded queues"
     "channel/make, channel/send!, channel/recv!, channel/close! — CSP-style"
     "job/spawn, job/wait, job/cancel — cooperative multitasking on the JS loop"
     "atomic/compare-and-swap! — not real atomics (JS is single-thread) but the shape")
  :have
    ("R7RS §6.10 has make-promise, delay, force, delay-force.  We ship those.
     Nothing beyond the R7RS surface today.")
  :missing
    ("Concurrency primitives beyond raw promises.  Every system-builder
     reaches for these in Python's `asyncio` or JS's Promise combinators.
     Sakura's Scheme surface should have them named.")
  :hello-world
    "(define urls '(\"a\" \"b\" \"c\"))
     (promise/all (map (lambda (u) (http/get u)) urls))"
  :not-base
    ("True parallelism (threads, workers) — variant if ever."
     "Distributed coordination (Raft, gossip) — variant."))

;; ─── SYSTEM-BUILDER KIT (this is the big one) ─────────────────────

(kit
  :audience "system"
  :subkits ("net" "data-formats" "fs" "crypto" "compression" "time"
            "sqlite" "logging" "cli" "regex" "testing" "process" "cron"))

(kit
  :audience "system"
  :subkit "net"
  :ship
    ("http/get — (http/get url [headers]) -> response          — Node's built-in fetch"
     "http/post — (http/post url body [headers]) -> response"
     "http/put, http/delete, http/patch, http/head — the rest"
     "http/request — (http/request method url opts) -> response — full form"
     "response/status — (response/status r) -> integer"
     "response/headers — (response/headers r) -> alist"
     "response/body — (response/body r) -> string"
     "response/json — (response/json r) -> value"
     "server/make — (server/make port handler) -> server          — node:http minimal"
     "server/stop — (server/stop s) -> #t"
     "server/route — (server/route method path handler) -> route  — sugar"
     "ws/connect — (ws/connect url [handlers]) -> ws              — WebSocket client"
     "ws/send! — (ws/send! ws data) -> #t"
     "ws/close! — (ws/close! ws [code]) -> #t"
     "url/parse — (url/parse str) -> record{scheme host port path query fragment}"
     "url/encode, url/decode — (url/encode str) -> string        — percent-encode"
     "url/query-string — (url/query-string alist) -> string"
     "url/query-parse — (url/query-parse str) -> alist")
  :have
    ("Nothing.  system (5) and eng (6) are small, no HTTP.")
  :missing
    ("The entire net kit.  Node has built-in fetch (Node 18+) and node:http +
     node:https + node:url — zero external deps.  WebSocket needs one dep;
     see :deps below.")
  :deps
    ("ws — MIT, mature, ~1MB.  Only dep required beyond Node built-ins.
     Bundling adds ~20KB gzipped to the binary.")
  :hello-world
    "(let* ((r (http/get \"https://api.example.com/status\"))
            (body (response/json r)))
       (if (= (response/status r) 200)
           (hash-ref body 'status)
           (raise (list 'http-error (response/status r)))))"
  :not-base
    ("HTTP/3, QUIC — variant + native."
     "gRPC — variant + external codegen."
     "MQTT, AMQP — variant."))

