     (:phase-2c "control + exceptions + numbers"
      :items (values call-with-values dynamic-wind
              raise raise-continuable with-exception-handler
              error-object family
              floor-slash truncate-slash family exact-integer-sqrt
              numerator denominator complex? predicates))
     (:phase-2d "ports + system"
      :items (string-ports bytevector-ports current-*-port port-predicates
              read-char peek-char read-line eof-object
              command-line current-second features cond-expand)))
  :deferred-with-decision-entries
    ((call/cc "decision-004")
     (dynamic-wind-continuation-aware "extend decision-004")
     (eval-runtime-source "decision-005")
     (mutable-pairs "decision-006")
     (mutable-strings "NEW decision")
     (file-ports "decision-010")
     (complex-numbers "NEW decision under decision-011")
     (exact-rationals "decision-011")
     (define-library "NEW decision")))
