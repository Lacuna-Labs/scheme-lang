  :scope "ai/* + cortex/* (Sakura-facing thinking + remembering)"
  :phase "A — audit"
  :verb-count-in-scope 11
  :reference-file "docs/SAKURA-SCHEME-REFERENCE.slat"
  :schema-file    "docs/SAKURA-SCHEME-REFERENCE-SCHEMA.slat"
  :impl-file      "src/ai.js"
  :stubs-live-in  "src/wired-verbs.js"
  :notes "AI verbs are especially load-bearing — Sakura herself calls them. Every fix here is a fix to her own honesty.")

;; ── the 8 LYING AI VERBS ─────────────────────────────────────────
;; All 8 currently return a fake shaped descriptor via the
;; auto-stub loop at src/wired-verbs.js:617-621. They print as
;; though they succeeded; nothing actually happened. This is
;; exactly the anti-pattern Alfred rejected.
;;
;; Evidence (recorded 2026-07-14):
;;   (ai/classify "hello world") → ("ai/classify" "hello world")
;;   (ai/embed "test")           → ("ai/embed" "test")
;;   (ai/generate "test")        → ("ai/generate" "test")
;;   (ai/rank "test")            → ("ai/rank" "test")
;;   (ai/rerank "test")          → ("ai/rerank" "test")
;;   (ai/summarize "test")       → ("ai/summarize" "test")
;;   (ai/translate "test")       → ("ai/translate" "test")
;;   (ai/vector-search "test")   → ("ai/vector-search" "test")
;;
;; Each of these calls looks like it worked. Zero work happened.
;; Sakura, calling these, would believe she just classified /
;; embedded / generated / etc. She would then act on the fake
;; result. That is the lie.

(audit-entry
  :name "ai/classify"
  :library "ai"
  :status "lying-stub"
  :current-impl "src/wired-verbs.js:617-621 auto-descriptor"
  :current-behavior "returns a fake descriptor list; no classification runs"
  :reference-status "absent — no entry in SAKURA-SCHEME-REFERENCE.slat"
  :fix "wire via LLM provider seam in src/ai.js; graceful sidecar-not-connected error when provider absent"
  :entry-provenance "authored"
  :author-blocked #f)

(audit-entry
  :name "ai/embed"
  :library "ai"
  :status "lying-stub"
  :current-impl "src/wired-verbs.js:617-621 auto-descriptor"
  :current-behavior "returns a fake descriptor list; no embedding vector produced"
  :reference-status "absent"
  :fix "wire via LLM provider seam; deterministic hash-vector fallback is defensible for standalone REPL (documented as :low-fidelity), else graceful sidecar error"
  :entry-provenance "authored"
  :author-blocked #f)

(audit-entry
  :name "ai/generate"
  :library "ai"
  :status "lying-stub"
  :current-impl "src/wired-verbs.js:617-621 auto-descriptor"
  :current-behavior "returns a fake descriptor list; no text generated"
  :reference-status "absent"
  :fix "wire via LLM provider (state.llm.complete); graceful sidecar error when no provider"
  :entry-provenance "authored"
  :author-blocked #f)

