;; ── PHASE B PLAN ──────────────────────────────────────────────────

(plan
  :phase "B"
  :order
    ("cortex/read (already-wired — lift to full schema first, easiest to REPL-verify)"
     "cortex/write"
     "cortex/topk"
     "ai/embed (deterministic hash-vector fallback — REPL runnable, honestly labeled)"
     "ai/classify"
     "ai/generate"
     "ai/summarize"
     "ai/translate"
     "ai/rank"
     "ai/rerank"
     "ai/vector-search")
  :fallback-shape
    "Every ai/* verb without a live provider raises:
       (error 'external-service \"requires-python-ml-sidecar\" verb args)
     This is CALLABLE and HONEST. The error IS the answer. Sakura
     handling this error correctly is a first-class use case."
  :verification "each example tier via ./bin/sakura-scheme eval; graceful-error return counts"
  :commit-shape "kenji-ai: wire <name>"
  :push "per-verb, no force, no --no-verify")

;; End of audit. Waiting on schema lock, then Phase B begins.
