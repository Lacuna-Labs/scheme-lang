  :current-impl "src/wired-verbs.js:1099"
  :current-behavior "returns ('surface/digest'); no digest computed"
  :fix "if fb bound, compute a stable hash of the pixel buffer (fnv1a over rgba bytes) and return it as a hex string. Real digest, verifiable, deterministic. Graceful error if no fb."
  :entry-provenance "authored"
  :author-blocked #f)

