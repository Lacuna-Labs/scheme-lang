  :name "surface/describe"
  :library "surface"
  :status "lying-descriptor"
  :current-impl "src/wired-verbs.js:1099"
  :current-behavior "returns ('surface/describe'); no description produced"
  :fix "return a shaped record with :width :height :bg-color read from the current framebuffer if one exists; graceful error otherwise. Real data, no lie."
  :entry-provenance "authored"
  :author-blocked #f)

(audit-entry
