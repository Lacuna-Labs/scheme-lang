;; ─── PHASE B PLAN ──────────────────────────────────────────────────────

(plan
  :phase "B"
  :ordering-strategy
    "Group by namespace to keep context tight. Within each namespace,
     lift real impls first (fast wins, learn the schema-lift shape),
     then fix lying descriptors. Commit per verb. Push per verb."
  :order
    (;; Wave 1 — Real-impl schema-lifts (no JS changes, just SLAT).
     ;; Fastest and lowest risk. Establishes the 5-tier + slice
     ;; template Sora will apply to the whole scope.
     "geom/rotate" "geom/rotate-about" "geom/translate" "geom/segment"
     "geom/triangle" "geom/triangle-area-heron" "geom/right-triangle-angle"
     "geom/solve-right" "geom/transform-polygon" "geom/slope"
     "vec/+" "vec/-" "vec/=" "vec/dim" "vec/ref" "vec/->string" "vec/angle-between"
     "matrix/+" "matrix/-" "matrix/*" "matrix/=" "matrix/->string"
     "stat/count" "stat/variance-sample" "stat/sd" "stat/sd-sample"
     "stat/quartile" "stat/probability" "stat/histogram-counts" "stat/histogram"
     "chem/atomic-weight" "chem/formula-counts"
     "beat/on"
     ;; Wave 2 — Real-impl-with-partial-behavior. geom/transform-polygon
     ;; is currently identity; fix the JS + lift SLAT together.
     "geom/similar?"
     "geom/transform-polygon"
     "group/count"
     "floor/problem?"
     ;; Wave 3 — Lying descriptors that CAN honestly compute standalone.
     "chem/balance"
     "pattern/clave"
     "domain/of"
     "route/off-domain"
     "animation/reflow-policy"
     "animation/set-reflow-policy"
     "animation/budget"
     "transport/tempo"
     ;; Wave 4 — Lying descriptors that require live subsystems.
     ;; These get real state-consulting impls PLUS graceful errors
     ;; when the subsystem isn't present.
     "surface/curtain"
     "surface/describe"
     "surface/digest"
     "surface/spotlight"
     "text/draw"
     "object/fetch"
     "object/spawn"
     "artifact/cite"
     "artifact/delete"
     "group/each"
     "group/find"
     "weather/conjure"
     "collision/define-layers!")
  :impl-locations
    ((geom     "src/wired-verbs.js (existing) — may extract to src/geom.js if it grows")
     (vec      "src/wired-verbs.js")
     (matrix   "src/wired-verbs.js")
     (stat     "src/wired-verbs.js")
     (chem     "src/wired-verbs.js — balance may warrant new src/chem.js")
     (surface  "src/wired-verbs.js — real ops route through media.js framebuffer")
     (animation "src/wired-verbs.js — module-level state for reflow policy")
     (group    "src/wired-verbs.js — group state via game.js")
     (artifact "src/wired-verbs.js — artifact store module-level")
     (object   "src/wired-verbs.js — routes to game.js entity registry")
     (text     "src/wired-verbs.js — routes to media.js text ops")
     (weather  "src/wired-verbs.js — module-level weather state")
     (pattern  "src/wired-verbs.js — hard-coded clave tables")
     (route    "src/wired-verbs.js — module-level route list")
     (transport "src/wired-verbs.js — module-level tempo state")
     (beat     "src/wired-verbs.js")
     (collision "src/wired-verbs.js — routes to game.js layer table")
     (domain   "src/wired-verbs.js — small classifier table")
     (floor    "src/wired-verbs.js — module-level floor state"))
  :error-shape
    "Graceful errors use a common shape:
       (error 'external-subsystem \"<what's missing>\" <verb> <args>)
     This is CALLABLE and HONEST. The error IS the answer. Sakura
     handling this error correctly is a first-class use case. See
     kenji-ai for the same doctrine applied to ai/*."
  :verification
    "Every example tier via ./bin/sakura-scheme eval. If it doesn't
     run cleanly, DO NOT ship. Master tier may compose with other
     verbs; those compositions verified too."
  :commit-shape "sora-everything: wire <name>"
  :push "per-verb, no --force, no --no-verify"
  :stamp "on each successful verb: architect reads the stamps file and
          bumps the counter. Sora does not touch the stamps file
          directly."
  :no-lie-rules
    ("No auto-stubs — every entry hand-authored."
     "No hallucinated behavior — every claim is REPL-verified before commit."
     "No swallowed errors — every :raises documented on the SLAT entry."
     "No pretend-success — if the subsystem isn't wired, raise a clear error."
     "5 example tiers each — novice, apprentice, intermediate, expert, master."
     "master tier composes with other verbs from the same or neighboring library."
     "long-tail is where quality slips — Sora holds the standard."))

