;; ═══════════════════════════════════════════════════════════════════════
;; sora-everything — Phase A audit
;; Lane: the "everything else" long-tail wiring lane
;; Date: 2026-07-14
;; Author: Sora (Lacuna Eng Lead — everything-else wiring lane)
;; Branch: verbs/wire-596-2026-07-14
;;
;; Scope (~57 verbs across 19 namespaces):
;;   geom/* (~11) stat/* (~8) vec/* (~7) matrix/* (~5)
;;   surface/* (~4) animation/* (~3) chem/* (~3) group/* (~3)
;;   artifact/* (~2) object/* (~2) text/* (~1) weather/* (~1)
;;   pattern/* (~1) route/* (~1) transport/* (~1) beat/* (~1)
;;   collision/* (~1) domain/* (~1) floor/* (~1)
;;
;; Doctrine (Alfred): "We can't lie to people. They trust us."
;; No auto-stubs. No hallucinated behavior. Every verb hand-authored.
;; 5-tier examples, REPL-verified each. Schema at
;; docs/SAKURA-SCHEME-REFERENCE-SCHEMA.slat is locked (v1.0).
;; ═══════════════════════════════════════════════════════════════════════

(audit
  :lane "sora-everything"
  :namespaces ("geom/*" "stat/*" "vec/*" "matrix/*" "surface/*" "animation/*"
               "chem/*" "group/*" "artifact/*" "object/*" "text/*" "weather/*"
               "pattern/*" "route/*" "transport/*" "beat/*" "collision/*"
               "domain/*" "floor/*")
  :in-scope-total 57
  :method "makeSakuraEnv full stack; probe each name; classify STUB vs IMPL vs LYING-DESCRIPTOR"
  :ref-file "docs/SAKURA-SCHEME-REFERENCE.slat"
  :schema "docs/SAKURA-SCHEME-REFERENCE-SCHEMA.slat"
  :stubs-live-in "src/wired-verbs.js"
  :repo "Lacuna-Labs/scheme-lang"
  :branch "verbs/wire-596-2026-07-14"
  :note "Every name in scope is bound (no unbound symbols). But binding is
         not the same as truth-telling. Two failure modes present:
           (1) 'REAL IMPL, PARTIAL REFERENCE' — the JS does honest work
               but the SLAT entry has only 3 example tiers and no
               :impl-status. Fix: schema-lift the SLAT entry.
           (2) 'LYING DESCRIPTOR STUB' — the JS returns a shaped
               list like ('surface/curtain') and pretends the call
               succeeded. Sakura calling this would believe she just
               drew a curtain / spawned an object / balanced a
               chemical equation. She did not. Fix: replace with
               either a real impl (where standalone JS supports it)
               or a graceful error that HONESTLY says the subsystem
               isn't wired in this build.")

;; ─── Bucket 1: REAL IMPLS, need schema-lift only (33 verbs) ─────────────
;;
;; These do honest work in wired-verbs.js. REPL-verified today with
;; concrete inputs. The impl is fine; only the SLAT entry needs to be
;; lifted to schema v1.0 (add :impl-status "wired", :impl-file
;; "src/wired-verbs.js", extend from 3 tiers to 5 tiers, add discipline
;; slices for math-y ones).

(bucket :name "real-impl-needs-schema-lift" :count 33
  :phase-b-action "extend SLAT entry to 5 tiers + :impl-status wired + slices; no JS changes needed"
  :verbs (
    ;; geom — real 2D geometry
    "geom/rotate"                 ;; (x, y, angle) -> [x', y']
    "geom/rotate-about"           ;; (x, y, cx, cy, angle) -> [x', y']
    "geom/translate"              ;; (x, y, dx, dy) -> [x+dx, y+dy]
    "geom/segment"                ;; (x1, y1, x2, y2) -> ('segment x1 y1 x2 y2)
    "geom/triangle"               ;; (a, b, c) -> ('triangle a b c)
    "geom/triangle-area-heron"    ;; Heron's formula, verified: (3,4,5)=6
    "geom/right-triangle-angle"   ;; atan2(opp, adj)
    "geom/solve-right"            ;; (a, b) -> [a, b, hypot, angle]
    "geom/transform-polygon"      ;; identity pass-through for now
    "geom/slope"                  ;; (y2-y1)/(x2-x1), NaN for vertical
    ;; vec — vector arithmetic, list-based
    "vec/+"                       ;; verified: (vec/+ '(1 2 3) '(4 5 6)) = (5 7 9)
    "vec/-"
    "vec/="
    "vec/dim"
    "vec/ref"
    "vec/->string"
    "vec/angle-between"
    ;; matrix — 2D matrix arithmetic, list-of-lists
    "matrix/+"
    "matrix/-"
    "matrix/*"                    ;; verified: 2x2 * 2x2 = correct 2x2 product
    "matrix/="
    "matrix/->string"
    ;; stat — small stats with real formulas
    "stat/count"
    "stat/variance-sample"
    "stat/sd"                     ;; verified: sd of (2 4 4 4 5 5 7 9) = 2 (population)
    "stat/sd-sample"
    "stat/quartile"
    "stat/probability"
    "stat/histogram-counts"
    "stat/histogram"
    ;; chem — real periodic table + parser
    "chem/atomic-weight"          ;; verified: (chem/atomic-weight 'H) = 1.008
    "chem/formula-counts"         ;; verified: "H2O" -> (("H" 2) ("O" 1))
    ;; beat — returns shaped record (not descriptor lie), consumable
    "beat/on"                     ;; returns {kind: beat-on, ok, beatIndex, totalBeats}
    ))

;; ─── Bucket 2: LYING DESCRIPTOR STUBS (20 verbs) ────────────────────────
;;
;; These currently return a shaped list like ('animation/budget') and
;; pretend the call succeeded. Zero work happens. Alfred rejected this
;; anti-pattern. Same shape as the ai/* lies Kenji is fixing.
;;
;; Evidence (recorded 2026-07-14 via ./bin/sakura-scheme eval):
;;   (chem/balance "H2 + O2 -> H2O") -> ("chem/balance" "H2 + O2 -> H2O")
;;   (surface/curtain)               -> ("surface/curtain")
;;   (surface/describe)              -> ("surface/describe")
;;   (animation/budget)              -> ("animation/budget")
;;   (object/spawn 'coin 10 20)      -> ("object/spawn" coin 10 20)
;;   (text/draw "hi" 5 5)            -> ("text/draw" "hi" 5 5)
;;
;; Each of these calls LOOKS like it worked. Nothing actually happened.
;; A caller reading a book example runs one of these, gets back a list,
;; and (a) if it's called for its side effect [text/draw, surface/paint]
;; the world doesn't change but no error signals that; (b) if called for
;; its return [chem/balance, domain/of] the caller gets a nonsense
;; list-of-tag-and-args and may operate on it as though it were data.
;;
;; Fix pattern — per verb:
;;   (a) Where standalone JS CAN honestly compute the answer, wire a
;;       real impl. (chem/balance = matrix null-space; domain/of =
;;       category lookup on kind; text/draw = write into the current
;;       framebuffer if one exists; etc.)
;;   (b) Where the verb REQUIRES a live subsystem (audio hardware,
;;       host frame loop, live surface pipeline), raise a graceful
;;       :external-service error whose message tells the caller
;;       exactly what's missing. The error IS the answer. Sakura
;;       handling this error correctly is a first-class use case.
;;   (c) NEVER return a fake tagged descriptor and pretend success.

(audit-entry
  :name "geom/similar?"
  :library "geom"
  :status "always-false-lie"
  :current-impl "src/wired-verbs.js:894 → () => false"
  :current-behavior "returns #f regardless of input; two congruent triangles report #f"
  :fix "implement real similarity check: normalize both polygons by
        edge-length ratio and interior angles; #t iff same up to
        rotation/reflection/uniform-scale. For non-polygon inputs raise
        a shape error."
  :entry-provenance "authored"
  :author-blocked #f)

(audit-entry
  :name "surface/curtain"
  :library "surface"
  :status "lying-descriptor"
  :current-impl "src/wired-verbs.js:1099 (surfaceExtras loop → descriptor)"
  :current-behavior "returns ('surface/curtain'); no curtain drawn"
  :reference-status "3-tier examples present, no :impl-status"
  :fix "if a framebuffer is bound, draw an actual darkening overlay (rgba over full extent); else raise :no-surface-active. Ship as a real fb op; surface/* is REPL-runnable only inside a media host."
  :entry-provenance "authored"
  :author-blocked #f)

