;; ═══════════════════════════════════════════════════════════════
;; EXECUTION PLAN
;; ═══════════════════════════════════════════════════════════════

(execution-plan
  :phase-1 "high-priority recoveries in dependency order: 001 → 002 → 003 → 004 (Reason volumes) — one commit per volume, tested by chapter count."
  :phase-2 "misfiled books: 008 (Jesse), 009 (Scheme ramp-up), 010 (Reason Code), 011 (Book Extensions). Parallel-safe."
  :phase-3 "reference-relocation: 006 (reference-manual fragments), 007 (scheme-lang-docs). Parallel-safe."
  :phase-4 "medium-priority: 005 (Math II flatten), 013 (shortened-block audit), 014 (lacuna-labs eng misattribution), 015 (engineering-spine)."
  :phase-5 "low-priority: 012 (alias-mirror archive), 016 (ambient cleanup)."
  :protocol
    ("Every recovery-item gets a stamp record in docs/reports/recovery-stamps-2026-07-14.slat when complete."
     "No source files deleted — moves are copy+preserve; original stays under BOOK/ per NO-DELETES doctrine."
     "Every migrated chapter tagged :arc <original-volume> so Sakura's :help can surface the arc when relevant."
     "Every migrated chapter tagged :provenance :source-path <original> — so future audits can trace where each file came from."
     "Merged books get a MANIFEST.slat updated to reflect the new chapter count + arc list.")
  :verification-suite
    ("For each recovered book, chapter count = source count minus any explicitly-flagged-as-alias duplicates."
     "For each restored shortened block, canonical file grew in line count."
     "For each relocated reference fragment, either merged into canonical reference OR archived — never both, never neither."
     "Final: `find ~/code/curator/scheme-books/.wrong-attribution-2026-07-13/ -type f` returns only files documented as intentionally archived.")
  :estimated-total-hours 34
  :recommended-lane-count 3-4
  :recommended-name "Lost Material Recovery Lane")

;; ═══════════════════════════════════════════════════════════════
;; SAFEGUARDS
;; ═══════════════════════════════════════════════════════════════

(safeguards
  :no-deletes "NEVER delete a source file. Copy to canonical + leave source in BOOK/ or .aliases/. Merkle-preserved."
  :no-content-loss "Concatenate all chunks + diff against source before committing a chunking split."
  :every-move-logged "docs/reports/recovery-log-2026-07-14.slat gets a (moved :from :to :date :verification) record per file."
  :chapter-count-invariant "For each book, chapter count after = chapter count before + net-added-from-recovery. Never less."
  :arc-tags-durable "Roman-numeral volumes flattened lose the number but keep the arc — chapters remain findable by :arc field."
  :provenance-chain "Every chapter has :provenance :source-path so 6-months-from-now anyone can trace where each file originated."
  :on-conflict "If two source paths have same-named content: hash both, log divergence, ask Alfred. Never silently pick one.")
