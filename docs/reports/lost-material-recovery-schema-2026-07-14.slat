;; ═══════════════════════════════════════════════════════════════
;; LOST + MISPLACED MATERIAL — RECOVERY SCHEMA
;; 2026-07-14, Alfred's directive
;;
;; This document is the plan for recovering every lost + misplaced
;; scheme doc + book chapter + reference fragment, aligned with the
;; new Base + Variant doctrine (see project_sakura_scheme_base_
;; variant_doctrine_2026_07_14.md in memory).
;;
;; Two audiences read this:
;;   1. Alfred — reviews the plan, adjusts priorities.
;;   2. Recovery lane(s) — executes item-by-item.
;;
;; ─── The rules ──────────────────────────────────────────────────
;;
;; 1. Roman-numeral stuff (reason-i/ii/iii/iv, math-book-ii, etc.)
;;    gets FLATTENED. Chapters merge into the canonical book under
;;    semantic names — never a Roman numeral in the final filename.
;;    Volume identity is preserved in the chapter TOPIC + optional
;;    :arc field in the record, not in the filename.
;;
;; 2. References go to their proper home:
;;      - Sakura Scheme Reference proper → scheme-lang/docs/
;;      - Engineering docs → scheme-lang/docs/
;;      - Book-shaped teaching material → curator/scheme-books/book-of-*
;;
;; 3. Shortened blocks (chapters abridged in a previous pass) get
;;    restored to full length from BOOK/ recovery lanes.
;;
;; 4. Misfiled books (in .wrong-attribution/) get a home decision +
;;    move. No content deleted; original preserved via Merkle trail.
;;
;; 5. "The Book of X" aliases (six mirror entries with 1 unique
;;    chapter each) get verified against canonical, then archived to
;;    scheme-books/.aliases/ — NOT deleted (no-deletes doctrine).
;;
;; 6. Every recovery item is a (recovery-item ...) SLAT record with
;;    the schema below. Executor writes a stamp per item.
;; ═══════════════════════════════════════════════════════════════

(schema
  :version "1.0"
  :for "lost-material-recovery"
  :required (:id :category :source-paths :new-canonical-home :variant)
  :fields
    ((:id                  "recovery-NNN, monotonic")
     (:category            "one of: roman-numeral-flatten | reference-relocation | misfiled-book | alias-mirror | shortened-block | misattribution-review | ambient-cleanup")
     (:source-paths        "list of absolute paths preserved in BOOK/ or elsewhere")
     (:file-count          "count of source files")
     (:current-status      "preserved-in-BOOK | misfiled-wrong-attribution | abridged-canonical | mirror-with-canonical | orphan | already-canonical")
     (:new-canonical-home  "absolute or relative path where this lives after recovery")
     (:variant             "base | curator | reference | engineering — per Base+Variant doctrine")
     (:rename-map          "list of (:from path :to path) — semantic filename fixes")
     (:merge-with          "canonical book/doc to merge into, or nil for standalone")
     (:arc                 "optional volume/arc tag preserved in the record — e.g. 'four-gates for reason-i content")
     (:verification        "how we confirm success — diff hash | REPL passes examples | chapter count matches source | ...")
     (:priority            "high | medium | low")
     (:estimate-hours      "rough time to execute")
     (:depends-on          "list of other recovery-ids that must complete first")
     (:notes               "free prose")))

